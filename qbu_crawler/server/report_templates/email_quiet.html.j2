<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <!--[if mso]><style>table{border-collapse:collapse;}td{font-family:Arial,sans-serif;}</style><![endif]-->
</head>
<body style="margin:0;padding:0;background:#f7f7f5;font-family:'Microsoft YaHei','PingFang SC',Arial,sans-serif;">

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#f7f7f5;">
<tr><td align="center" style="padding:20px 10px;">

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="max-width:600px;background:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.06);">

  <!-- ===== 1. HEADER BAR ===== -->
  <tr>
    <td style="background:#4f46e5;padding:16px 24px;">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0"><tr>
        <td style="color:#ffffff;font-size:12px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;">QBU 网评监控{% if is_weekly %} · 本周{% endif %}</td>
        <td style="color:rgba(255,255,255,0.6);font-size:11px;text-align:right;white-space:nowrap;">{{ logical_date }}</td>
      </tr></table>
    </td>
  </tr>

  <!-- ===== 2. QUIET STATUS LINE ===== -->
  <tr>
    <td style="background:#ecfdf5;padding:10px 24px;text-align:center;">
      <span style="color:#047857;font-size:12px;font-weight:600;">
        ✓ {% if is_weekly %}本周无新增评论{% else %}今日无新评论{% endif %}
        {% if consecutive_quiet_days and consecutive_quiet_days > 1 %} · 已连续静默 {{ consecutive_quiet_days }} 天{% endif %}
        · 采集于 {{ (snapshot.snapshot_at or "")[:16] }}
      </span>
    </td>
  </tr>

  <!-- ===== 3. KPI SNAPSHOT (4 cards — 2x2) ===== -->
  {# KPI 快照优先取当日 analytics（effective_analytics）；
     仅当当日 analytics 生成失败时回退到昨日，避免展示空白。 #}
  {% set _kpis = (analytics or previous_analytics or {}).get("kpis", {}) %}
  <tr>
    <td style="padding:20px 24px 8px;">
      <div style="font-size:10px;color:#8e8ea0;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:12px;">健康快照</div>
      <!-- Row 1 -->
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0"><tr>
        <td width="49%" style="padding:14px 12px;background:#f7f7f5;border:1px solid #e5e4e0;border-radius:8px;text-align:center;vertical-align:top;">
          <div style="font-size:9px;color:#8e8ea0;margin-bottom:6px;">健康指数</div>
          <div style="font-size:28px;font-weight:900;color:#4f46e5;line-height:1;">{{ _kpis.get("health_index", "—") }}</div>
          <div style="font-size:9px;color:#8e8ea0;margin-top:4px;">/ 100</div>
        </td>
        <td width="2%"></td>
        <td width="49%" style="padding:14px 12px;background:#f7f7f5;border:1px solid #e5e4e0;border-radius:8px;text-align:center;vertical-align:top;">
          <div style="font-size:9px;color:#8e8ea0;margin-bottom:6px;">差评率</div>
          <div style="font-size:28px;font-weight:900;color:#1a1a2e;line-height:1;">{{ _kpis.get("own_negative_review_rate_display", "—") }}</div>
          <div style="font-size:9px;color:#8e8ea0;margin-top:4px;">自有产品</div>
        </td>
      </tr></table>
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0"><tr><td style="height:8px;"></td></tr></table>
      <!-- Row 2 -->
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0"><tr>
        <td width="49%" style="padding:14px 12px;background:#f7f7f5;border:1px solid #e5e4e0;border-radius:8px;text-align:center;vertical-align:top;">
          <div style="font-size:9px;color:#8e8ea0;margin-bottom:6px;">评论样本量</div>
          <div style="font-size:28px;font-weight:900;color:#1a1a2e;line-height:1;">{{ _kpis.get("own_review_rows", 0) }}</div>
          <div style="font-size:9px;color:#8e8ea0;margin-top:4px;">累计条数</div>
        </td>
        <td width="2%"></td>
        <td width="49%" style="padding:14px 12px;background:#f7f7f5;border:1px solid #e5e4e0;border-radius:8px;text-align:center;vertical-align:top;">
          <div style="font-size:9px;color:#8e8ea0;margin-bottom:6px;">高风险产品</div>
          <div style="font-size:28px;font-weight:900;color:{% if _kpis.get('high_risk_count', 0) > 0 %}#b91c1c{% else %}#047857{% endif %};line-height:1;">{{ _kpis.get("high_risk_count", 0) }}</div>
          <div style="font-size:9px;color:#8e8ea0;margin-top:4px;">自有 {{ _kpis.get("own_product_count", 0) }} / 竞品 {{ _kpis.get("competitor_product_count", 0) }}</div>
        </td>
      </tr></table>
    </td>
  </tr>

  <!-- ===== 4. OUTSTANDING ISSUES ===== -->
  {% set _clusters = ((previous_analytics or {}).get("self", {}) or {}).get("top_negative_clusters", []) %}
  {% set _active = [] %}
  {% for c in _clusters %}{% if c.get("severity") in ("critical", "high", "medium") %}{% set _ = _active.append(c) %}{% endif %}{% endfor %}
  {% if _active %}
  <tr>
    <td style="padding:8px 24px 16px;">
      <div style="font-size:10px;color:#8e8ea0;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:12px;">未解决问题</div>
      {% for c in _active[:5] %}
      {% set sev = c.get("severity", "medium") %}
      {% if sev == "critical" %}{% set sc = "#b91c1c" %}{% set sb = "#fef2f2" %}
      {% elif sev == "high" %}{% set sc = "#c2410c" %}{% set sb = "#fff7ed" %}
      {% else %}{% set sc = "#a16207" %}{% set sb = "#fefce8" %}{% endif %}
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:8px;"><tr>
        <td style="padding:10px 12px;background:#ffffff;border:1px solid #e5e4e0;border-left:3px solid {{ sc }};border-radius:0 6px 6px 0;">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0"><tr>
            <td style="font-size:11px;color:#1a1a2e;">
              <span style="display:inline-block;padding:2px 8px;background:{{ sb }};color:{{ sc }};border-radius:999px;font-size:9px;font-weight:700;margin-right:6px;">{{ c.get("severity_display", sev) }}</span>
              <strong>{{ c.get("label_display", c.get("label_code", "")) }}</strong>
            </td>
            <td style="text-align:right;white-space:nowrap;font-size:10px;color:#8e8ea0;">{{ c.get("review_count", 0) }} 条</td>
          </tr></table>
        </td>
      </tr></table>
      {% endfor %}
    </td>
  </tr>
  {% endif %}

  <!-- ===== 5. TRANSLATION PROGRESS ===== -->
  {% if translate_stats %}
  {% set _total = translate_stats.get("total", 0) %}
  {% set _done = translate_stats.get("done", 0) %}
  {% set _pct = ((_done / (_total or 1)) * 100) | round(0) | int %}
  <tr>
    <td style="padding:8px 24px 16px;background:#f7f7f5;border-top:1px solid #e5e4e0;">
      <div style="font-size:10px;color:#8e8ea0;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:10px;">翻译进度</div>
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:8px;"><tr>
        <td style="background:#e5e4e0;border-radius:999px;height:8px;overflow:hidden;">
          <table role="presentation" height="8" cellpadding="0" cellspacing="0" style="height:8px;"><tr>
            <td width="{{ [_pct, 100] | min }}%" style="background:#4f46e5;height:8px;border-radius:999px;font-size:0;line-height:0;">&nbsp;</td>
          </tr></table>
        </td>
      </tr></table>
      <p style="margin:0;font-size:11px;color:#8e8ea0;line-height:1.6;">
        已翻译 <strong style="color:#1a1a2e;">{{ _done }}</strong> / <strong style="color:#1a1a2e;">{{ _total }}</strong> 条（{{ _pct }}%）
        {% if translate_stats.get("pending", 0) > 0 %} · 待处理 <strong>{{ translate_stats.pending }}</strong>{% endif %}
        {% if translate_stats.get("failed", 0) > 0 %} · <span style="color:#b91c1c;">失败 {{ translate_stats.failed }}</span>{% endif %}
      </p>
    </td>
  </tr>
  {% endif %}

  <!-- ===== 6. FOOTER ===== -->
  <tr>
    <td style="padding:12px 24px;text-align:center;border-top:1px solid #e5e4e0;">
      <p style="margin:0;font-size:10px;color:#8e8ea0;line-height:1.6;">
        QBU 网评监控智能分析系统 · 差评定义：≤{{ threshold or 2 }}星 · 内部资料<br>
        本报告由 AI 自动生成，数据及分析结论仅供参考 · 请勿直接回复此邮件
      </p>
    </td>
  </tr>

</table>
</td></tr>
</table>
</body>
</html>
