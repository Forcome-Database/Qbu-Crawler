{% extends "_email_base.html.j2" %}
{% block content %}
  {% if mode == "partial" %}
    <p style="background:#f0efed;padding:10px 14px;border-radius:6px;border-left:3px solid #8e8ea0;margin-bottom:16px;">
      <strong>基线建立中</strong>：样本积累中，本日数据置信度：样本不足。
    </p>
  {% elif mode == "quiet" %}
    <p style="background:#ecfdf5;padding:10px 14px;border-radius:6px;border-left:3px solid #047857;margin-bottom:16px;">
      <strong>连续 {{ mode_context.quiet_days or 0 }} 天无新评论</strong> · 累积指标稳定。
    </p>
  {% endif %}

  {% if window_reviews %}
  <h3 style="margin:20px 0 8px;font-size:16px;">今日新评论 · {{ window_reviews|length }} 条</h3>
  {% for r in window_reviews[:5] %}
  <div style="padding:10px 12px;background:#f7f7f5;border-radius:6px;margin-bottom:6px;">
    <div style="font-size:12px;color:#8e8ea0;">
      {{ "★"*(r.rating|int if r.rating else 0) }} · {{ r.get("product_name","") }}
    </div>
    <div style="font-size:13px;margin-top:2px;">{{ r.get("headline_cn") or r.get("headline","") }}</div>
  </div>
  {% endfor %}
  {% endif %}

  {% if changes and (changes.price_changes or changes.stock_changes or changes.rating_changes) %}
  <h3 style="margin:20px 0 8px;font-size:16px;">产品数据变动</h3>
  <ul style="font-size:13px;padding-left:18px;">
    {% for c in (changes.price_changes or [])[:5] %}
    <li>{{ c.name }}: ${{ c.old }} → {% if c.new is not none %}${{ c.new }}{% else %}已下架{% endif %}</li>
    {% endfor %}
    {% for c in (changes.stock_changes or [])[:5] %}
    <li>{{ c.name }}: {{ c.old }} → {{ c.new }}</li>
    {% endfor %}
    {% for c in (changes.rating_changes or [])[:5] %}
    <li>{{ c.name }}: {{ c.old }} ⭐ → {{ c.new }} ⭐</li>
    {% endfor %}
  </ul>
  {% endif %}

  {% if action_signals %}
  <div style="margin-top:20px;padding:12px 14px;background:#fef2f2;border-left:3px solid #b91c1c;border-radius:4px;">
    <div style="font-size:11px;font-weight:700;color:#b91c1c;margin-bottom:6px;letter-spacing:0.1em;">需行动</div>
    <ul style="margin:0;padding-left:18px;font-size:13px;">
      {% for s in action_signals %}<li>{{ s.title }}</li>{% endfor %}
    </ul>
  </div>
  {% endif %}
{% endblock %}
