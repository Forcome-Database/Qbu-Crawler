<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>QBU网评监控智能分析报告 {{ logical_date }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700;800&family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700&family=DM+Mono:wght@400;500&family=Noto+Serif+SC:wght@400;600;700&display=swap" rel="stylesheet">
  <style>{{ css_text | safe }}</style>
</head>
<body>
  {% set change_digest = analytics.change_digest or {} %}
  {% set change_summary = change_digest.summary or {} %}
  {% set issue_changes = change_digest.issue_changes or {} %}
  {% set issue_new = issue_changes.new or [] %}
  {% set issue_escalated = issue_changes.escalated or [] %}
  {% set issue_improving = issue_changes.improving or [] %}
  {% set issue_de_escalated = issue_changes.de_escalated or [] %}
  {% set issue_change_items = issue_new + issue_escalated + issue_improving + issue_de_escalated %}
  {% set product_changes = change_digest.product_changes or {} %}
  {% set review_signals = change_digest.review_signals or {} %}
  {% set fresh_negative_reviews = review_signals.fresh_negative_reviews or [] %}
  {% set fresh_competitor_positive_reviews = review_signals.fresh_competitor_positive_reviews or [] %}
  {% set review_signal_items = fresh_negative_reviews + fresh_competitor_positive_reviews %}
  {% set change_warnings = change_digest.warnings or {} %}
  {% set change_empty = change_digest.empty_state or {} %}
  {% set trend_digest = analytics.trend_digest or {} %}
  {% set risk_products = analytics.self.risk_products if analytics.self is defined else [] %}
  {% set gap_analysis = analytics.competitor.gap_analysis if analytics.competitor is defined else [] %}
  {% set benchmarks = analytics.competitor.benchmark_examples if analytics.competitor is defined else [] %}
  {% set own_review_rows = analytics.kpis.own_review_rows or 0 %}
  {% set competitor_review_rows = analytics.kpis.competitor_review_rows or 0 %}
  {% set window_ingested_reviews = change_summary.get("ingested_review_count", analytics.kpis.get("ingested_review_rows", 0)) %}
  {% set recent_review_rows = analytics.kpis.get("recently_published_count", change_summary.fresh_review_count or 0) %}
  {% set report_contract = analytics.report_user_contract or {} %}

  <header class="kpi-bar">
    <div class="kpi-bar-inner">
      <span class="kpi-bar-brand">QBU 网评监控</span>
      <div class="kpi-bar-metrics">
        {% for card in (analytics.kpi_cards or [])[:5] %}
        <span class="kpi-bar-item">{{ card.label }} <strong>{{ card.value }}</strong></span>
        {% endfor %}
      </div>
      <button id="btn-print" class="btn-icon" title="打印 / 导出PDF">⎙</button>
    </div>
  </header>

  <nav class="tab-nav" role="tablist">
    <button data-tab="overview" class="tab-btn tab-active" role="tab">总览</button>
    <button data-tab="changes" class="tab-btn" role="tab">今日变化</button>
    <button data-tab="trends" class="tab-btn" role="tab">变化趋势</button>
    <button data-tab="issues" class="tab-btn" role="tab">问题诊断 <span class="tab-badge">{{ (report_contract.get("issue_diagnostics") or analytics.issue_cards or []) | length }}</span></button>
    <button data-tab="products" class="tab-btn" role="tab">产品排行 <span class="tab-badge">{{ analytics.kpis.own_product_count or 0 }}</span></button>
    <button data-tab="competitive" class="tab-btn" role="tab">竞品启示</button>
    <button data-tab="panorama" class="tab-btn" role="tab">全景数据 <span class="tab-badge">{{ (snapshot.reviews or []) | length }}</span></button>
  </nav>

  <main class="report-main">
    <section id="tab-overview" class="tab-panel tab-active" role="tabpanel">
      <div class="hero">
        <div class="gauge-wrapper" data-health="{{ analytics.kpis.health_index or 50 }}">
          <div class="gauge-arc">
            <div class="gauge-fill"></div>
            <div class="gauge-mask"></div>
            <div class="gauge-value">0</div>
          </div>
          <div class="gauge-label">健康指数</div>
          <div class="gauge-scale"><span>0</span><span>50</span><span>100</span></div>
        </div>
        <div class="hero-text">
          <p class="hero-kicker">Daily Product Intelligence</p>
          <h1 class="hero-title">QBU网评监控智能分析报告</h1>
          <p class="hero-headline">{{ report_copy.hero_headline or (analytics.kpis.health_index|string ~ "/100") }}</p>
          <p class="hero-meta">Run #{{ snapshot.run_id }} · {{ logical_date }} · {{ analytics.mode_display or mode }} · 数据截至 {{ (snapshot.snapshot_at or "")[:16] }}</p>
        </div>
      </div>

      <div class="kpi-grid">
        {% for card in analytics.kpi_cards or [] %}
        <div class="kpi-card reveal">
          <span class="kpi-label">{{ card.label }}{% if card.tooltip %} <span class="tip-trigger" data-tip="{{ card.tooltip }}">?</span>{% endif %}</span>
          <strong class="kpi-value {{ card.value_class or '' }}">{{ card.value }}</strong>
          {% if card.delta_display %}<span class="kpi-delta {{ card.delta_class or '' }}">{{ card.delta_display }}</span>{% endif %}
        </div>
        {% endfor %}
      </div>

      <div class="review-scope-grid">
        <div class="review-scope-item"><span>累计自有评论</span><strong>{{ own_review_rows }}</strong></div>
        <div class="review-scope-item"><span>累计竞品评论</span><strong>{{ competitor_review_rows }}</strong></div>
        <div class="review-scope-item"><span>基线样本评论</span><strong>{{ window_ingested_reviews or 0 }}</strong></div>
        <div class="review-scope-item"><span>近30天评论</span><strong>{{ recent_review_rows or 0 }}</strong></div>
      </div>

      {% if alert_level and alert_text %}
      <div class="alert-banner alert-{{ alert_level }}">{{ alert_text }}</div>
      {% endif %}

      <div class="exec-grid">
        <article class="exec-block reveal">
          <div class="exec-block-header">
            <span class="exec-block-icon icon-judgment">●</span>
            <h3>关键判断</h3>
          </div>
          <div class="exec-block-body">
            <ul>
              {% for item in (report_copy.executive_bullets or [])[:3] %}
              <li>{{ item }}</li>
              {% endfor %}
            </ul>
          </div>
        </article>
        <article class="exec-block reveal">
          <div class="exec-block-header">
            <span class="exec-block-icon icon-scope">●</span>
            <h3>报告口径</h3>
          </div>
          <div class="exec-block-body">
            <div class="exec-scope-row"><span class="exec-scope-label">报告模式</span><span class="exec-scope-value">{{ analytics.mode_display or mode }}</span></div>
            <div class="exec-scope-row"><span class="exec-scope-label">自有产品</span><span class="exec-scope-value">{{ analytics.kpis.own_product_count or 0 }} · 累计评论 {{ own_review_rows }} 条</span></div>
            <div class="exec-scope-row"><span class="exec-scope-label">竞品</span><span class="exec-scope-value">{{ analytics.kpis.competitor_product_count or 0 }} · 累计评论 {{ competitor_review_rows }} 条</span></div>
            <div class="exec-scope-row"><span class="exec-scope-label">差评阈值</span><span class="exec-scope-value">≤ {{ threshold or 2 }} 星</span></div>
          </div>
        </article>
      </div>

      {# F011 §4.2.2 (H14) — 建议行动：short_title 作主显，full_action 折叠 #}
      {% set _priorities = report_contract.get("action_priorities") or [] %}
      {% if _priorities %}
      <section class="recommendations">
        <h2>建议行动</h2>
        {% for rec in _priorities[:5] %}
        <div class="recommendation-card reveal">
          <span class="rec-number">{{ loop.index }}</span>
          <div class="rec-content">
            <h3 class="rec-title">{{ rec.short_title or rec.label_display or rec.label_code }}</h3>
            <div class="rec-meta">影响 {{ rec.affected_products_count or 0 }} 款 · 证据 {{ rec.evidence_count or 0 }} 条</div>
            <details class="rec-details">
              <summary>详情</summary>
              <p class="rec-full-action">{{ rec.full_action }}</p>
              {% if rec.evidence_review_ids %}
              <div class="evidence-refs">
                {% for rid in rec.evidence_review_ids[:5] %}
                  {# F011 §4.2.2 — chip target depends on matching id="review-{{ rid }}" rendered
                     on the panorama-table <tr> below; do not rename without updating both ends. #}
                  <a href="#review-{{ rid }}" class="evidence-chip">#{{ rid }}</a>
                {% endfor %}
                {% if (rec.evidence_review_ids | length) > 5 %}
                  <span class="evidence-more">+{{ (rec.evidence_review_ids | length) - 5 }} 更多</span>
                {% endif %}
              </div>
              {% endif %}
              {% if rec.affected_products %}
              <div class="affected-products">影响 SKU: {{ rec.affected_products | join("、") }}</div>
              {% endif %}
            </details>
          </div>
        </div>
        {% endfor %}
      </section>
      {% endif %}
    </section>

    <section id="tab-changes" class="tab-panel" role="tabpanel">
      <h2 class="section-title">今日变化</h2>
      <p class="section-sub">只看本期入库信号，不把全量现状和历史趋势混在一起。</p>

      {# F011 §4.2.4 — bootstrap 单卡 / mature 三层金字塔 #}
      {% if analytics.report_semantics == "bootstrap" or change_digest.view_state == "bootstrap" %}
      {% set bd = (analytics.report_user_contract or {}).get("bootstrap_digest") or {} %}
      {% set bs = bd.baseline_summary or {} %}
      {% set bs_product_count = bs.get("product_count") %}
      {% set bs_review_count = bs.get("review_count") %}
      {% set bs_coverage_rate = bs.get("coverage_rate") %}
      {% set bs_translation_rate = bs.get("translation_completion_rate") %}
      <div class="info-card bootstrap-notice">
        <strong>{{ bs.headline or "监控起点已建立" }}</strong>
        <div>当前截面：{{ bs_product_count if bs_product_count is not none else 0 }} 款产品 / {{ bs_review_count if bs_review_count is not none else 0 }} 条评论</div>
        {% if bs_coverage_rate is not none or bs_translation_rate is not none %}
        <div>
          {% if bs_coverage_rate is not none %}覆盖率：{{ "%.0f"|format(bs_coverage_rate * 100) }}%{% endif %}
          {% if bs_translation_rate is not none %}{% if bs_coverage_rate is not none %} · {% endif %}翻译完成率：{{ "%.0f"|format(bs_translation_rate * 100) }}%{% endif %}
        </div>
        {% endif %}
        {% if bd.immediate_attention %}
        <ul>
          {% for item in bd.immediate_attention[:3] %}
          <li>{{ item }}</li>
          {% endfor %}
        </ul>
        {% endif %}
      </div>
      {% else %}
      {% set ia = change_digest.immediate_attention or {} %}
      {% set tc = change_digest.trend_changes or {} %}
      {% set co = change_digest.competitive_opportunities or {} %}

      {# Layer 1: 立即关注 #}
      {% if ia.own_new_negative_reviews or ia.own_rating_drops or ia.own_stock_alerts %}
      <article class="comp-card change-card change-card-attention">
        <header class="comp-card-head">
          <span class="comp-icon icon-fire">🔥</span>
          <div>
            <h3>立即关注</h3>
            <p class="comp-sub">本期入库的我方负面信号 — 优先处理</p>
          </div>
        </header>
        <ul class="change-list">
          {% for item in ia.own_new_negative_reviews or [] %}
          {% set _problems = (item.primary_problems_display or []) | select | list %}
          {% if not _problems %}{% set _problems = item.primary_problems or [] %}{% endif %}
          <li class="change-row change-row-danger">
            <span class="change-tag tag-danger">新差评 {{ item.review_count or 0 }} 条</span>
            <span class="change-product">{{ item.product_name or "未命名产品" }}</span>
            <span class="change-detail">主要问题：{{ _problems | join('、') or "暂无标签" }}</span>
          </li>
          {% endfor %}
          {% for item in ia.own_rating_drops or [] %}
          {% set _from = item.rating_from if item.rating_from is not none else item.prev %}
          {% set _to = item.rating_to if item.rating_to is not none else item.new %}
          <li class="change-row change-row-danger">
            <span class="change-tag tag-danger">评分下滑</span>
            <span class="change-product">{{ item.product_name or item.sku or "未命名产品" }}</span>
            <span class="change-detail">{{ _from if _from is not none else "-" }} → {{ _to if _to is not none else "-" }}{% if item.delta is not none %} <em class="delta-down">({{ "{:+.2f}".format(item.delta) }})</em>{% endif %}</span>
          </li>
          {% endfor %}
          {% for item in ia.own_stock_alerts or [] %}
          <li class="change-row change-row-danger">
            <span class="change-tag tag-danger">库存告警</span>
            <span class="change-product">{{ item.product_name or item.sku or "未命名产品" }}</span>
            <span class="change-detail">{% if item.new_status %}{{ item.new_status }}{% else %}缺货{% endif %}</span>
          </li>
          {% endfor %}
        </ul>
      </article>
      {% endif %}

      {# Layer 2: 趋势变化 #}
      {% if tc.new_issues or tc.escalated_issues or tc.improving_issues %}
      <article class="comp-card change-card change-card-trend">
        <header class="comp-card-head">
          <span class="comp-icon icon-trend">📈</span>
          <div>
            <h3>趋势变化</h3>
            <p class="comp-sub">问题簇的新增 / 升级 / 改善</p>
          </div>
        </header>
        <ul class="change-list">
          {% for item in tc.new_issues or [] %}
          <li class="change-row change-row-warn">
            <span class="change-tag tag-warn">新增</span>
            <span class="change-product">{{ item.label_display or item.label_code or "未命名问题" }}</span>
            <span class="change-detail">{{ item.current_review_count or 0 }} 条 · {{ item.affected_product_count or 0 }} 款</span>
          </li>
          {% endfor %}
          {% for item in tc.escalated_issues or [] %}
          <li class="change-row change-row-warn">
            <span class="change-tag tag-warn">升级</span>
            <span class="change-product">{{ item.label_display or item.label_code or "未命名问题" }}</span>
            <span class="change-detail">{{ item.current_review_count or 0 }} 条 · {{ item.affected_product_count or 0 }} 款</span>
          </li>
          {% endfor %}
          {% for item in tc.improving_issues or [] %}
          <li class="change-row change-row-good">
            <span class="change-tag tag-success">改善</span>
            <span class="change-product">{{ item.label_display or item.label_code or "未命名问题" }}</span>
            <span class="change-detail">{{ item.current_review_count or 0 }} 条 · {{ item.affected_product_count or 0 }} 款</span>
          </li>
          {% endfor %}
        </ul>
      </article>
      {% endif %}

      {# Layer 3: 反向利用 #}
      {% if co.competitor_new_negative_reviews or co.competitor_new_positive_reviews %}
      <article class="comp-card change-card change-card-opp">
        <header class="comp-card-head">
          <span class="comp-icon icon-bulb">💡</span>
          <div>
            <h3>反向利用</h3>
            <p class="comp-sub">竞品的本期差评 = 我方机会，竞品好评 = 借鉴方向</p>
          </div>
        </header>
        <ul class="change-list">
          {% for item in co.competitor_new_negative_reviews or [] %}
          {% set _problems = (item.primary_problems_display or []) | select | list %}
          {% if not _problems %}{% set _problems = item.primary_problems or [] %}{% endif %}
          <li class="change-row change-row-info">
            <span class="change-tag tag-info">竞品差评</span>
            <span class="change-product">{{ item.product_name or item.competitor_name or "未命名竞品" }}{% if item.review_count %} · {{ item.review_count }} 条{% endif %}</span>
            <span class="change-detail">{% if _problems %}{{ _problems | join('、') }}{% else %}差评信号{% endif %}</span>
          </li>
          {% endfor %}
          {% for item in co.competitor_new_positive_reviews or [] %}
          {% set _hl_raw = item.highlight or item.headline_cn or item.body_cn or item.headline or "" %}
          {% set _hl = _hl_raw.split("产品：")[0].split(" 产品:")[0].rstrip(" 。.") or _hl_raw %}
          <li class="change-row change-row-info">
            <span class="change-tag tag-info">竞品好评</span>
            <span class="change-product">{{ item.product_name or item.competitor_name or "未命名竞品" }}</span>
            <span class="change-detail">{{ _hl or "好评亮点" }}</span>
          </li>
          {% endfor %}
        </ul>
      </article>
      {% endif %}
      {% endif %}
    </section>

    <section id="tab-trends" class="tab-panel" role="tabpanel">
      <header class="section-head">
        <h2 class="section-title">变化趋势</h2>
        <p class="section-sub">时间窗 × 分析维度，看长期信号与短期波动</p>
      </header>

      {% set td = analytics.trend_digest or {} %}
      {% set trend_workspace = td.workspace or {} %}
      {% if trend_workspace.data %}
      {% set view_labels = {"week": "近7天", "month": "近30天", "year": "近12个月"} %}
      {% set dimension_labels = {"reputation": "口碑趋势", "issues": "问题趋势", "products": "产品趋势", "competition": "竞品对比"} %}
      {% set default_view = trend_workspace.default_view or "month" %}
      {% set default_dimension = trend_workspace.default_dimension or "reputation" %}
      <div class="trend-workspace">
        <div class="trend-switch-bar">
          <div class="trend-switch-group" role="tablist" aria-label="趋势时间">
            <span class="trend-switch-label">时间</span>
            <div class="trend-switch-segment trend-switch-time">
              {% for view in trend_workspace.views or [] %}
              <button type="button"
                      class="trend-workspace-view-btn{% if view == default_view %} trend-active{% endif %}"
                      data-trend-workspace-view="{{ view }}">{{ view_labels.get(view, view) }}</button>
              {% endfor %}
            </div>
          </div>
          <div class="trend-switch-group" role="tablist" aria-label="趋势维度">
            <span class="trend-switch-label">维度</span>
            <div class="trend-switch-segment trend-switch-dim">
              {% for dimension in trend_workspace.dimensions or [] %}
              <button type="button"
                      class="trend-workspace-dimension-btn{% if dimension == default_dimension %} trend-active{% endif %}"
                      data-trend-workspace-dimension="{{ dimension }}">{{ dimension_labels.get(dimension, dimension) }}</button>
              {% endfor %}
            </div>
          </div>
        </div>

        {% for view in trend_workspace.views or [] %}
          {% set panels = (trend_workspace.data or {}).get(view) or {} %}
          {% for dimension in trend_workspace.dimensions or [] %}
            {% set panel = panels.get(dimension) or {} %}
            {% set chart_key = "trend_workspace_" ~ view ~ "_" ~ dimension %}
            <article class="trend-workspace-panel{% if view == default_view and dimension == default_dimension %} trend-workspace-panel-active{% endif %}"
                     data-trend-workspace-view="{{ view }}"
                     data-trend-workspace-dimension="{{ dimension }}">
              <div class="trend-workspace-header">
                <div>
                  <h3>{{ panel.title or (view_labels.get(view, view) ~ " / " ~ dimension_labels.get(dimension, dimension)) }}</h3>
                  {% if panel.comparison and panel.comparison.label %}
                  <p>{{ panel.comparison.label }}</p>
                  {% endif %}
                </div>
                {% if panel.status and panel.status != "ready" %}
                <span class="trend-workspace-status">{{ panel.status_message or "趋势数据正在积累" }}</span>
                {% endif %}
              </div>

              <div class="trend-workspace-grid">
                <div class="trend-workspace-chart">
                  {% if charts.get(chart_key) %}
                  <canvas data-chart-config='{{ charts.get(chart_key) | tojson }}'></canvas>
                  {% else %}
                  <div class="trend-empty">{{ panel.status_message or "暂无趋势数据" }}</div>
                  {% endif %}
                </div>
              <div class="trend-workspace-kpis">
                  {% for item in ((panel.kpis or {}).get("items") or []) %}
                  <div class="trend-workspace-kpi">
                    <span>{{ item.label }}</span>
                    <strong>{{ item.value }}</strong>
                    {% if item.change %}<small>{{ item.change }}</small>{% endif %}
                  </div>
                  {% endfor %}
                </div>
              </div>

              {% set table = panel.table or {} %}
              {% if table.rows %}
              <div class="trend-workspace-table-wrap">
                <table class="trend-workspace-table">
                  <thead>
                    <tr>
                      {% for col in table.columns or [] %}
                      <th>{{ col }}</th>
                      {% endfor %}
                    </tr>
                  </thead>
                  <tbody>
                    {% for row in table.rows %}
                    <tr>
                      {% for col in table.columns or [] %}
                      <td>{{ row.get(col, "—") }}</td>
                      {% endfor %}
                    </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
              {% endif %}
            </article>
          {% endfor %}
        {% endfor %}
      </div>
      {% else %}
      {# F011 §4.2.5 — 1 主图 + 3 折叠下钻；bootstrap (low / no_data) 单卡 #}
      {% set primary = td.primary_chart or {} %}
      {% set _confidence = primary.confidence or "no_data" %}

      {% if _confidence in ("low", "no_data") %}
      <div class="info-card bootstrap-notice trend-bootstrap-notice">
        ℹ 趋势数据正在累积，需 ≥30 样本且每周 ≥7 个有效样本
        {% if primary.min_sample_warning %}
        <div class="warning-detail">{{ primary.min_sample_warning }}</div>
        {% endif %}
      </div>
      {% else %}
      <div class="primary-chart">
        <h3>口碑健康度趋势</h3>

        <div id="health-trend-chart" class="health-trend-chart"
             data-series-own='{{ primary.series_own | tojson }}'
             data-series-competitor='{{ primary.series_competitor | tojson }}'>
        </div>

        {% if primary.comparison and primary.comparison.own_vs_prior_window %}
        {% set _cmp = primary.comparison.own_vs_prior_window %}
        <div class="comparison-baseline">
          当前 {{ "%.1f"|format(_cmp.current or 0) }}
          {% if _cmp.delta is not none %}
            {% if _cmp.delta < 0 %}↓{% elif _cmp.delta > 0 %}↑{% else %}→{% endif %}
            {{ "%.1f"|format(_cmp.delta|abs) }}pt
          {% endif %}
          对比前30天平均
        </div>
        {% endif %}

        <div class="window-toggle">
          <span class="toggle-label">时间切换:</span>
          {% for w in primary.windows_available or [] %}
          <button type="button" data-window="{{ w }}"{% if w == primary.default_window %} class="active"{% endif %}>{{ w }}</button>
          {% endfor %}
        </div>
        <div class="anchor-toggle">
          <span class="toggle-label">口径切换:</span>
          <button type="button" data-anchor="scraped_at"{% if primary.default_anchor == "scraped_at" %} class="active"{% endif %}>采集时间</button>
          <button type="button" data-anchor="date_published"{% if primary.default_anchor == "date_published" %} class="active"{% endif %}>发表时间</button>
        </div>
      </div>

      {% for d in td.drill_downs or [] %}
      {% set drill_data = d.data or {} %}
      {% set drill_items = drill_data.get("items") or [] %}
      {% set count_ns = namespace(max_count=0) %}
      {% for item in drill_items %}
        {% if (item.review_count or 0) > count_ns.max_count %}
          {% set count_ns.max_count = item.review_count or 0 %}
        {% endif %}
      {% endfor %}
      <details class="drill-down" open>
        <summary>{{ d.title }}</summary>
        <div class="drill-content" data-drill-id="{{ d.id }}" data-payload='{{ drill_data | tojson }}'>
          {% if not drill_items %}
          <div class="drill-empty">暂无可展示的趋势明细。</div>
          {% elif d.id == "product_ratings" %}
          <div class="drill-table-wrap">
            <table class="drill-table drill-product-table">
              <thead>
                <tr>
                  <th>产品</th>
                  <th>SKU</th>
                  <th>平均评分</th>
                  <th>评论数</th>
                </tr>
              </thead>
              <tbody>
                {% for item in drill_items %}
                <tr>
                  <td class="drill-product">{{ item.product_name or "-" }}</td>
                  <td class="drill-sku">{{ item.sku or "-" }}</td>
                  <td class="drill-rating">{{ item.rating_avg if item.rating_avg is not none else "-" }}</td>
                  <td>{{ item.review_count or 0 }}</td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
          {% else %}
          <div class="drill-table-wrap">
            <table class="drill-table drill-signal-table">
              <thead>
                <tr>
                  <th>信号</th>
                  <th>评论数</th>
                  <th>强度</th>
                </tr>
              </thead>
              <tbody>
                {% for item in drill_items %}
                <tr>
                  <td class="drill-label">{{ item.label_display or item.label_code or "-" }}</td>
                  <td>{{ item.review_count or 0 }}</td>
                  <td class="drill-bar-cell">
                    <span class="drill-bar" style="--bar-width: {{ ((item.review_count or 0) / count_ns.max_count * 100) if count_ns.max_count else 0 }}%;"></span>
                  </td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
          {% endif %}
        </div>
      </details>
      {% endfor %}
      {% endif %}
      {% endif %}
    </section>

    <section id="tab-issues" class="tab-panel" role="tabpanel">
      <h2 class="section-title">自有产品问题诊断</h2>
      {% set _issue_cards = report_contract.get("issue_diagnostics") or analytics.issue_cards or [] %}
      {# F011 §4.2.3.1 v1.2 — Top 3 default-expanded; remaining wrapped in <details> #}
      <p class="section-sub">Top 3 默认展开 · 共 {{ _issue_cards | length }} 张诊断卡，点击卡片头部展开/收起</p>
      {% if not _issue_cards %}
      <div class="empty-state">未发现明确问题簇。</div>
      {% endif %}

      {% set _expanded_cards = _issue_cards | selectattr("default_expanded", "equalto", true) | list %}
      {% set _folded_cards = _issue_cards | selectattr("default_expanded", "equalto", false) | list %}

      {% for card in _expanded_cards %}
      {% set idx = loop.index %}
      <div class="issue-card severity-{{ card.severity }} reveal">
        <div class="card-header">
          <span class="card-number">#{{ idx }}</span>
          <strong class="card-title">{{ card.feature_display or card.label_display }}</strong>
          <span class="badge badge-{{ card.severity }}">{{ card.severity_display }}</span>
          <span class="card-toggle">▾</span>
        </div>
        <div class="card-body">
          <div class="card-stats">
            <span>{{ card.review_count }} 条评论</span>
            <span>{{ card.affected_product_count }} 个产品</span>
            {% if card.recency_display %}<span>{{ card.recency_display }}</span>{% endif %}
            {% if card.frequent_period %}
              <span class="frequent-period">高频期 {{ card.frequent_period.start }} ~ {{ card.frequent_period.end }}</span>
            {% endif %}
          </div>
          {% for review in (card.example_reviews or [])[:2] %}
          <blockquote class="quote-block">
            <div class="quote-meta">
              <span class="quote-stars" data-rating="{{ review.rating }}"></span>
              <span>{{ review.author or "" }}</span>
              <span>{{ review.date_published or "" }}</span>
            </div>
            <p class="quote-cn">"{{ review.headline_cn or review.headline or "" }}：{{ (review.body_cn or review.body or "")[:200] }}"</p>
          </blockquote>
          {% endfor %}
          {% if card.image_evidence %}
          <div class="issue-image-evidence">
            {% for image in card.image_evidence %}
            <figure>
              <img src="{{ image.data_uri or image.url }}" alt="{{ image.evidence_id or '评论图片证据' }}">
              <figcaption>{{ image.evidence_id }}</figcaption>
            </figure>
            {% endfor %}
          </div>
          {% endif %}
          {% if card.ai_recommendation or card.recommendation %}
          <div class="ai-box ai-box-suggest"><p>{{ card.ai_recommendation or card.recommendation }}</p></div>
          {% endif %}
          {% if card.failure_modes or card.root_causes or card.user_workarounds %}
          <div class="issue-deep-analysis">
            {% if card.failure_modes %}
            <div><strong>失效模式</strong>
              <ul>{% for item in card.failure_modes[:3] %}<li>{{ item.name if item.name is defined else item.mode if item.mode is defined else item.summary if item.summary is defined else item }}</li>{% endfor %}</ul>
            </div>
            {% endif %}
            {% if card.root_causes %}
            <div><strong>可能根因</strong>
              <ul>{% for item in card.root_causes[:3] %}<li>{{ item.name if item.name is defined else item.cause if item.cause is defined else item.summary if item.summary is defined else item }}</li>{% endfor %}</ul>
            </div>
            {% endif %}
            {% if card.user_workarounds %}
            <div><strong>用户应对</strong>
              <ul>{% for item in card.user_workarounds[:3] %}<li>{{ item }}</li>{% endfor %}</ul>
            </div>
            {% endif %}
          </div>
          {% endif %}
        </div>
      </div>
      {% endfor %}

      {# F011 §4.2.3.1 v1.3 — 4-N 直接展示，仅默认收缩 body（card-collapsed），点头部展开 #}
      {% for card in _folded_cards %}
      {% set idx = (_expanded_cards | length) + loop.index %}
      <div class="issue-card severity-{{ card.severity }} card-collapsed reveal">
        <div class="card-header">
          <span class="card-number">#{{ idx }}</span>
          <strong class="card-title">{{ card.feature_display or card.label_display }}</strong>
          <span class="badge badge-{{ card.severity }}">{{ card.severity_display }}</span>
          <span class="card-toggle">▾</span>
        </div>
        <div class="card-body">
          <div class="card-stats">
            <span>{{ card.review_count }} 条评论</span>
            <span>{{ card.affected_product_count }} 个产品</span>
            {% if card.recency_display %}<span>{{ card.recency_display }}</span>{% endif %}
            {% if card.frequent_period %}
              <span class="frequent-period">高频期 {{ card.frequent_period.start }} ~ {{ card.frequent_period.end }}</span>
            {% endif %}
          </div>
          {% for review in (card.example_reviews or [])[:2] %}
          <blockquote class="quote-block">
            <div class="quote-meta">
              <span class="quote-stars" data-rating="{{ review.rating }}"></span>
              <span>{{ review.author or "" }}</span>
              <span>{{ review.date_published or "" }}</span>
            </div>
            <p class="quote-cn">"{{ review.headline_cn or review.headline or "" }}：{{ (review.body_cn or review.body or "")[:200] }}"</p>
          </blockquote>
          {% endfor %}
          {% if card.image_evidence %}
          <div class="issue-image-evidence">
            {% for image in card.image_evidence %}
            <figure>
              <img src="{{ image.data_uri or image.url }}" alt="{{ image.evidence_id or '评论图片证据' }}">
              <figcaption>{{ image.evidence_id }}</figcaption>
            </figure>
            {% endfor %}
          </div>
          {% endif %}
          {% if card.ai_recommendation or card.recommendation %}
          <div class="ai-box ai-box-suggest"><p>{{ card.ai_recommendation or card.recommendation }}</p></div>
          {% endif %}
          {% if card.failure_modes or card.root_causes or card.user_workarounds %}
          <div class="issue-deep-analysis">
            {% if card.failure_modes %}
            <div><strong>失效模式</strong>
              <ul>{% for item in card.failure_modes[:3] %}<li>{{ item.name if item.name is defined else item.mode if item.mode is defined else item.summary if item.summary is defined else item }}</li>{% endfor %}</ul>
            </div>
            {% endif %}
            {% if card.root_causes %}
            <div><strong>可能根因</strong>
              <ul>{% for item in card.root_causes[:3] %}<li>{{ item.name if item.name is defined else item.cause if item.cause is defined else item.summary if item.summary is defined else item }}</li>{% endfor %}</ul>
            </div>
            {% endif %}
            {% if card.user_workarounds %}
            <div><strong>用户应对</strong>
              <ul>{% for item in card.user_workarounds[:3] %}<li>{{ item }}</li>{% endfor %}</ul>
            </div>
            {% endif %}
          </div>
          {% endif %}
        </div>
      </div>
      {% endfor %}
    </section>

    <section id="tab-products" class="tab-panel" role="tabpanel">
      <h2 class="section-title">自有产品状态</h2>
      <p class="section-sub">灯 + 一句原因（详细风险因子悬停查看）。</p>

      {% set product_status = (analytics.self or {}).get("product_status") or [] %}
      {% if product_status %}
      <div class="table-wrap">
        <table class="data-table product-status-table">
          <thead>
            <tr>
              <th>状态</th>
              <th>产品</th>
              <th>主要问题</th>
              <th class="hover-only">风险分</th>
            </tr>
          </thead>
          <tbody>
            {% for p in product_status %}
            <tr class="status-row status-{{ p.status_lamp }}">
              <td>
                <span class="lamp lamp-{{ p.status_lamp }}" aria-hidden="true">
                  {%- if p.status_lamp == "green" -%}🟢
                  {%- elif p.status_lamp == "yellow" -%}🟡
                  {%- elif p.status_lamp == "red" -%}🔴
                  {%- else -%}⚪{%- endif -%}
                </span>
                <span class="status-label">{{ p.status_label }}</span>
              </td>
              <td>{{ p.product_name or p.product_sku }}</td>
              <td class="primary-concern">
                {%- if p.primary_concern -%}
                  {{ p.primary_concern }}
                {%- elif p.status_lamp == 'green' -%}
                  健康
                {%- elif p.status_lamp == 'gray' -%}
                  无数据
                {%- endif -%}
              </td>
              <td class="risk-detail hover-only">
                <span class="risk-score" data-tooltip='{% if p.risk_factors %}{{ p.risk_factors | tojson }}{% elif p.status_lamp == "gray" %}未采集到评论{% else %}无负向风险因子{% endif %}'>{% if p.risk_factors %}{{ "%.1f"|format(p.risk_score or 0) }}{% else %}—{% endif %}</span>
              </td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      {% else %}
      <div class="empty-state">暂无产品状态数据。</div>
      {% endif %}

      {% if charts.scatter %}
      <div class="chart-container">
        <h3>价格-评分象限</h3>
        <canvas data-chart-config='{{ charts.scatter | tojson }}'></canvas>
      </div>
      {% endif %}
    </section>

    {# F011 §4.2.7 v1.3 — 竞品启示 redesigned layout #}
    <section id="tab-competitive" class="tab-panel competitive-panel" role="tabpanel">
      <header class="section-head">
        <h2 class="section-title">竞品启示</h2>
        <p class="section-sub">看竞品做对了什么、做错了什么，把它转换成我们的下一步动作。</p>
      </header>

      {# Block 1: 竞品弱点 = 我方机会 #}
      {% set _weakness = (analytics.competitor or {}).get("weakness_opportunities") or [] %}
      {% if _weakness %}
      <article class="comp-card weakness-opp">
        <header class="comp-card-head">
          <span class="comp-icon icon-bolt">⚡</span>
          <div>
            <h3>竞品弱点 ＝ 我方机会</h3>
            <p class="comp-sub">竞品高频差评中我们已有正面证据的差异化点</p>
          </div>
        </header>
        <ul class="weakness-list">
          {% for opp in _weakness %}
          <li class="weakness-row">
            <div class="weakness-side weakness-them">
              <span class="weakness-tag tag-danger">{{ opp.competitor_evidence_count }} 条差评</span>
              <p class="weakness-text">{{ opp.competitor_complaint_display }}</p>
            </div>
            <span class="weakness-arrow" aria-hidden="true">→</span>
            <div class="weakness-side weakness-us">
              <span class="weakness-tag tag-success">我方 {{ opp.our_positive_count }} 条正面证据</span>
              <p class="weakness-text">{{ opp.our_advantage_direction }}</p>
            </div>
          </li>
          {% endfor %}
        </ul>
      </article>
      {% endif %}

      {# Block 2: 借鉴竞品什么 — 3-column grid of quote cards #}
      {% set _benchmarks = (analytics.competitor or {}).get("benchmark_examples") or [] %}
      {% if _benchmarks %}
      <article class="comp-card benchmark">
        <header class="comp-card-head">
          <span class="comp-icon icon-spark">✨</span>
          <div>
            <h3>我们能借鉴竞品什么</h3>
            <p class="comp-sub">竞品被反复夸的产出方式，分三类拆解</p>
          </div>
        </header>
        {% if _benchmarks is mapping %}
        {% set _bench_groups = [
          ("product_design", "产品形态", "🔧", "design"),
          ("marketing_message", "营销话术", "📣", "marketing"),
          ("service_model", "服务模式", "🛎️", "service")
        ] %}
        <div class="benchmark-grid">
          {% for key, title, emoji, theme in _bench_groups %}
            {% set _items = _benchmarks.get(key) or [] %}
            <section class="benchmark-col benchmark-{{ theme }}">
              <header class="benchmark-col-head">
                <span class="benchmark-col-icon">{{ emoji }}</span>
                <span class="benchmark-col-title">{{ title }}</span>
                <span class="benchmark-col-count">{{ _items | length }}</span>
              </header>
              {% if _items %}
              <ul class="benchmark-list">
                {% for item in _items[:3] %}
                {% set _raw = item.body_cn or item.headline_cn or item.body or item.headline or "" %}
                {% set _quote = _raw.split("产品：")[0].split(" 产品:")[0].rstrip(" 。.") %}
                <li class="benchmark-item">
                  <p class="benchmark-quote">{{ _quote or _raw }}</p>
                  <div class="benchmark-attr">
                    <span class="benchmark-product">{{ item.product_name or item.product_sku or "未命名" }}</span>
                    {% if item.rating %}<span class="benchmark-rating">★ {{ item.rating }}</span>{% endif %}
                  </div>
                </li>
                {% endfor %}
              </ul>
              {% else %}
              <p class="benchmark-empty">暂无样本</p>
              {% endif %}
            </section>
          {% endfor %}
        </div>
        {% else %}
        <ul class="benchmark-list benchmark-list-flat">
          {% for item in _benchmarks[:5] %}
          {% set _raw = item.body_cn or item.headline_cn or item.body or item.headline or "" %}
          {% set _quote = _raw.split("产品：")[0].split(" 产品:")[0].rstrip(" 。.") %}
          <li class="benchmark-item">
            <p class="benchmark-quote">{{ _quote or _raw }}</p>
            <div class="benchmark-attr">
              <span class="benchmark-product">{{ item.product_name or item.product_sku or "未命名" }}</span>
            </div>
          </li>
          {% endfor %}
        </ul>
        {% endif %}
      </article>
      {% endif %}

      {# Block 3: 多维度对标雷达 — chart + insight column #}
      {% if analytics._radar_data and analytics._radar_data.categories %}
      {% set _radar = analytics._radar_data %}
      <article class="comp-card radar">
        <header class="comp-card-head">
          <span class="comp-icon icon-radar">📡</span>
          <div>
            <h3>多维度对标雷达</h3>
            <p class="comp-sub">核心 {{ _radar.categories | length }} 维好评率，自有 vs 竞品</p>
          </div>
        </header>
        <div class="radar-layout">
          <div class="radar-chart-wrap">
            {% if charts.radar %}
            <div class="chart-container">
              <canvas data-chart-config='{{ charts.radar | tojson }}'></canvas>
            </div>
            {% else %}
            <div id="radar-chart" data-radar='{{ _radar | tojson }}'></div>
            {% endif %}
          </div>
          <div class="radar-insight">
            <table class="radar-delta-table">
              <thead>
                <tr>
                  <th class="col-dim">维度</th>
                  <th class="col-own"><span class="legend-dot dot-own"></span>自有</th>
                  <th class="col-comp"><span class="legend-dot dot-comp"></span>竞品</th>
                  <th class="col-delta">差速</th>
                </tr>
              </thead>
              <tbody>
                {% for cat in _radar.categories %}
                  {% set i = loop.index0 %}
                  {% set ov = _radar.own_values[i] %}
                  {% set cv = _radar.competitor_values[i] %}
                  {% set delta = ov - cv %}
                  {% set lead_class = "lead-up" if delta > 0.05 else ("lead-down" if delta < -0.05 else "lead-flat") %}
                  <tr class="{{ lead_class }}">
                    <th scope="row" class="col-dim">{{ cat }}</th>
                    <td class="col-own">{{ (ov * 100) | round(0) }}%</td>
                    <td class="col-comp">{{ (cv * 100) | round(0) }}%</td>
                    <td class="col-delta">
                      {% if delta > 0.05 %}<span class="delta-badge up">+{{ (delta * 100) | round(0) }}pp</span>
                      {% elif delta < -0.05 %}<span class="delta-badge down">−{{ ((-delta) * 100) | round(0) }}pp</span>
                      {% else %}<span class="delta-badge flat">持平</span>
                      {% endif %}
                    </td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </div>
      </article>
      {% endif %}

      {# Block 4: 评分两极分化对比 — 自有 vs 竞品 双栏 #}
      {% if charts.sentiment_own or charts.sentiment_comp %}
      <article class="comp-card rating-dist">
        <header class="comp-card-head">
          <span class="comp-icon icon-bars">📊</span>
          <div>
            <h3>评分分布对比</h3>
            <p class="comp-sub">自有 vs 竞品的好评 / 中评 / 差评结构，差评占比越高 = 改良或差异化空间越大</p>
          </div>
        </header>
        <div class="rating-grid">
          {% if charts.sentiment_own %}
          <div class="rating-panel">
            <h4 class="rating-panel-title">自有产品评分分布</h4>
            <div class="chart-container chart-tall">
              <canvas data-chart-config='{{ charts.sentiment_own | tojson }}'></canvas>
            </div>
          </div>
          {% endif %}
          {% if charts.sentiment_comp %}
          <div class="rating-panel">
            <h4 class="rating-panel-title">竞品评分分布</h4>
            <div class="chart-container chart-tall">
              <canvas data-chart-config='{{ charts.sentiment_comp | tojson }}'></canvas>
            </div>
          </div>
          {% endif %}
        </div>
        <div class="comp-insight comp-insight-success">
          <span class="comp-insight-icon">↗</span>
          <span>对照看：自有差评比例高的产品 → 改良优先；竞品差评比例高的产品 → 我方差异化机会。</span>
        </div>
      </article>
      {% endif %}

      {# Block 5: 维度差距对照 — visual rows #}
      {% if gap_analysis %}
      <article class="comp-card gap">
        <header class="comp-card-head">
          <span class="comp-icon icon-list">📋</span>
          <div>
            <h3>维度差距对照</h3>
            <p class="comp-sub">竞品好评 vs 自有差评，按优先级排序</p>
          </div>
        </header>
        {% set _max_pos = ((gap_analysis | map(attribute='competitor_positive_count') | list) + [1]) | max %}
        {% set _max_neg = ((gap_analysis | map(attribute='own_negative_count') | list) + [1]) | max %}
        <div class="gap-rows">
          {% for gap in gap_analysis %}
          {% set _pri = (gap.priority_display or "") | trim %}
          {% set _is_bleed = (gap.gap_type or "") == "止血" %}
          {% set _row_class = "gap-row-bleed" if _is_bleed else "gap-row-monitor" %}
          {% set _pos = gap.competitor_positive_count or 0 %}
          {% set _neg = gap.own_negative_count or 0 %}
          <div class="gap-row {{ _row_class }}">
            <div class="gap-meta">
              <span class="gap-dim">{{ gap.label_display or "" }}</span>
              <span class="gap-meta-sub">
                {{ gap.gap_type or "" }}{% if _pri %} · {{ _pri }}{% endif %}
              </span>
            </div>
            <div class="gap-bars">
              <div class="gap-bar-row">
                <span class="gap-bar-label">竞品好评</span>
                <span class="gap-bar-track"><span class="gap-bar-fill bar-comp" style="width: {{ ((_pos / _max_pos) * 100) | round(0) }}%;"></span></span>
                <span class="gap-bar-value">{{ _pos }}</span>
              </div>
              <div class="gap-bar-row">
                <span class="gap-bar-label">自有差评</span>
                <span class="gap-bar-track"><span class="gap-bar-fill bar-own-neg" style="width: {{ ((_neg / _max_neg) * 100) | round(0) }}%;"></span></span>
                <span class="gap-bar-value">{{ _neg }}</span>
              </div>
            </div>
          </div>
          {% endfor %}
        </div>
      </article>
      {% endif %}
    </section>

    <section id="tab-panorama" class="tab-panel panorama" role="tabpanel">
      <header class="section-head">
        <h2 class="section-title">全景数据</h2>
        <p class="section-sub">{{ (snapshot.reviews or []) | length }} 条评论 · 按归属 / 评分 / 产品 / 标签 5 维筛选</p>
      </header>

      {% if analytics._heatmap_data and analytics._heatmap_data.y_labels and analytics._heatmap_data.x_labels %}
      {# F011 §4.2.6.2 v1.2 — feature × product sentiment heatmap (Top 8 dim aggregation) #}
      <article class="comp-card heatmap-card">
        <header class="comp-card-head">
          <span class="comp-icon icon-grid">🟩</span>
          <div>
            <h3>特征情感热力图</h3>
            <p class="comp-sub">每款产品在每个标签上的好评率，色越深 = 信号越强；混合=正负并存按 0.5 权重计入健康度</p>
          </div>
        </header>
        <div class="hm-legend-row" role="note" aria-label="热力图色阶图例">
          <span class="hm-legend-item"><span class="hm-legend-cell green"></span>认可 &gt;70%</span>
          <span class="hm-legend-item"><span class="hm-legend-cell yellow"></span>中性 40–70%</span>
          <span class="hm-legend-item"><span class="hm-legend-cell red"></span>负面 &lt;40%</span>
          <span class="hm-legend-item"><span class="hm-legend-cell gray"></span>样本不足 &lt;3</span>
        </div>
        <div class="heatmap-container">
          <table class="heatmap-table heatmap-table-v12">
            <thead>
              <tr>
                <th></th>
                {% for x in analytics._heatmap_data.x_labels %}
                <th>{{ x }}</th>
                {% endfor %}
              </tr>
            </thead>
            <tbody>
              {% set y_items = analytics._heatmap_data.y_items or [] %}
              {% for y in analytics._heatmap_data.y_labels %}
              {% set y_item = y_items[loop.index0] if y_items else {} %}
              {% set y_display = y_item.display_label or y %}
              {% set y_product = y_item.product_name or y %}
              <tr>
                <th>{{ y_display }}</th>
                {% set row = analytics._heatmap_data.z[loop.index0] %}
                {% for cell in row %}
                  {% set cell_idx = loop.index0 %}
                  {% set x_label = analytics._heatmap_data.x_labels[cell_idx] %}
                  {% set x_code = (analytics._heatmap_data.x_label_codes[cell_idx] if analytics._heatmap_data.x_label_codes else '') %}
                  <td class="heatmap-cell {{ cell.color_class }}"
                      data-product="{{ y_product }}"
                      data-label="{{ x_label }}"
                      data-label-code="{{ x_code }}"
                      data-review-id="{{ cell.top_review_id or '' }}"
                      title="{{ y_display }} × {{ x_label }} ({{ cell.sample_size }} 条)&#10;{{ cell.tooltip or cell.top_review_excerpt }}">
                    {% if cell.score is not none %}{{ '%.0f%%' | format(cell.score * 100) }}{% else %}<span class="hm-empty">—</span>{% endif %}
                  </td>
                {% endfor %}
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
        {% if analytics._heatmap_data.aggregated_labels %}
        <p class="heatmap-foot">"其他"聚合了 {{ analytics._heatmap_data.aggregated_labels | length }} 个低频维度</p>
        {% endif %}
      </article>
      {% endif %}

      <article class="comp-card reviews-card">
        <header class="comp-card-head">
          <span class="comp-icon icon-feed">📜</span>
          <div>
            <h3>评论清单</h3>
            <p class="comp-sub">原始评论流，可按维度筛选；点击行号可定位证据</p>
          </div>
        </header>
        <div class="panorama-filters" role="search" aria-label="评论筛选">
          <div class="filter-group">
            <label class="filter-label" for="filter-ownership">归属</label>
            <select id="filter-ownership" name="ownership">
              <option value="">全部</option>
              <option value="own">自有</option>
              <option value="competitor">竞品</option>
            </select>
          </div>
          <div class="filter-group">
            <label class="filter-label" for="filter-rating">评分</label>
            <select id="filter-rating" name="rating">
              <option value="">全部</option>
              <option value="low">≤2 星</option>
              <option value="mid">3 星</option>
              <option value="high">≥4 星</option>
            </select>
          </div>
          <div class="filter-group filter-group-wide">
            <label class="filter-label" for="filter-product">产品</label>
            <select id="filter-product" name="product">
              <option value="">全部产品</option>
              {% for p in snapshot.products or [] %}
              <option value="{{ p.name or p.sku }}">{{ p.name or p.sku }}</option>
              {% endfor %}
            </select>
          </div>
          <div class="filter-group">
            <label class="filter-label" for="filter-label">标签</label>
            <select id="filter-label" name="label">
              <option value="">全部</option>
              {% for l in analytics.label_options or [] %}
              <option value="{{ l.code }}">{{ l.display }}</option>
              {% endfor %}
            </select>
          </div>
          <div class="filter-toggles">
            <label class="checkbox-label"><input type="checkbox" name="has_images"> 仅含图</label>
            <label class="checkbox-label"><input type="checkbox" name="recent"> 近 30 天</label>
          </div>
        </div>

        <div class="table-wrap">
          <table class="data-table panorama-table">
            <thead>
              <tr>
                <th class="col-own">归属</th>
                <th class="col-prod">产品</th>
                <th class="col-rate">评分</th>
                <th class="col-content">评论内容</th>
                <th class="col-date">日期</th>
              </tr>
            </thead>
            <tbody>
              {% for r in snapshot.reviews or [] %}
              {% set _body_raw = r.body_cn or r.body_translated or r.body or '' %}
              {% set _body_clean = _body_raw.split("产品：")[0].split(" 产品:")[0].rstrip(" 。.") %}
              {% set _body = _body_clean or _body_raw %}
              {% set _title = r.headline_cn or r.headline or '' %}
              <tr id="review-{{ r.id }}"
                  data-review-id="{{ r.id }}"
                  data-ownership="{{ r.ownership or '' }}"
                  data-rating-value="{{ r.rating or 0 }}"
                  data-product="{{ r.product_name or '' }}"
                  data-has-images="{{ '1' if r.images else '0' }}"
                  data-recent="{{ '1' if r.is_recent else '0' }}"
                  data-labels="{{ (r.label_codes or []) | join(',') }}">
                <td class="col-own">
                  {% if r.ownership == 'own' %}<span class="own-chip own-chip-self">自有</span>
                  {% elif r.ownership == 'competitor' %}<span class="own-chip own-chip-comp">竞品</span>
                  {% endif %}
                </td>
                <td class="col-prod" title="{{ r.product_name or '' }}">{{ (r.product_name or '') | truncate(28) }}</td>
                <td class="col-rate"><span class="star-rating" data-rating="{{ r.rating or 0 }}"></span></td>
                <td class="col-content">
                  {% if _title %}<div class="review-title">{{ _title }}</div>{% endif %}
                  <div class="review-body">{{ _body | truncate(180) }}</div>
                </td>
                <td class="col-date">{{ r.date_published or '' }}</td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </article>
    </section>
  </main>

  <div id="lightbox">
    <div class="lightbox-backdrop"></div>
    <img id="lightbox-img" src="" alt="">
    <button id="lightbox-close">&times;</button>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/chart.js@4" onerror="document.getElementById('chart-fallback-msg').style.display='block'"></script>
  <div id="chart-fallback-msg" style="display:none" class="chart-fallback">⚠️ 图表库加载失败，仍可查看文字和表格。</div>

  <script>{{ js_text | safe }}</script>

  <footer class="report-footer">
    <span>QBU 网评监控智能分析系统 · 差评定义：≤{{ threshold or 2 }}星 · 内部资料</span>
    <span class="footer-ai">本报告由 AI 自动生成，数据及分析结论仅供参考</span>
  </footer>
</body>
</html>
