<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>QBU网评监控智能分析报告 {{ logical_date }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700;800&family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700&family=DM+Mono:wght@400;500&family=Noto+Serif+SC:wght@400;600;700&display=swap" rel="stylesheet">
  <style>{{ css_text | safe }}</style>
</head>
<body>
  <!-- ── Sticky Header Bar ──────────────────────────────────── -->
  <header class="kpi-bar">
    <div class="kpi-bar-inner">
      <span class="kpi-bar-brand">QBU 网评监控</span>
      <div class="kpi-bar-metrics">
        {% for card in (analytics.kpi_cards or [])[:5] %}
        <span class="kpi-bar-item">{{ card.label }} <strong>{{ card.value }}</strong></span>
        {% endfor %}
      </div>
      <button id="btn-print" class="btn-icon" title="打印 / 导出PDF">⎙</button>
    </div>
  </header>

  <!-- ── Tab Navigation (Pill + Badge) ──────────────────────── -->
  <nav class="tab-nav" role="tablist">
    <button data-tab="overview" class="tab-btn tab-active" role="tab">总览</button>
    {% if mode != "baseline" %}
    <button data-tab="changes" class="tab-btn" role="tab">今日变化</button>
    {% endif %}
    {% if (analytics.kpis.own_review_rows or 0) > 0 %}
    <button data-tab="issues" class="tab-btn" role="tab">问题诊断 <span class="tab-badge">{{ (analytics.issue_cards or []) | length }}</span></button>
    <button data-tab="products" class="tab-btn" role="tab">产品排行 <span class="tab-badge">{{ analytics.kpis.own_product_count or 0 }}</span></button>
    {% endif %}
    {% if (analytics.kpis.competitor_review_rows or 0) > 0 and (analytics.kpis.product_count or 0) > 1 %}
    <button data-tab="competitive" class="tab-btn" role="tab">竞品对标</button>
    {% endif %}
    <button data-tab="panorama" class="tab-btn" role="tab">全景数据 <span class="tab-badge">{{ ((snapshot.cumulative.reviews if snapshot.cumulative is defined and snapshot.cumulative and snapshot.cumulative.reviews is defined else snapshot.reviews) or []) | length }}</span></button>
  </nav>

  <main class="report-main">

    <!-- ════════════════════════════════════════════════════════
         TAB 1: 总览 (Overview)
         ════════════════════════════════════════════════════════ -->
    <section id="tab-overview" class="tab-panel tab-active" role="tabpanel">

      <!-- Hero: CSS Gauge + Headline -->
      <div class="hero">
        <div class="gauge-wrapper" data-health="{{ analytics.kpis.health_index or 50 }}">
          <div class="gauge-arc">
            <div class="gauge-fill"></div>
            <div class="gauge-mask"></div>
            <div class="gauge-value">0</div>
          </div>
          <div class="gauge-label">健康指数</div>
          <div class="gauge-scale"><span>0</span><span>50</span><span>100</span></div>
        </div>
        <div class="hero-text">
          <p class="hero-kicker">Daily Product Intelligence</p>
          <h1 class="hero-title">QBU网评监控智能分析报告</h1>
          <p class="hero-headline">{{ (report_copy.hero_headline or analytics.kpis.health_index|string ~ '/100') }}</p>
          <p class="hero-meta">Run #{{ snapshot.run_id }} · {{ logical_date }} · {{ analytics.mode_display }} · 数据截至 {{ (snapshot.snapshot_at or '')[:16] }}</p>
        </div>
      </div>

      <!-- Sample warning -->
      {% if (analytics.kpis.own_review_rows or 0) < 5 %}
      <div class="badge-warn" style="margin-bottom: var(--sp-sm)">⚠️ 样本不足 ({{ analytics.kpis.own_review_rows or 0 }}条)</div>
      {% endif %}

      <!-- KPI Cards Grid -->
      <div class="kpi-grid">
        {% for card in (analytics.kpi_cards or []) %}
        <div class="kpi-card reveal">
          <span class="kpi-label">{{ card.label }}{% if card.tooltip %} <span class="tip-trigger" data-tip="{{ card.tooltip }}">?</span>{% endif %}</span>
          <strong class="kpi-value {{ card.value_class or '' }}">{{ card.value }}</strong>
          {% if card.delta_display %}<span class="kpi-delta {{ card.delta_class or '' }}">{{ card.delta_display }}</span>{% endif %}
        </div>
        {% endfor %}
      </div>

      <!-- Alert Signal -->
      {% if alert_level and alert_text %}
      <div class="alert-banner alert-{{ alert_level }}">{{ alert_text }}</div>
      {% endif %}

      {% if (analytics.kpis.translation_completion_rate or 1) < 0.5 %}
      <div class="alert-banner alert-yellow">
        ⚠️ 翻译进度 {{ (analytics.kpis.translation_completion_rate * 100) | round(0) }}%，以下分析基于部分数据
      </div>
      {% endif %}

      <!-- Executive Blocks -->
      <div class="exec-grid">
        <article class="exec-block reveal">
          <div class="exec-block-header">
            <span class="exec-block-icon icon-judgment">◆</span>
            <h3>关键判断</h3>
          </div>
          <div class="exec-block-body">
            <ul>{% for item in (report_copy.executive_bullets or [])[:3] %}<li>{{ item }}</li>{% endfor %}</ul>
          </div>
        </article>
        <article class="exec-block reveal">
          <div class="exec-block-header">
            <span class="exec-block-icon icon-scope">◎</span>
            <h3>报告口径</h3>
          </div>
          <div class="exec-block-body">
            <div class="exec-scope-row"><span class="exec-scope-label">报告模式</span><span class="exec-scope-value">{{ analytics.mode_display }}</span></div>
            <div class="exec-scope-row"><span class="exec-scope-label">差评阈值</span><span class="exec-scope-value">≤ {{ threshold or 2 }} 星</span></div>
            <div class="exec-scope-row"><span class="exec-scope-label">自有产品</span><span class="exec-scope-value">{{ analytics.kpis.own_product_count or 0 }} 个 · {{ analytics.kpis.own_review_rows or 0 }} 条评论</span></div>
            <div class="exec-scope-row"><span class="exec-scope-label">竞品</span><span class="exec-scope-value">{{ analytics.kpis.competitor_product_count or 0 }} 个 · {{ analytics.kpis.competitor_review_rows or 0 }} 条评论</span></div>
          </div>
        </article>
      </div>

      <!-- Top Actions -->
      {% if analytics.top_actions %}
      <div class="action-board">
        <h2>建议行动</h2>
        {% for action in analytics.top_actions %}
        <div class="action-card reveal">
          <span class="action-rank">{{ loop.index }}</span>
          <div class="action-body">
            <div class="action-title">{{ action.title }}</div>
            <p class="action-evidence">{{ action.evidence_summary }}{% if action.affected_products %} · 涉及: {{ action.affected_products | join('、') }}{% endif %}</p>
          </div>
        </div>
        {% endfor %}
      </div>
      {% endif %}
    </section>

    <!-- ════════════════════════════════════════════════════════
         TAB 2: 今日变化 (Changes)
         ════════════════════════════════════════════════════════ -->
    {% if mode != "baseline" %}
    <section id="tab-changes" class="tab-panel" role="tabpanel">
      <h2 class="section-title">今日变化</h2>
      <p class="section-sub">采集窗口内的新增评论和产品数据变动。</p>

      {% set win_reviews = snapshot.reviews if snapshot.reviews is defined else [] %}
      {% if win_reviews %}
      <h3 style="margin-top:var(--sp-lg);">新增评论（{{ win_reviews|length }} 条）</h3>
      {% for r in win_reviews[:20] %}
      <div class="quote-block {% if r.rating is defined and r.rating is not none and r.rating <= 2 %}quote-negative{% elif r.rating is defined and r.rating is not none and r.rating >= 4 %}quote-positive{% else %}quote-neutral{% endif %}" style="margin-bottom:var(--sp-md);">
        <div class="quote-cn">{{ r.headline_cn if r.headline_cn is defined and r.headline_cn else (r.headline if r.headline is defined else "") }}</div>
        <div class="quote-en" style="font-size:var(--fs-xs); color:var(--text-secondary);">{{ (r.body if r.body is defined and r.body else "")[:200] }}{% if r.body is defined and r.body and r.body|length > 200 %}...{% endif %}</div>
        <div class="quote-meta">
          <span class="quote-stars">{{ "★" * ((r.rating|int) if r.rating is defined and r.rating is not none else 0) }}{{ "☆" * (5 - ((r.rating|int) if r.rating is defined and r.rating is not none else 0)) }}</span>
          <span>{{ r.author if r.author is defined and r.author else "Anonymous" }}</span>
          <span>{{ r.product_name if r.product_name is defined and r.product_name else (r.product_sku if r.product_sku is defined else "") }}</span>
        </div>
      </div>
      {% endfor %}
      {% if win_reviews|length > 20 %}
      <div class="empty-state">还有 {{ win_reviews|length - 20 }} 条评论未显示，查看全景数据 Tab 查看完整列表。</div>
      {% endif %}
      {% else %}
      <div class="empty-state">本期无新增评论。</div>
      {% endif %}

      {# P008: Product data changes (price/stock/rating) #}
      {% set _changes = changes if changes is defined and changes else {} %}
      {% if _changes and _changes.has_changes is defined and _changes.has_changes %}
      <h3 style="margin-top:var(--sp-2xl);">产品数据变动</h3>

      {% if _changes.price_changes %}
      <h4 style="margin-top:var(--sp-md);color:var(--text-secondary);">价格变化（{{ _changes.price_changes|length }}个）</h4>
      <div class="table-wrap">
        <table class="data-table">
          <thead><tr><th>产品</th><th style="text-align:center;">原价</th><th style="text-align:center;">现价</th></tr></thead>
          <tbody>
          {% for c in _changes.price_changes %}
          <tr>
            <td>{{ c.name }}</td>
            <td style="text-align:center;color:var(--text-muted);text-decoration:line-through;font-family:var(--font-mono);">${{ c.old }}</td>
            <td style="text-align:center;font-weight:700;font-family:var(--font-mono);color:{% if c.new is none %}var(--text-muted){% elif c.new > c.old %}var(--critical){% else %}var(--positive){% endif %};">{% if c.new is not none %}${{ c.new }} {% if c.new > c.old %}▲{% else %}▼{% endif %}{% else %}已下架{% endif %}</td>
          </tr>
          {% endfor %}
          </tbody>
        </table>
      </div>
      {% endif %}

      {% if _changes.stock_changes %}
      <h4 style="margin-top:var(--sp-md);color:var(--text-secondary);">库存变化（{{ _changes.stock_changes|length }}个）</h4>
      <div class="table-wrap">
        <table class="data-table">
          <thead><tr><th>产品</th><th style="text-align:center;">原状态</th><th style="text-align:center;">现状态</th></tr></thead>
          <tbody>
          {% for c in _changes.stock_changes %}
          <tr>
            <td>{{ c.name }}</td>
            <td style="text-align:center;color:var(--text-muted);">{{ "有货" if c.old == "in_stock" else "缺货" }}</td>
            <td style="text-align:center;font-weight:700;color:{% if c.new == 'in_stock' %}var(--positive){% else %}var(--critical){% endif %};">{{ "有货" if c.new == "in_stock" else "缺货" }}</td>
          </tr>
          {% endfor %}
          </tbody>
        </table>
      </div>
      {% endif %}

      {% if _changes.rating_changes %}
      <h4 style="margin-top:var(--sp-md);color:var(--text-secondary);">评分变化（{{ _changes.rating_changes|length }}个）</h4>
      <div class="table-wrap">
        <table class="data-table">
          <thead><tr><th>产品</th><th style="text-align:center;">原评分</th><th style="text-align:center;">现评分</th></tr></thead>
          <tbody>
          {% for c in _changes.rating_changes %}
          <tr>
            <td>{{ c.name }}</td>
            <td style="text-align:center;color:var(--text-muted);font-family:var(--font-mono);">{{ c.old if c.old is not none else "—" }}</td>
            <td style="text-align:center;font-weight:700;font-family:var(--font-mono);color:{% if c.new is none %}var(--text-muted){% elif (c.new or 0) > (c.old or 0) %}var(--positive){% else %}var(--critical){% endif %};">{{ c.new if c.new is not none else "已下架" }}</td>
          </tr>
          {% endfor %}
          </tbody>
        </table>
      </div>
      {% endif %}

      {% endif %}
    </section>
    {% endif %}

    <!-- ════════════════════════════════════════════════════════
         TAB 3: 问题诊断 (Issues)
         ════════════════════════════════════════════════════════ -->
    {% if (analytics.kpis.own_review_rows or 0) > 0 %}
    <section id="tab-issues" class="tab-panel" role="tabpanel">
      <h2 class="section-title">自有产品问题诊断</h2>
      <p class="section-sub">按影响规模排序，每个问题簇附带证据引用和改良建议。</p>

      {% if (snapshot.reviews if snapshot.reviews is defined else []) | length == 0 %}
      <div style="margin-bottom:var(--sp-md);padding:8px 12px;background:#f7fafc;border-radius:4px;font-size:13px;color:var(--text-muted,#a0aec0);">
        本周无新数据变动，以下为累积分析。
      </div>
      {% endif %}

      {% set _issue_cards = analytics.issue_cards if analytics.issue_cards else (analytics.self.issue_cards if analytics.self is defined and analytics.self.issue_cards is defined else []) %}

      {% if not _issue_cards %}
      <div class="empty-state">未发现问题，所有评论均为正面反馈。</div>
      {% endif %}

      {% for card in _issue_cards %}
      <div class="issue-card severity-{{ card.severity }} reveal"
           {% if loop.index > 4 %}data-default-collapsed="true"{% endif %}>
        <div class="card-header">
          <span class="card-number">#{{ loop.index }}</span>
          <strong class="card-title">{{ card.feature_display or card.label_display }}</strong>
          <span class="badge badge-{{ card.severity }}">{{ card.severity_display }}</span>
              {% if card.dispersion_type is defined and card.dispersion_type %}
              <span style="font-size:11px;padding:2px 6px;border-radius:4px;margin-left:4px;
                {% if card.dispersion_type == 'systemic' %}background:#fed7d7;color:#c53030;
                {% elif card.dispersion_type == 'isolated' %}background:#c6f6d5;color:#276749;
                {% else %}background:#e2e8f0;color:#718096;{% endif %}">{{ card.dispersion_display if card.dispersion_display is defined else card.dispersion_type }}</span>
              {% endif %}
              {% if card.lifecycle_status is defined and card.lifecycle_status %}
              <span style="font-size:11px;padding:2px 6px;border-radius:4px;margin-left:4px;
                {% if card.lifecycle_status == 'active' %}background:#fed7d7;color:#c53030;
                {% else %}background:#e2e8f0;color:#718096;{% endif %}">{{ "活跃" if card.lifecycle_status == "active" else "静默" }}</span>
              {% endif %}
          <span class="card-toggle">▼</span>
        </div>
        <div class="card-body">
          <div class="card-stats">
            <span>📝 {{ card.review_count }} 条评论</span>
            <span>📦 {{ card.affected_product_count }} 个产品</span>
            {% if card.recency_display %}<span>🕐 {{ card.recency_display }}</span>{% endif %}
            {% if card.translated_rate is defined and card.translated_rate < 0.8 %}
            <span class="badge-warn">翻译覆盖 {{ (card.translated_rate * 100) | int }}%</span>
            {% endif %}
          </div>
          {% if card.first_seen and card.last_seen %}
          <p class="card-timeline">{{ card.first_seen }} → {{ card.last_seen }}，持续 {{ card.duration_display }}</p>
          {% endif %}

          <!-- Quotes with star ratings -->
          {% for review in (card.example_reviews or [])[:2] %}
          <blockquote class="quote-block">
            <div class="quote-meta">
              <span class="quote-stars" data-rating="{{ review.rating }}"></span>
              <span>{{ review.author }}</span>
              <span>{{ review.date_published or '' }}</span>
            </div>
            <p class="quote-cn">"{{ review.headline_cn or review.headline }}：{{ (review.body_cn or review.body or '')[:200] }}"</p>
            {% if review.body and review.body != review.body_cn %}
            <p class="quote-en">"{{ (review.body or '')[:150] }}"</p>
            {% endif %}
          </blockquote>
          {% endfor %}

          <!-- Evidence gallery -->
          {% if card.image_evidence %}
          <div class="evidence-gallery">
            {% for img in card.image_evidence[:4] %}
            <div class="evidence-thumb">
              <img class="evidence-img" src="{{ img.url or img }}" alt="证据" data-full="{{ img.url or img }}" decoding="async">
            </div>
            {% endfor %}
            {% if card.image_evidence | length > 4 %}
            <div class="evidence-more">+{{ card.image_evidence | length - 4 }}</div>
            {% endif %}
          </div>
          {% endif %}

          <!-- AI Analysis -->
          {% if card.deep_analysis %}
          <div class="ai-box {{ 'ai-box-urgent' if card.severity in ['critical', 'high'] else 'ai-box-suggest' }}">
            <p><strong>{{ card.deep_analysis.actionable_summary }}</strong></p>
            {% if card.deep_analysis.failure_modes %}
            <details>
              <summary>失效模式 ({{ card.deep_analysis.failure_modes | length }}种)</summary>
              {% for fm in card.deep_analysis.failure_modes %}
              <div class="failure-mode">
                <strong>{{ fm.mode }}</strong> — 约{{ fm.frequency }}例
                {% if fm.example_quote %}<blockquote class="quote-neutral" style="margin-top:4px">"{{ fm.example_quote }}"</blockquote>{% endif %}
              </div>
              {% endfor %}
            </details>
            {% endif %}
          </div>
          {% elif card.recommendation %}
          <div class="ai-box {{ 'ai-box-urgent' if card.severity in ['critical', 'high'] else 'ai-box-suggest' }}">
            <p>{{ card.recommendation.text if card.recommendation is mapping else card.recommendation }}</p>
          </div>
          {% endif %}
        </div>
      </div>
      {% endfor %}
    </section>
    {% endif %}

    <!-- ════════════════════════════════════════════════════════
         TAB 4: 产品排行 (Product Health)
         ════════════════════════════════════════════════════════ -->
    {% if (analytics.kpis.own_review_rows or 0) > 0 %}
    <section id="tab-products" class="tab-panel" role="tabpanel">
      <h2 class="section-title">自有产品健康度排名</h2>
      <p class="section-sub">按风险分降序排列。</p>

      {% set risk_products = analytics.self.risk_products if analytics.self is defined else [] %}
      {% if risk_products %}
      <div class="table-wrap">
        <table class="data-table">
          <thead>
            <tr>
              <th data-sortable>产品</th>
              <th data-sortable>SKU</th>
              <th data-sortable>评分</th>
              <th data-sortable>差评率</th>
              <th data-sortable>差评数</th>
              <th data-sortable>风险分</th>
              <th>主要问题</th>
            </tr>
          </thead>
          <tbody>
            {% for p in risk_products %}
            <tr class="severity-{{ 'high' if p.risk_score >= 70 else 'medium' if p.risk_score >= 40 else 'low' }}">
              <td>{{ p.product_name }}</td>
              <td style="font-family: var(--font-mono); font-size: var(--fs-xs);">{{ p.product_sku }}</td>
              <td><span data-rating="{{ p.rating_avg }}" class="quote-stars"></span> {{ p.rating_avg }}</td>
              <td>{{ (p.negative_rate * 100) | round(0) if p.negative_rate is not none and p.negative_rate else '—' }}{% if p.negative_rate is not none and p.negative_rate %}%{% endif %}</td>
              <td>{{ p.negative_review_rows }}</td>
              <td><strong style="font-family: var(--font-mono);">{{ p.risk_score }}</strong></td>
              <td style="font-size: var(--fs-xs); color: var(--text-secondary);">{{ p.top_features_display }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      {% else %}
      <div class="empty-state">暂无产品风险数据。</div>
      {% endif %}

      {% if charts.scatter %}
      <div class="chart-container">
        <h3>价格-评分象限图</h3>
        <canvas data-chart-config='{{ charts.scatter | tojson }}'></canvas>
      </div>
      {% endif %}
    </section>
    {% endif %}

    <!-- ════════════════════════════════════════════════════════
         TAB 5: 竞品对标 (Competitive)
         ════════════════════════════════════════════════════════ -->
    {% if (analytics.kpis.competitor_review_rows or 0) > 0 %}
    <section id="tab-competitive" class="tab-panel" role="tabpanel">
      <h2 class="section-title">竞品差距分析与机会</h2>

      {% set gap_css = {'止血': 'badge-stop', '追赶': 'badge-chase', '监控': 'badge-watch'} %}
      {% set gap_analysis = analytics.competitor.gap_analysis if analytics.competitor is defined else [] %}
      {% if gap_analysis %}
      <div class="table-wrap">
        <table class="data-table">
          <thead>
            <tr>
              <th>维度</th>
              <th>类型</th>
              <th data-sortable>修复紧迫度</th>
              <th data-sortable>追赶差距</th>
              <th data-sortable>综合优先级</th>
              <th>竞品好评</th>
              <th>自有差评</th>
            </tr>
          </thead>
          <tbody>
            {% for g in gap_analysis %}
            <tr>
              <td><strong>{{ g.label_display }}</strong></td>
              <td><span class="badge {{ gap_css.get(g.gap_type, 'badge-watch') }}">{{ g.gap_type }}</span></td>
              <td style="font-family: var(--font-mono);">{{ g.fix_urgency }}%</td>
              <td style="font-family: var(--font-mono);">{{ g.catch_up_gap }}%</td>
              <td><strong style="font-family: var(--font-mono);">{{ g.priority_score }}</strong> <span class="badge badge-{{ g.priority }}">{{ g.priority_display }}</span></td>
              <td>{{ g.competitor_positive_count }} ({{ g.competitor_positive_rate }}%)</td>
              <td>{{ g.own_negative_count }} ({{ g.own_negative_rate }}%)</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      {% endif %}

      {% if report_copy.competitive_insight %}
      <div class="ai-box ai-box-insight">
        <p>{{ report_copy.competitive_insight }}</p>
      </div>
      {% endif %}

      {% if charts.radar %}
      <div class="chart-container">
        <h3>竞品对标雷达图</h3>
        <div style="max-width:420px;margin:0 auto;">
          <canvas data-chart-config='{{ charts.radar | tojson }}'></canvas>
        </div>
      </div>
      {% endif %}

      {% set benchmarks = analytics.competitor.benchmark_examples if analytics.competitor is defined else [] %}
      {% if benchmarks %}
      <h3 style="margin-top: var(--sp-2xl);">高价值竞品样本</h3>
      {% for b in benchmarks[:3] %}
      <div class="quote-block quote-positive reveal">
        <div class="quote-meta">
          <strong>{{ b.product_name }}</strong>
          <span style="font-family: var(--font-mono); font-size: var(--fs-xs);">SKU: {{ b.product_sku }}</span>
        </div>
        {% if b.label_display_list %}<p style="font-size: var(--fs-xs); color: var(--positive); margin: var(--sp-xs) 0;">{{ b.label_display_list }}</p>{% endif %}
        <p class="quote-cn">{{ b.summary_text or '' }}</p>
      </div>
      {% endfor %}
      {% endif %}

      {% if report_copy.benchmark_takeaway %}
      <div class="ai-box ai-box-insight">
        <p>{{ report_copy.benchmark_takeaway }}</p>
      </div>
      {% endif %}
    </section>
    {% endif %}

    <!-- ════════════════════════════════════════════════════════
         TAB 6: 全景数据 (Panorama)
         ════════════════════════════════════════════════════════ -->
    <section id="tab-panorama" class="tab-panel" role="tabpanel">
      <h2 class="section-title">全景数据</h2>

      <!-- Heatmap -->
      {% if charts.heatmap and charts.heatmap.y_labels | length >= 3 %}
      <h3>特征情感热力图</h3>
      <div class="heatmap-container">
        <table class="heatmap-table">
          <thead><tr><th></th>{% for x in charts.heatmap.x_labels %}<th>{{ x[:5] }}</th>{% endfor %}</tr></thead>
          <tbody>
            {% for y_idx in range(charts.heatmap.y_labels | length) %}
            <tr>
              <th>{{ charts.heatmap.y_labels[y_idx][:20] }}</th>
              {% for x_idx in range(charts.heatmap.x_labels | length) %}
              {% set val = charts.heatmap.z[y_idx][x_idx] if y_idx < charts.heatmap.z | length and x_idx < charts.heatmap.z[y_idx] | length else 0 %}
              <td class="heatmap-cell" style="background: {{ 'rgba(4,120,87,' ~ (val * 0.6) ~ ')' if val > 0 else 'rgba(185,28,28,' ~ (-val * 0.6) ~ ')' if val < 0 else 'transparent' }}; {{ 'color:#fff' if (val > 0.3 or val < -0.3) else '' }}">{{ val | round(2) }}</td>
              {% endfor %}
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      {% endif %}

      <!-- Sentiment Charts -->
      <div class="chart-grid">
        {% if charts.sentiment_own %}
        <div class="chart-container">
          <h3>自有产品评分分布</h3>
          <canvas data-chart-config='{{ charts.sentiment_own | tojson }}'></canvas>
        </div>
        {% endif %}
        {% if charts.sentiment_comp %}
        <div class="chart-container">
          <h3>竞品评分分布</h3>
          <canvas data-chart-config='{{ charts.sentiment_comp | tojson }}'></canvas>
        </div>
        {% endif %}
      </div>

      <!-- Review Detail Table with Pagination -->
      {# P008: panorama uses cumulative data (all reviews), not just window #}
      {% set _panorama_reviews = snapshot.cumulative.reviews if snapshot.cumulative is defined and snapshot.cumulative and snapshot.cumulative.reviews is defined else snapshot.reviews %}
      {% if _panorama_reviews %}
      <h3 class="mt-xl">评论明细（累积 {{ _panorama_reviews|length }} 条）</h3>
      <div class="filter-bar">
        <input type="text" class="filter-input" data-target="review-table" placeholder="搜索产品、标题、评论内容...">
        <div class="filter-pills">
          <button class="filter-pill active" data-ownership="all">全部</button>
          <button class="filter-pill" data-ownership="own">自有</button>
          <button class="filter-pill" data-ownership="comp">竞品</button>
        </div>
        <span class="filter-count"></span>
      </div>
      <div class="table-wrap">
        <table class="data-table" id="review-table">
          <thead>
            <tr>
              <th data-sortable>产品</th>
              <th data-sortable>归属</th>
              <th data-sortable>评分</th>
              <th data-sortable>标题</th>
              <th>正文</th>
              <th data-sortable>日期</th>
            </tr>
          </thead>
          <tbody>
            {% for r in _panorama_reviews %}
            <tr id="review-{{ r.id }}">
              <td>{{ r.product_name }}</td>
              <td>{{ '自有' if r.ownership == 'own' else '竞品' }}</td>
              <td><span class="quote-stars" data-rating="{{ r.rating }}"></span></td>
              <td>{{ r.headline_cn or r.headline }}</td>
              <td style="max-width:360px; font-size: var(--fs-xs); color: var(--text-secondary);">{{ (r.body_cn or r.body or '')[:160] }}</td>
              <td style="font-family: var(--font-mono); font-size: var(--fs-xs); white-space:nowrap;">{{ r.date_published_parsed or r.date_published }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      <div id="review-pagination" class="pagination"></div>
      {% if analytics.has_estimated_dates %}
      <p class="footnote">⚠️ 部分评论日期为相对时间估算值（如"3 years ago"），时间分布仅供参考。</p>
      {% endif %}
      {% endif %}
    </section>

    {% if analytics.label_quality is defined and analytics.label_quality and analytics.label_quality.total_flagged is defined and analytics.label_quality.total_flagged > 0 %}
    <section style="margin-top:24px;padding:12px 16px;background:var(--surface,#fff);border:1px solid var(--border,#e2e8f0);border-radius:8px;">
      <h3 style="font-size:14px;margin:0 0 8px;">标签质量</h3>
      <p style="font-size:13px;color:var(--text-secondary,#718096);">
        {{ analytics.label_quality.total_checked }} 条评论已分析，其中 {{ analytics.label_quality.total_flagged }} 条标注存疑
      </p>
    </section>
    {% endif %}

  </main>

  <!-- Lightbox -->
  <div id="lightbox">
    <div class="lightbox-backdrop"></div>
    <img id="lightbox-img" src="" alt="">
    <button id="lightbox-close">&times;</button>
  </div>

  <!-- Chart.js CDN -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4"
          onerror="document.getElementById('chart-fallback-msg').style.display='block'"></script>
  <div id="chart-fallback-msg" style="display:none" class="chart-fallback">
    ⚠️ 图表库加载失败（需要网络连接）。数据表格仍可正常查看。
  </div>

  <script>{{ js_text | safe }}</script>

  <footer class="report-footer">
    <span>QBU 网评监控智能分析系统 · 差评定义：≤{{ threshold or 2 }}星 · 内部资料</span>
    <span class="footer-ai">本报告由 AI 自动生成，数据及分析结论仅供参考</span>
  </footer>
</body>
</html>
