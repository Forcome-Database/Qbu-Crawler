<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>QBU网评监控智能分析报告 {{ logical_date }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700;800&family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700&family=DM+Mono:wght@400;500&family=Noto+Serif+SC:wght@400;600;700&display=swap" rel="stylesheet">
  <style>{{ css_text | safe }}</style>
</head>
<body>
  {% set change_digest = analytics.change_digest or {} %}
  {% set change_summary = change_digest.summary or {} %}
  {% set issue_changes = change_digest.issue_changes or {} %}
  {% set issue_new = issue_changes.new or [] %}
  {% set issue_escalated = issue_changes.escalated or [] %}
  {% set issue_improving = issue_changes.improving or [] %}
  {% set issue_de_escalated = issue_changes.de_escalated or [] %}
  {% set issue_change_items = issue_new + issue_escalated + issue_improving + issue_de_escalated %}
  {% set product_changes = change_digest.product_changes or {} %}
  {% set review_signals = change_digest.review_signals or {} %}
  {% set fresh_negative_reviews = review_signals.fresh_negative_reviews or [] %}
  {% set fresh_competitor_positive_reviews = review_signals.fresh_competitor_positive_reviews or [] %}
  {% set review_signal_items = fresh_negative_reviews + fresh_competitor_positive_reviews %}
  {% set change_warnings = change_digest.warnings or {} %}
  {% set change_empty = change_digest.empty_state or {} %}
  {% set trend_digest = analytics.trend_digest or {} %}
  {% set risk_products = analytics.self.risk_products if analytics.self is defined else [] %}
  {% set gap_analysis = analytics.competitor.gap_analysis if analytics.competitor is defined else [] %}
  {% set benchmarks = analytics.competitor.benchmark_examples if analytics.competitor is defined else [] %}
  {% set own_review_rows = analytics.kpis.own_review_rows or 0 %}
  {% set competitor_review_rows = analytics.kpis.competitor_review_rows or 0 %}
  {% set window_ingested_reviews = change_summary.get("ingested_review_count", analytics.kpis.get("ingested_review_rows", 0)) %}
  {% set recent_review_rows = analytics.kpis.get("recently_published_count", change_summary.fresh_review_count or 0) %}

  <header class="kpi-bar">
    <div class="kpi-bar-inner">
      <span class="kpi-bar-brand">QBU 网评监控</span>
      <div class="kpi-bar-metrics">
        {% for card in (analytics.kpi_cards or [])[:5] %}
        <span class="kpi-bar-item">{{ card.label }} <strong>{{ card.value }}</strong></span>
        {% endfor %}
      </div>
      <button id="btn-print" class="btn-icon" title="打印 / 导出PDF">⎙</button>
    </div>
  </header>

  <nav class="tab-nav" role="tablist">
    <button data-tab="overview" class="tab-btn tab-active" role="tab">总览</button>
    <button data-tab="changes" class="tab-btn" role="tab">今日变化</button>
    <button data-tab="trends" class="tab-btn" role="tab">变化趋势</button>
    <button data-tab="issues" class="tab-btn" role="tab">问题诊断 <span class="tab-badge">{{ (analytics.issue_cards or []) | length }}</span></button>
    <button data-tab="products" class="tab-btn" role="tab">产品排行 <span class="tab-badge">{{ analytics.kpis.own_product_count or 0 }}</span></button>
    <button data-tab="competitive" class="tab-btn" role="tab">竞品对标</button>
    <button data-tab="panorama" class="tab-btn" role="tab">全景数据 <span class="tab-badge">{{ (snapshot.reviews or []) | length }}</span></button>
  </nav>

  <main class="report-main">
    <section id="tab-overview" class="tab-panel tab-active" role="tabpanel">
      <div class="hero">
        <div class="gauge-wrapper" data-health="{{ analytics.kpis.health_index or 50 }}">
          <div class="gauge-arc">
            <div class="gauge-fill"></div>
            <div class="gauge-mask"></div>
            <div class="gauge-value">0</div>
          </div>
          <div class="gauge-label">健康指数</div>
          <div class="gauge-scale"><span>0</span><span>50</span><span>100</span></div>
        </div>
        <div class="hero-text">
          <p class="hero-kicker">Daily Product Intelligence</p>
          <h1 class="hero-title">QBU网评监控智能分析报告</h1>
          <p class="hero-headline">{{ report_copy.hero_headline or (analytics.kpis.health_index|string ~ "/100") }}</p>
          <p class="hero-meta">Run #{{ snapshot.run_id }} · {{ logical_date }} · {{ analytics.mode_display or mode }} · 数据截至 {{ (snapshot.snapshot_at or "")[:16] }}</p>
        </div>
      </div>

      <div class="kpi-grid">
        {% for card in analytics.kpi_cards or [] %}
        <div class="kpi-card reveal">
          <span class="kpi-label">{{ card.label }}{% if card.tooltip %} <span class="tip-trigger" data-tip="{{ card.tooltip }}">?</span>{% endif %}</span>
          <strong class="kpi-value {{ card.value_class or '' }}">{{ card.value }}</strong>
          {% if card.delta_display %}<span class="kpi-delta {{ card.delta_class or '' }}">{{ card.delta_display }}</span>{% endif %}
        </div>
        {% endfor %}
      </div>

      <div class="review-scope-grid">
        <div class="review-scope-item"><span>累计自有评论</span><strong>{{ own_review_rows }}</strong></div>
        <div class="review-scope-item"><span>累计竞品评论</span><strong>{{ competitor_review_rows }}</strong></div>
        <div class="review-scope-item"><span>本次入库评论</span><strong>{{ window_ingested_reviews or 0 }}</strong></div>
        <div class="review-scope-item"><span>近30天评论</span><strong>{{ recent_review_rows or 0 }}</strong></div>
      </div>

      {% if alert_level and alert_text %}
      <div class="alert-banner alert-{{ alert_level }}">{{ alert_text }}</div>
      {% endif %}

      <div class="exec-grid">
        <article class="exec-block reveal">
          <div class="exec-block-header">
            <span class="exec-block-icon icon-judgment">●</span>
            <h3>关键判断</h3>
          </div>
          <div class="exec-block-body">
            <ul>
              {% for item in (report_copy.executive_bullets or [])[:3] %}
              <li>{{ item }}</li>
              {% endfor %}
            </ul>
          </div>
        </article>
        <article class="exec-block reveal">
          <div class="exec-block-header">
            <span class="exec-block-icon icon-scope">●</span>
            <h3>报告口径</h3>
          </div>
          <div class="exec-block-body">
            <div class="exec-scope-row"><span class="exec-scope-label">报告模式</span><span class="exec-scope-value">{{ analytics.mode_display or mode }}</span></div>
            <div class="exec-scope-row"><span class="exec-scope-label">自有产品</span><span class="exec-scope-value">{{ analytics.kpis.own_product_count or 0 }} · 累计评论 {{ own_review_rows }} 条</span></div>
            <div class="exec-scope-row"><span class="exec-scope-label">竞品</span><span class="exec-scope-value">{{ analytics.kpis.competitor_product_count or 0 }} · 累计评论 {{ competitor_review_rows }} 条</span></div>
            <div class="exec-scope-row"><span class="exec-scope-label">差评阈值</span><span class="exec-scope-value">≤ {{ threshold or 2 }} 星</span></div>
          </div>
        </article>
      </div>

      {# F011 §4.2.2 (H14) — 现在该做什么：short_title 作主显，full_action 折叠 #}
      {% set _priorities = (analytics.report_copy or {}).get("improvement_priorities") or [] %}
      {% if _priorities %}
      <section class="recommendations">
        <h2>现在该做什么</h2>
        {% for rec in _priorities[:5] %}
        <div class="recommendation-card reveal">
          <h3 class="rec-title">{{ rec.short_title or rec.label_display or rec.label_code }}</h3>
          <div class="rec-meta">影响 {{ rec.affected_products_count or 0 }} 款 · 证据 {{ rec.evidence_count or 0 }} 条</div>
          <details class="rec-details">
            <summary>详情</summary>
            <p class="rec-full-action">{{ rec.full_action }}</p>
            {% if rec.evidence_review_ids %}
            <div class="evidence-refs">
              {% for rid in rec.evidence_review_ids[:5] %}
                {# F011 §4.2.2 — chip target depends on matching id="review-{{ rid }}" rendered
                   on the panorama-table <tr> below; do not rename without updating both ends. #}
                <a href="#review-{{ rid }}" class="evidence-chip">#{{ rid }}</a>
              {% endfor %}
              {% if (rec.evidence_review_ids | length) > 5 %}
                <span class="evidence-more">+{{ (rec.evidence_review_ids | length) - 5 }} 更多</span>
              {% endif %}
            </div>
            {% endif %}
            {% if rec.affected_products %}
            <div class="affected-products">影响 SKU: {{ rec.affected_products | join("、") }}</div>
            {% endif %}
          </details>
        </div>
        {% endfor %}
      </section>
      {% endif %}
    </section>

    <section id="tab-changes" class="tab-panel" role="tabpanel">
      <h2 class="section-title">今日变化</h2>
      <p class="section-sub">只看本期入库信号，不把全量现状和历史趋势混在一起。</p>

      {# F011 §4.2.4 — bootstrap 单卡 / mature 三层金字塔 #}
      {% if analytics.report_semantics == "bootstrap" or change_digest.view_state == "bootstrap" %}
      <div class="info-card bootstrap-notice">
        ℹ 首日基线已建档，对比信号将从下一日起出现
      </div>
      {% else %}
      {% set ia = change_digest.immediate_attention or {} %}
      {% set tc = change_digest.trend_changes or {} %}
      {% set co = change_digest.competitive_opportunities or {} %}

      {# Layer 1: 🔥 立即关注 (red) #}
      {% if ia.own_new_negative_reviews or ia.own_rating_drops or ia.own_stock_alerts %}
      <div class="layer immediate-attention">
        <h3>🔥 立即关注</h3>
        {% for item in ia.own_new_negative_reviews or [] %}
        <div class="alert-item">• 我方新差评 {{ item.review_count or 0 }} 条（{{ item.product_name or "未命名产品" }}）— 主要问题：{{ (item.primary_problems or []) | join('、') or "(暂无标签)" }}</div>
        {% endfor %}
        {% for item in ia.own_rating_drops or [] %}
        {% set _from = item.rating_from if item.rating_from is not none else item.prev %}
        {% set _to = item.rating_to if item.rating_to is not none else item.new %}
        <div class="alert-item">• {{ item.product_name or item.sku or "未命名产品" }} 评分 {{ _from if _from is not none else "-" }} → {{ _to if _to is not none else "-" }}{% if item.delta is not none %} ({{ "{:+.2f}".format(item.delta) }}){% endif %}</div>
        {% endfor %}
        {% for item in ia.own_stock_alerts or [] %}
        <div class="alert-item">• {{ item.product_name or item.sku or "未命名产品" }} 缺货警告{% if item.new_status %}（{{ item.new_status }}）{% endif %}</div>
        {% endfor %}
      </div>
      {% endif %}

      {# Layer 2: 📈 趋势变化 (yellow) #}
      {% if tc.new_issues or tc.escalated_issues or tc.improving_issues %}
      <div class="layer trend-changes">
        <h3>📈 趋势变化</h3>
        {% for item in tc.new_issues or [] %}
        <div class="trend-item new">• 新增问题：{{ item.label_display or item.label_code or "未命名问题" }}（{{ item.current_review_count or 0 }} 条 / {{ item.affected_product_count or 0 }} 款）</div>
        {% endfor %}
        {% for item in tc.escalated_issues or [] %}
        <div class="trend-item escalated">• 升级问题：{{ item.label_display or item.label_code or "未命名问题" }}（{{ item.current_review_count or 0 }} 条 / {{ item.affected_product_count or 0 }} 款）</div>
        {% endfor %}
        {% for item in tc.improving_issues or [] %}
        <div class="trend-item improving">• 改善问题：{{ item.label_display or item.label_code or "未命名问题" }}（{{ item.current_review_count or 0 }} 条 / {{ item.affected_product_count or 0 }} 款）</div>
        {% endfor %}
      </div>
      {% endif %}

      {# Layer 3: 💡 反向利用 (blue) #}
      {% if co.competitor_new_negative_reviews or co.competitor_new_positive_reviews %}
      <div class="layer competitive-opportunities">
        <h3>💡 反向利用</h3>
        {% for item in co.competitor_new_negative_reviews or [] %}
        <div class="comp-item negative">• 竞品差评机会：{{ item.product_name or item.competitor_name or "未命名竞品" }}{% if item.review_count %}（{{ item.review_count }} 条）{% endif %} — {{ (item.primary_problems or []) | join('、') if item.primary_problems else (item.headline or "差评信号") }}</div>
        {% endfor %}
        {% for item in co.competitor_new_positive_reviews or [] %}
        <div class="comp-item positive">• 竞品好评借鉴：{{ item.product_name or item.competitor_name or "未命名竞品" }} — {{ item.highlight or item.headline or "好评亮点" }}</div>
        {% endfor %}
      </div>
      {% endif %}
      {% endif %}
    </section>

    <section id="tab-trends" class="tab-panel" role="tabpanel">
      <h2 class="section-title">变化趋势</h2>

      {# F011 §4.2.5 — 1 主图 + 3 折叠下钻；bootstrap (low / no_data) 单卡 #}
      {% set td = analytics.trend_digest or {} %}
      {% set primary = td.primary_chart or {} %}
      {% set _confidence = primary.confidence or "no_data" %}

      {% if _confidence in ("low", "no_data") %}
      <div class="info-card bootstrap-notice trend-bootstrap-notice">
        ℹ 趋势数据正在累积，需 ≥30 样本且每周 ≥7 个有效样本
        {% if primary.min_sample_warning %}
        <div class="warning-detail">{{ primary.min_sample_warning }}</div>
        {% endif %}
      </div>
      {% else %}
      <div class="primary-chart">
        <h3>口碑健康度趋势</h3>

        <div id="health-trend-chart" class="health-trend-chart"
             data-series-own='{{ primary.series_own | tojson }}'
             data-series-competitor='{{ primary.series_competitor | tojson }}'>
        </div>

        {% if primary.comparison and primary.comparison.own_vs_prior_window %}
        {% set _cmp = primary.comparison.own_vs_prior_window %}
        <div class="comparison-baseline">
          当前 {{ "%.1f"|format(_cmp.current or 0) }}
          {% if _cmp.delta is not none %}
            {% if _cmp.delta < 0 %}↓{% elif _cmp.delta > 0 %}↑{% else %}→{% endif %}
            {{ "%.1f"|format(_cmp.delta|abs) }}pt
          {% endif %}
          vs 上期平均（对比上 {{ primary.default_window or "30 天" }}平均）
        </div>
        {% endif %}

        <div class="window-toggle">
          <span class="toggle-label">时间切换:</span>
          {% for w in primary.windows_available or [] %}
          <button type="button" data-window="{{ w }}"{% if w == primary.default_window %} class="active"{% endif %}>{{ w }}</button>
          {% endfor %}
        </div>
        <div class="anchor-toggle">
          <span class="toggle-label">口径切换:</span>
          <button type="button" data-anchor="scraped_at"{% if primary.default_anchor == "scraped_at" %} class="active"{% endif %}>采集时间</button>
          <button type="button" data-anchor="date_published"{% if primary.default_anchor == "date_published" %} class="active"{% endif %}>发表时间</button>
        </div>
      </div>

      {% for d in td.drill_downs or [] %}
      <details class="drill-down">
        <summary>{{ d.title }}</summary>
        <div class="drill-content" data-drill-id="{{ d.id }}" data-payload='{{ d.data | tojson }}'></div>
      </details>
      {% endfor %}
      {% endif %}
    </section>

    <section id="tab-issues" class="tab-panel" role="tabpanel">
      <h2 class="section-title">自有产品问题诊断</h2>
      {# F011 §4.2.3.1 v1.2 — Top 3 default-expanded; remaining wrapped in <details> #}
      <p class="section-sub">Top 3 默认展开 · 共 {{ (analytics.issue_cards or []) | length }} 张诊断卡</p>
      {% if not analytics.issue_cards %}
      <div class="empty-state">未发现明确问题簇。</div>
      {% endif %}

      {% set _expanded_cards = (analytics.issue_cards or []) | selectattr("default_expanded", "equalto", true) | list %}
      {% set _folded_cards = (analytics.issue_cards or []) | selectattr("default_expanded", "equalto", false) | list %}

      {% for card in _expanded_cards %}
      {% set idx = loop.index %}
      <div class="issue-card severity-{{ card.severity }} reveal">
        <div class="card-header">
          <span class="card-number">#{{ idx }}</span>
          <strong class="card-title">{{ card.feature_display or card.label_display }}</strong>
          <span class="badge badge-{{ card.severity }}">{{ card.severity_display }}</span>
          <span class="card-toggle">▾</span>
        </div>
        <div class="card-body">
          <div class="card-stats">
            <span>{{ card.review_count }} 条评论</span>
            <span>{{ card.affected_product_count }} 个产品</span>
            {% if card.recency_display %}<span>{{ card.recency_display }}</span>{% endif %}
            {% if card.frequent_period %}
              <span class="frequent-period">高频期 {{ card.frequent_period.start }} ~ {{ card.frequent_period.end }}</span>
            {% endif %}
          </div>
          {% for review in (card.example_reviews or [])[:2] %}
          <blockquote class="quote-block">
            <div class="quote-meta">
              <span class="quote-stars" data-rating="{{ review.rating }}"></span>
              <span>{{ review.author or "" }}</span>
              <span>{{ review.date_published or "" }}</span>
            </div>
            <p class="quote-cn">"{{ review.headline_cn or review.headline or "" }}：{{ (review.body_cn or review.body or "")[:200] }}"</p>
          </blockquote>
          {% endfor %}
          {% if card.recommendation %}
          <div class="ai-box ai-box-suggest"><p>{{ card.recommendation }}</p></div>
          {% endif %}
        </div>
      </div>
      {% endfor %}

      {% if _folded_cards %}
      <details class="issue-cards-folded">
        <summary>展开剩余 {{ _folded_cards | length }} 张诊断卡</summary>
        {% for card in _folded_cards %}
        {% set idx = (_expanded_cards | length) + loop.index %}
        <div class="issue-card severity-{{ card.severity }} reveal">
          <div class="card-header">
            <span class="card-number">#{{ idx }}</span>
            <strong class="card-title">{{ card.feature_display or card.label_display }}</strong>
            <span class="badge badge-{{ card.severity }}">{{ card.severity_display }}</span>
            <span class="card-toggle">▾</span>
          </div>
          <div class="card-body">
            <div class="card-stats">
              <span>{{ card.review_count }} 条评论</span>
              <span>{{ card.affected_product_count }} 个产品</span>
              {% if card.recency_display %}<span>{{ card.recency_display }}</span>{% endif %}
              {% if card.frequent_period %}
                <span class="frequent-period">高频期 {{ card.frequent_period.start }} ~ {{ card.frequent_period.end }}</span>
              {% endif %}
            </div>
            {% for review in (card.example_reviews or [])[:2] %}
            <blockquote class="quote-block">
              <div class="quote-meta">
                <span class="quote-stars" data-rating="{{ review.rating }}"></span>
                <span>{{ review.author or "" }}</span>
                <span>{{ review.date_published or "" }}</span>
              </div>
              <p class="quote-cn">"{{ review.headline_cn or review.headline or "" }}：{{ (review.body_cn or review.body or "")[:200] }}"</p>
            </blockquote>
            {% endfor %}
            {% if card.recommendation %}
            <div class="ai-box ai-box-suggest"><p>{{ card.recommendation }}</p></div>
            {% endif %}
          </div>
        </div>
        {% endfor %}
      </details>
      {% endif %}
    </section>

    <section id="tab-products" class="tab-panel" role="tabpanel">
      <h2 class="section-title">自有产品状态</h2>
      <p class="section-sub">灯 + 一句原因（详细风险因子悬停查看）。</p>

      {% set product_status = (analytics.self or {}).get("product_status") or [] %}
      {% if product_status %}
      <div class="table-wrap">
        <table class="data-table product-status-table">
          <thead>
            <tr>
              <th>状态</th>
              <th>产品</th>
              <th>主要问题</th>
              <th class="hover-only">风险分</th>
            </tr>
          </thead>
          <tbody>
            {% for p in product_status %}
            <tr class="status-row status-{{ p.status_lamp }}">
              <td>
                <span class="lamp lamp-{{ p.status_lamp }}" aria-hidden="true">
                  {%- if p.status_lamp == "green" -%}🟢
                  {%- elif p.status_lamp == "yellow" -%}🟡
                  {%- elif p.status_lamp == "red" -%}🔴
                  {%- else -%}⚪{%- endif -%}
                </span>
                <span class="status-label">{{ p.status_label }}</span>
              </td>
              <td>{{ p.product_name or p.product_sku }}</td>
              <td class="primary-concern">
                {%- if p.primary_concern -%}
                  {{ p.primary_concern }}
                {%- elif p.status_lamp == 'green' -%}
                  健康
                {%- elif p.status_lamp == 'gray' -%}
                  无数据
                {%- endif -%}
              </td>
              <td class="risk-detail hover-only">
                <span class="risk-score" data-tooltip='{{ (p.risk_factors or {}) | tojson }}'>
                  {{ "%.1f"|format(p.risk_score or 0) }}
                </span>
              </td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      {% else %}
      <div class="empty-state">暂无产品状态数据。</div>
      {% endif %}

      {% if charts.scatter %}
      <div class="chart-container">
        <h3>价格-评分象限</h3>
        <canvas data-chart-config='{{ charts.scatter | tojson }}'></canvas>
      </div>
      {% endif %}
    </section>

    <section id="tab-competitive" class="tab-panel" role="tabpanel">
      <h2 class="section-title">竞品对标</h2>
      {% if gap_analysis %}
      <div class="table-wrap">
        <table class="data-table">
          <thead>
            <tr>
              <th>维度</th>
              <th>类型</th>
              <th>优先级</th>
              <th>竞品好评</th>
              <th>自有差评</th>
            </tr>
          </thead>
          <tbody>
            {% for gap in gap_analysis %}
            <tr>
              <td>{{ gap.label_display or "" }}</td>
              <td>{{ gap.gap_type or "" }}</td>
              <td>{{ gap.priority_display or "" }}</td>
              <td>{{ gap.competitor_positive_count or 0 }}</td>
              <td>{{ gap.own_negative_count or 0 }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      {% endif %}
      {% if charts.radar %}
      <div class="chart-container">
        <h3>竞品对标雷达图</h3>
        <div style="max-width:420px;margin:0 auto;">
          <canvas data-chart-config='{{ charts.radar | tojson }}'></canvas>
        </div>
      </div>
      {% endif %}
      {% if benchmarks %}
      {% for benchmark in benchmarks[:3] %}
      <blockquote class="quote-block quote-positive reveal">
        <div class="quote-meta">
          <strong>{{ benchmark.product_name or "" }}</strong>
          <span>{{ benchmark.label_display_list or "" }}</span>
        </div>
        <p class="quote-cn">{{ benchmark.summary_text or "" }}</p>
      </blockquote>
      {% endfor %}
      {% endif %}
    </section>

    <section id="tab-panorama" class="tab-panel panorama" role="tabpanel">
      <h2 class="section-title">全景数据</h2>
      <p class="section-sub">{{ (snapshot.reviews or []) | length }} 条评论 · 5 个客户端筛选器</p>

      {% if analytics._heatmap_data and analytics._heatmap_data.y_labels and analytics._heatmap_data.x_labels %}
      {# F011 §4.2.6.2 v1.2 — feature × product sentiment heatmap (Top 8 dim aggregation) #}
      <section class="heatmap-section">
        <h3 class="subsection-title">特征情感热力图</h3>
        <div class="heatmap-legend" role="note" aria-label="热力图色阶图例">
          <span class="legend-item"><span class="legend-cell green"></span>认可（&gt;70%）</span>
          <span class="legend-item"><span class="legend-cell yellow"></span>中性（40%–70%）</span>
          <span class="legend-item"><span class="legend-cell red"></span>负面（&lt;40%）</span>
          <span class="legend-item"><span class="legend-cell gray"></span>样本不足（&lt;3）</span>
        </div>
        <div class="heatmap-container">
          <table class="heatmap-table heatmap-table-v12">
            <thead>
              <tr>
                <th></th>
                {% for x in analytics._heatmap_data.x_labels %}
                <th>{{ x }}</th>
                {% endfor %}
              </tr>
            </thead>
            <tbody>
              {% for y in analytics._heatmap_data.y_labels %}
              <tr>
                <th>{{ y }}</th>
                {% set row = analytics._heatmap_data.z[loop.index0] %}
                {% set y_label = y %}
                {% for cell in row %}
                  {# Bind cell_idx explicitly before any inner loop can shadow loop.index0. #}
                  {% set cell_idx = loop.index0 %}
                  {% set x_label = analytics._heatmap_data.x_labels[cell_idx] %}
                  {% set x_code = (analytics._heatmap_data.x_label_codes[cell_idx] if analytics._heatmap_data.x_label_codes else '') %}
                  <td class="heatmap-cell {{ cell.color_class }}"
                      data-product="{{ y_label }}"
                      data-label="{{ x_label }}"
                      data-label-code="{{ x_code }}"
                      data-review-id="{{ cell.top_review_id or '' }}"
                      title="{{ y_label }} × {{ x_label }} ({{ cell.sample_size }} 条)&#10;{{ cell.top_review_excerpt }}">
                    {% if cell.score is not none %}{{ '%.0f%%' | format(cell.score * 100) }}{% else %}—{% endif %}
                  </td>
                {% endfor %}
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
        {% if analytics._heatmap_data.aggregated_labels %}
        <p class="heatmap-foot">
          “其他”聚合了 {{ analytics._heatmap_data.aggregated_labels | length }} 个低频维度
        </p>
        {% endif %}
      </section>
      {% endif %}

      <div class="panorama-filters">
        <select name="ownership" aria-label="归属">
          <option value="">全部归属</option>
          <option value="own">自有</option>
          <option value="competitor">竞品</option>
        </select>
        <select name="rating" aria-label="评分">
          <option value="">全部评分</option>
          <option value="low">≤2 星</option>
          <option value="mid">3 星</option>
          <option value="high">≥4 星</option>
        </select>
        <label class="checkbox-label"><input type="checkbox" name="has_images"> 仅含图</label>
        <label class="checkbox-label"><input type="checkbox" name="recent"> 近 30 天</label>
        <select name="label" aria-label="标签">
          <option value="">全部标签</option>
          {% for l in analytics.label_options or [] %}
          <option value="{{ l.code }}">{{ l.display }}</option>
          {% endfor %}
        </select>
      </div>

      <div class="table-wrap">
        <table class="data-table panorama-table">
          <thead>
            <tr>
              <th>归属</th>
              <th>产品</th>
              <th>评分</th>
              <th>标题</th>
              <th>正文</th>
              <th>发表日期</th>
            </tr>
          </thead>
          <tbody>
            {% for r in snapshot.reviews or [] %}
            <tr id="review-{{ r.id }}"
                data-review-id="{{ r.id }}"
                data-ownership="{{ r.ownership or '' }}"
                data-rating="{{ r.rating or 0 }}"
                data-has-images="{{ '1' if r.images else '0' }}"
                data-recent="{{ '1' if r.is_recent else '0' }}"
                data-labels="{{ (r.label_codes or []) | join(',') }}">
              <td>{{ '自有' if r.ownership == 'own' else '竞品' if r.ownership == 'competitor' else '' }}</td>
              <td>{{ r.product_name or '' }}</td>
              <td>{{ r.rating or '' }}</td>
              <td>{{ r.headline_cn or r.headline or '' }}</td>
              <td class="review-body">{{ (r.body_cn or r.body_translated or r.body or '') | truncate(200) }}</td>
              <td>{{ r.date_published or '' }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </section>
  </main>

  <div id="lightbox">
    <div class="lightbox-backdrop"></div>
    <img id="lightbox-img" src="" alt="">
    <button id="lightbox-close">&times;</button>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/chart.js@4" onerror="document.getElementById('chart-fallback-msg').style.display='block'"></script>
  <div id="chart-fallback-msg" style="display:none" class="chart-fallback">⚠️ 图表库加载失败，仍可查看文字和表格。</div>

  <script>{{ js_text | safe }}</script>

  <footer class="report-footer">
    <span>QBU 网评监控智能分析系统 · 差评定义：≤{{ threshold or 2 }}星 · 内部资料</span>
    <span class="footer-ai">本报告由 AI 自动生成，数据及分析结论仅供参考</span>
  </footer>
</body>
</html>
