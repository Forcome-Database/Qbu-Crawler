<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>产品监控简报 {{ logical_date }}</title>
  <style>{{ css_text | safe }}</style>
</head>
<body>
  <div class="report-main">

    <!-- ===== HEADER ===== -->
    <div style="background:#93543f;padding:16px 24px;border-radius:12px 12px 0 0;margin-bottom:0;">
      <table style="width:100%;border-collapse:collapse;">
        <tr>
          <td style="color:#ffffff;font-size:13px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;">Daily Product Intelligence</td>
          <td style="color:rgba(255,255,255,0.7);font-size:12px;text-align:right;white-space:nowrap;">{{ logical_date }}</td>
        </tr>
      </table>
    </div>

    <!-- ===== QUIET STATUS BANNER ===== -->
    <div class="alert-signal alert-green" style="border-radius:0;margin-bottom:0;">
      &#10003;&nbsp;&nbsp;今日无新评论 — 简报模式 &nbsp;·&nbsp; 上次采集：{{ (snapshot.snapshot_at or "")[:16] }}
    </div>

    <div style="background:#fffaf3;border:1px solid #d9ccb9;border-top:none;border-radius:0 0 12px 12px;padding:24px;margin-bottom:24px;">

      <!-- ===== KPI SNAPSHOT (from previous analytics) ===== -->
      {% set kpis = (previous_analytics or {}).get("kpis", {}) %}
      <div class="section-kicker" style="margin-top:0;">当前健康快照（上期数据）</div>
      <h2 style="font-size:20px;letter-spacing:-0.02em;margin-bottom:14px;">产品整体状况</h2>

      <div class="kpi-grid" style="padding:0 0 16px;">
        <!-- Health Index -->
        <div class="metric-card">
          <div class="metric-label">健康指数</div>
          <strong class="metric-value" style="color:#93543f;">{{ kpis.get("health_index", "N/A") }}</strong>
          <span class="metric-delta delta-flat">/ 100</span>
        </div>
        <!-- Negative Rate -->
        <div class="metric-card">
          <div class="metric-label">差评率</div>
          <strong class="metric-value">{{ kpis.get("own_negative_review_rate_display", "N/A") }}</strong>
        </div>
        <!-- Sample Size -->
        <div class="metric-card">
          <div class="metric-label">评论样本量</div>
          <strong class="metric-value">{{ kpis.get("own_review_rows", 0) }}</strong>
        </div>
        <!-- High Risk Count -->
        <div class="metric-card">
          <div class="metric-label">高风险产品</div>
          <strong class="metric-value" style="{% if kpis.get('high_risk_count', 0) > 0 %}color:#93543f;{% endif %}">
            {{ kpis.get("high_risk_count", 0) }}
          </strong>
        </div>
      </div>

      <!-- ===== DATA CHANGES ===== -->
      {% if changes and changes.has_changes %}
      <div class="section-kicker" style="margin-top:8px;">数据变化</div>
      <h2 style="font-size:20px;letter-spacing:-0.02em;margin-bottom:14px;">本期变动明细</h2>

      {% if changes.price_changes %}
      <div class="section-kicker" style="margin-top:4px;">价格变化</div>
      <table class="data-table" style="width:100%;border-collapse:collapse;font-size:13px;margin-bottom:16px;">
        <thead><tr>
          <th style="padding:8px 10px;background:#f1e6d7;color:#766d62;text-align:left;font-weight:700;">产品</th>
          <th style="padding:8px 10px;background:#f1e6d7;color:#766d62;text-align:center;font-weight:700;">原价</th>
          <th style="padding:8px 10px;background:#f1e6d7;color:#766d62;text-align:center;font-weight:700;">现价</th>
        </tr></thead>
        <tbody>
        {% for c in changes.price_changes %}
        <tr style="background:{% if loop.index is odd %}#faf5ef{% else %}#ffffff{% endif %};">
          <td style="padding:7px 10px;border-bottom:1px solid #e8dfd4;color:#201b16;">{{ c.name }}</td>
          <td style="padding:7px 10px;border-bottom:1px solid #e8dfd4;text-align:center;color:#766d62;">${{ c.old }}</td>
          <td style="padding:7px 10px;border-bottom:1px solid #e8dfd4;text-align:center;font-weight:700;">${{ c.new }}</td>
        </tr>
        {% endfor %}
        </tbody>
      </table>
      {% endif %}

      {% if changes.stock_changes %}
      <div class="section-kicker" style="margin-top:4px;">库存变化</div>
      <table class="data-table" style="width:100%;border-collapse:collapse;font-size:13px;margin-bottom:16px;">
        <thead><tr>
          <th style="padding:8px 10px;background:#f1e6d7;color:#766d62;text-align:left;font-weight:700;">产品</th>
          <th style="padding:8px 10px;background:#f1e6d7;color:#766d62;text-align:center;font-weight:700;">原状态</th>
          <th style="padding:8px 10px;background:#f1e6d7;color:#766d62;text-align:center;font-weight:700;">现状态</th>
        </tr></thead>
        <tbody>
        {% for c in changes.stock_changes %}
        <tr style="background:{% if loop.index is odd %}#faf5ef{% else %}#ffffff{% endif %};">
          <td style="padding:7px 10px;border-bottom:1px solid #e8dfd4;color:#201b16;">{{ c.name }}</td>
          <td style="padding:7px 10px;border-bottom:1px solid #e8dfd4;text-align:center;color:#766d62;">{{ c.old }}</td>
          <td style="padding:7px 10px;border-bottom:1px solid #e8dfd4;text-align:center;font-weight:700;">{{ c.new }}</td>
        </tr>
        {% endfor %}
        </tbody>
      </table>
      {% endif %}

      {% if changes.rating_changes %}
      <div class="section-kicker" style="margin-top:4px;">评分变化</div>
      <table class="data-table" style="width:100%;border-collapse:collapse;font-size:13px;margin-bottom:16px;">
        <thead><tr>
          <th style="padding:8px 10px;background:#f1e6d7;color:#766d62;text-align:left;font-weight:700;">产品</th>
          <th style="padding:8px 10px;background:#f1e6d7;color:#766d62;text-align:center;font-weight:700;">原评分</th>
          <th style="padding:8px 10px;background:#f1e6d7;color:#766d62;text-align:center;font-weight:700;">现评分</th>
        </tr></thead>
        <tbody>
        {% for c in changes.rating_changes %}
        <tr style="background:{% if loop.index is odd %}#faf5ef{% else %}#ffffff{% endif %};">
          <td style="padding:7px 10px;border-bottom:1px solid #e8dfd4;color:#201b16;">{{ c.name }}</td>
          <td style="padding:7px 10px;border-bottom:1px solid #e8dfd4;text-align:center;color:#766d62;">{{ c.old }}</td>
          <td style="padding:7px 10px;border-bottom:1px solid #e8dfd4;text-align:center;font-weight:700;">{{ c.new }}</td>
        </tr>
        {% endfor %}
        </tbody>
      </table>
      {% endif %}

      {% if changes.new_products %}
      <div class="section-kicker" style="margin-top:4px;">新增监控产品</div>
      <ul style="font-size:13px;color:#201b16;margin:0 0 16px;padding-left:20px;">
        {% for p in changes.new_products %}<li>{{ p.name }} ({{ p.sku }})</li>{% endfor %}
      </ul>
      {% endif %}

      {% if changes.removed_products %}
      <div class="section-kicker" style="margin-top:4px;">产品不可用</div>
      <ul style="font-size:13px;color:#93543f;margin:0 0 16px;padding-left:20px;">
        {% for p in changes.removed_products %}<li>{{ p.name }} ({{ p.sku }})</li>{% endfor %}
      </ul>
      {% endif %}

      {% endif %}

      <!-- ===== OUTSTANDING ISSUES ===== -->
      {% set clusters = ((previous_analytics or {}).get("self", {}) or {}).get("top_negative_clusters", []) %}
      {% set active_clusters = clusters | selectattr("severity", "in", ["critical", "high", "medium"]) | list %}
      {% if active_clusters %}
      <div class="section-kicker" style="margin-top:8px;">未解决问题（上期遗留）</div>
      <h2 style="font-size:20px;letter-spacing:-0.02em;margin-bottom:14px;">需持续关注</h2>

      {% for c in active_clusters %}
      {% set sev = c.get("severity", "low") %}
      <div class="issue-card severity-{{ sev }}" style="margin-bottom:10px;">
        <div class="card-header" style="cursor:default;padding:12px 16px;">
          <div style="flex:1;">
            <span class="badge badge-{{ sev }}" style="margin-right:8px;">
              {{ c.get("severity_display", sev) }}
            </span>
            <strong>{{ c.get("label_display", c.get("label_code", "")) }}</strong>
          </div>
          <div style="font-size:13px;color:#766d62;white-space:nowrap;">
            {{ c.get("review_count", 0) }} 条差评
          </div>
        </div>
      </div>
      {% endfor %}
      {% else %}
      <div class="empty-state" style="padding:24px 0 8px;">暂无未解决的中高风险问题</div>
      {% endif %}

      <!-- ===== TRANSLATION PROGRESS ===== -->
      {% if translate_stats %}
      {% set total = translate_stats.get("total", 0) %}
      {% set done = translate_stats.get("done", 0) %}
      {% set pending = translate_stats.get("pending", 0) %}
      {% set failed = translate_stats.get("failed", 0) %}
      {% set pct = ((done / (total or 1)) * 100) | round(0) | int %}
      <div class="section-kicker" style="margin-top:16px;">翻译进度</div>
      <h2 style="font-size:20px;letter-spacing:-0.02em;margin-bottom:10px;">评论中文化状态</h2>

      <!-- Progress bar -->
      <div style="background:#e8dfd4;border-radius:999px;height:8px;margin-bottom:10px;overflow:hidden;">
        <div style="background:#93543f;height:8px;width:{{ [pct, 100] | min }}%;border-radius:999px;transition:width 0.4s;"></div>
      </div>
      <p style="font-size:13px;color:#766d62;margin:0 0 4px;">
        已翻译 <strong style="color:#201b16;">{{ done }}</strong> /
        <strong style="color:#201b16;">{{ total }}</strong> 条
        （{{ pct }}%）
        {% if pending > 0 %}&nbsp;·&nbsp; 待处理 <strong>{{ pending }}</strong> 条{% endif %}
        {% if failed > 0 %}&nbsp;·&nbsp; <span style="color:#93543f;">失败 {{ failed }} 条</span>{% endif %}
      </p>
      {% endif %}

      <!-- ===== LINK TO LAST FULL REPORT ===== -->
      {% if last_full_report_path %}
      <div style="margin-top:20px;padding:14px 16px;background:#f5f0e8;border:1px solid #e8dfd4;border-radius:8px;">
        &#128196;&nbsp;
        <a href="{{ last_full_report_path }}" style="color:#93543f;font-weight:600;text-decoration:none;">
          查看上期完整分析报告
        </a>
        <span style="color:#766d62;font-size:12px;">&nbsp;— 包含详细问题分析与建议</span>
      </div>
      {% endif %}

    </div><!-- end white panel -->

    <!-- ===== FOOTER ===== -->
    <footer class="report-footer">
      <p>产品评论智能监控系统 &nbsp;·&nbsp; 差评定义：≤{{ threshold or 2 }}星 &nbsp;·&nbsp; 内部资料<br>
      此报告由自动化系统生成，仅在数据静默日触发。</p>
    </footer>

  </div><!-- end report-main -->
</body>
</html>
