<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <title>产品评论深度分析报告 {{ snapshot.logical_date }}</title>
  <style>{{ css_text | safe }}</style>
  <style>:root { --report-font-family: "{{ report_font_family }}", sans-serif; }</style>
  <script>{{ plotly_js | safe }}</script>
</head>
<body class="report-shell">

  {# ═══════════════════════════════════════════════════════════════════════════
     P1 — Executive Dashboard
     ═══════════════════════════════════════════════════════════════════════════ #}
  <section class="report-page report-page-hero">
    <div class="page-frame hero-frame">
      <div class="hero-topline">Daily Product Intelligence</div>

      {# Health gauge left + title/headline/meta right #}
      <div class="health-gauge-wrap">
        {% if charts.health_gauge is defined %}
        <div class="chart-container">
          {{ charts.health_gauge | safe }}
        </div>
        {% endif %}
        <div class="hero-main">
          <p class="section-kicker">主结论</p>
          <h1>产品评论深度分析报告</h1>
          <p class="hero-headline">{{ analytics.report_copy.hero_headline }}</p>
          <p class="hero-meta">Run #{{ snapshot.run_id }} ｜ {{ snapshot.logical_date }} ｜ {{ analytics.mode_display }}</p>
        </div>
      </div>

      {# KPI metric cards grid #}
      {% if analytics.kpi_cards %}
      <div class="kpi-grid">
        {% for card in analytics.kpi_cards %}
        <div class="metric-card">
          <span class="metric-label">{{ card.label }}</span>
          <strong class="metric-value {{ card.value_class or '' }}">{{ card.value }}</strong>
          {% if card.delta_display %}
          <span class="delta {{ card.delta_class or '' }}">{{ card.delta_display }}</span>
          {% endif %}
        </div>
        {% endfor %}
      </div>
      {% endif %}

      {# Alert signal #}
      {% if analytics.alert_level is defined and analytics.alert_level %}
      <div class="alert-signal alert-{{ analytics.alert_level }}">
        {{ analytics.alert_text }}
      </div>
      {% endif %}

      {# Hero support: key judgments + report calibration #}
      <div class="hero-support">
        <article class="hero-block">
          <p class="section-kicker">关键判断</p>
          <ul class="hero-bullets">
            {% for item in analytics.report_copy.executive_bullets[:3] %}
            <li>{{ item }}</li>
            {% endfor %}
          </ul>
        </article>
        <article class="hero-block hero-block-mode">
          <p class="section-kicker">报告口径</p>
          <p class="mode-copy">当前模式：{{ analytics.mode_display }}</p>
          <p class="mode-copy">差评阈值：{{ threshold }} 星及以下</p>
          <p class="mode-copy">自有产品 {{ analytics.kpis.own_product_count }} 个，竞品 {{ analytics.kpis.competitor_product_count }} 个。</p>
          <p class="mode-copy">自有评论 {{ analytics.kpis.own_review_rows }} 条，竞品评论 {{ analytics.kpis.competitor_review_rows }} 条。</p>
        </article>
      </div>
    </div>
  </section>

  {# ═══════════════════════════════════════════════════════════════════════════
     P2 — Product Health Matrix
     ═══════════════════════════════════════════════════════════════════════════ #}
  <section class="report-page report-section">
    <div class="page-frame">
      <div class="page-head">
        <p class="section-kicker">产品健康矩阵</p>
        <h2>自有产品健康度排名</h2>
        <p class="page-note">按风险分降序排列，帮助快速锁定需要优先排查的产品。</p>
      </div>

      {# Product health data table #}
      {% if analytics.self.risk_products %}
      <table class="data-table">
        <thead>
          <tr>
            <th>产品</th>
            <th>SKU</th>
            <th>评分</th>
            <th>差评率</th>
            <th>风险分</th>
            <th>主要问题</th>
            <th>趋势</th>
          </tr>
        </thead>
        <tbody>
          {% for item in analytics.self.risk_products %}
          <tr class="{% if item.risk_score is defined and item.risk_score >= 80 %}severity-high{% elif item.risk_score is defined and item.risk_score >= 50 %}severity-medium{% else %}severity-low{% endif %}">
            <td>{{ item.product_name }}</td>
            <td>{{ item.product_sku }}</td>
            <td>{% if item.rating_avg is defined and item.rating_avg is not none %}{{ "%.1f" | format(item.rating_avg) }}{% else %}—{% endif %}</td>
            <td>{% if item.negative_rate is defined and item.negative_rate is not none %}{{ "%.0f%%" | format(item.negative_rate * 100) }}{% else %}—{% endif %}</td>
            <td class="fw-bold {% if item.risk_score is defined and item.risk_score >= 80 %}severity-high{% elif item.risk_score is defined and item.risk_score >= 50 %}severity-medium{% else %}severity-low{% endif %}">{{ item.risk_score }}</td>
            <td>{{ item.top_features_display or '—' }}</td>
            <td>{{ item.trend_display or '—' }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% endif %}

      {# Charts: Price-Rating Quadrant + Rating Trend #}
      {% if charts.price_rating_quadrant is defined or charts.rating_trend is defined %}
      <div class="grid-2 mt-lg">
        {% if charts.price_rating_quadrant is defined %}
        <div class="chart-container">
          {{ charts.price_rating_quadrant | safe }}
        </div>
        {% endif %}
        {% if charts.rating_trend is defined %}
        <div class="chart-container">
          {{ charts.rating_trend | safe }}
        </div>
        {% endif %}
      </div>
      {% endif %}
    </div>
  </section>

  {# ═══════════════════════════════════════════════════════════════════════════
     P3 — Issue Deep Dive
     ═══════════════════════════════════════════════════════════════════════════ #}
  <section class="report-page report-section">
    <div class="page-frame">
      <div class="page-head">
        <p class="section-kicker">自有产品问题诊断</p>
        <h2>按影响规模排序</h2>
        <p class="page-note">每个问题簇附带证据引用和改良建议，便于研发快速定位根因。</p>
      </div>

      {% for item in analytics.self.issue_cards[:4] %}
      <article class="issue-card">
        {# Issue header: priority number + feature_display + severity badge #}
        <div class="issue-header">
          <h3><span class="text-accent fw-bold">#{{ loop.index }}</span>&nbsp;&nbsp;{{ item.feature_display }}</h3>
          {% if item.severity_display is defined %}
          <span class="badge severity-{{ item.severity or 'medium' }}">{{ item.severity_display }}</span>
          {% endif %}
        </div>

        {# Stats row #}
        <div class="issue-stats">
          <span>评论 {{ item.review_count }} 条</span>
          {% if item.affected_product_count is defined %}
          <span>涉及 {{ item.affected_product_count }} 个产品</span>
          {% endif %}
        </div>

        {# Timeline #}
        {% if item.first_seen %}
        <p class="issue-timeline">
          {{ item.first_seen }} → {{ item.last_seen }}
          {% if item.duration_display %}，持续 {{ item.duration_display }}{% endif %}
        </p>
        {% endif %}

        {# Example review quotes (up to 2) #}
        {% if item.example_reviews %}
        <div class="quote-stack mt-md">
          {% for ex in item.example_reviews[:2] %}
          <div class="quote-block">
            {% if ex.insight_cn %}
            <p class="quote-cn">"{{ ex.insight_cn }}"</p>
            {% elif ex.summary_text %}
            <p class="quote-cn">"{{ ex.summary_text }}"</p>
            {% endif %}
            {% if ex.headline_en or ex.body_en %}
            <p class="quote-en">"{{ ex.headline_en or '' }}{% if ex.headline_en and ex.body_en %}: {% endif %}{{ (ex.body_en or '')[:100] }}"</p>
            {% endif %}
            <p class="quote-meta">
              <span>评分 {{ ex.rating }}</span>
              <span>{{ ex.author or '匿名' }}</span>
              {% if ex.date_published %}
              <span>{{ ex.date_published }}</span>
              {% endif %}
            </p>
          </div>
          {% endfor %}
        </div>
        {% endif %}

        {# Image evidence strip (up to 3 thumbnails) #}
        {% if item.image_evidence %}
        <div class="evidence-strip">
          {% for img in item.image_evidence[:3] %}
          <div class="evidence-thumb">
            <img src="{{ img.data_uri or img.url }}" alt="{{ img.evidence_id }}">
            <span class="evidence-label">{{ img.evidence_id }}</span>
          </div>
          {% endfor %}
          {% if item.image_evidence | length > 3 %}
          <div class="evidence-more">+{{ item.image_evidence | length - 3 }}</div>
          {% endif %}
        </div>
        {% endif %}

        {# LLM recommendation #}
        {% if item.recommendation %}
        <div class="recommendation-box">
          {{ item.recommendation }}
        </div>
        {% endif %}
      </article>
      {% endfor %}
    </div>
  </section>

  {# ═══════════════════════════════════════════════════════════════════════════
     P4 — Competitive Intelligence
     ═══════════════════════════════════════════════════════════════════════════ #}
  <section class="report-page report-section">
    <div class="page-frame">
      <div class="page-head">
        <p class="section-kicker">竞品情报</p>
        <h2>竞品差距分析与机会</h2>
        <p class="page-note">竞品只看正向借鉴，不抢自有产品主篇幅。</p>
      </div>

      {# Gap analysis table #}
      {% if analytics.competitor.gap_analysis %}
      <table class="data-table">
        <thead>
          <tr>
            <th>维度</th>
            <th>竞品好评</th>
            <th>自有差评</th>
            <th>差距</th>
            <th>优先级</th>
          </tr>
        </thead>
        <tbody>
          {% for gap in analytics.competitor.gap_analysis %}
          <tr>
            <td>{{ gap.label_display }}</td>
            <td>{{ gap.competitor_positive_count }}</td>
            <td>{{ gap.own_negative_count }}</td>
            <td>{{ gap.gap }}</td>
            <td><span class="badge severity-{{ gap.priority or 'medium' }}">{{ gap.priority_display }}</span></td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% endif %}

      {# Competitive insight recommendation #}
      {% if analytics.report_copy.competitive_insight %}
      <div class="recommendation-box mt-md">
        {{ analytics.report_copy.competitive_insight }}
      </div>
      {% endif %}

      {# Charts: Competitive Radar + Competitor Positive Themes #}
      {% if charts.competitive_radar is defined or charts.competitor_positive_themes is defined %}
      <div class="grid-2 mt-lg">
        {% if charts.competitive_radar is defined %}
        <div class="chart-container">
          {{ charts.competitive_radar | safe }}
        </div>
        {% endif %}
        {% if charts.competitor_positive_themes is defined %}
        <div class="chart-container">
          {{ charts.competitor_positive_themes | safe }}
        </div>
        {% endif %}
      </div>
      {% endif %}

      {# Benchmark examples #}
      {% if analytics.competitor.benchmark_examples %}
      <div class="block-head mt-lg">
        <h3>高价值样本</h3>
        <p>少量高纯度好评样本，用于产品对标参考。</p>
      </div>
      <div class="quote-stack">
        {% for item in analytics.competitor.benchmark_examples[:2] %}
        <article class="quote-block">
          <p class="row-title">{{ item.product_name }}</p>
          <p class="row-meta">SKU: {{ item.product_sku }} ｜ {{ item.label_display_list }}</p>
          <p>{{ item.summary_text }}</p>
        </article>
        {% endfor %}
      </div>
      {% endif %}

      {# Benchmark takeaways #}
      {% if analytics.competitor.benchmark_takeaways %}
      <ul class="takeaway-list mt-md">
        {% for item in analytics.competitor.benchmark_takeaways[:3] %}
        <li>{{ item }}</li>
        {% endfor %}
      </ul>
      {% endif %}
    </div>
  </section>

  {# ═══════════════════════════════════════════════════════════════════════════
     P5 — Feature Sentiment Panorama (conditional)
     ═══════════════════════════════════════════════════════════════════════════ #}
  {% if charts.feature_heatmap is defined %}
  <section class="report-page report-section">
    <div class="page-frame">
      <div class="page-head">
        <p class="section-kicker">自有产品特征全景</p>
        <h2>产品×特征 情感矩阵</h2>
        <p class="page-note">行为产品，列为特征维度，色值表示情感倾向（绿=正面，红=负面）。</p>
      </div>

      {# Feature heatmap — full width #}
      <div class="chart-container">
        {{ charts.feature_heatmap | safe }}
      </div>

      {# Sentiment distribution (own + competitor) side-by-side #}
      {% if charts.sentiment_distribution_own is defined or charts.sentiment_distribution_competitor is defined %}
      <div class="grid-2 mt-lg">
        {% if charts.sentiment_distribution_own is defined %}
        <div class="chart-container">
          {{ charts.sentiment_distribution_own | safe }}
        </div>
        {% endif %}
        {% if charts.sentiment_distribution_competitor is defined %}
        <div class="chart-container">
          {{ charts.sentiment_distribution_competitor | safe }}
        </div>
        {% endif %}
      </div>
      {% endif %}

      {# Rating trend #}
      {% if charts.rating_trend is defined %}
      <div class="chart-container mt-lg">
        {{ charts.rating_trend | safe }}
      </div>
      {% endif %}
    </div>
  </section>
  {% endif %}

</body>
</html>
