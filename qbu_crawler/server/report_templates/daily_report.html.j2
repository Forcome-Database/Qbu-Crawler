<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <title>每日深度分析报告 {{ snapshot.logical_date }}</title>
  <style>
{{ css_text | safe }}
  </style>
  <style>
    :root {
      --report-font-family: "{{ report_font_family }}", sans-serif;
    }
  </style>
</head>
<body class="report-shell">
  <section class="report-page report-page-hero">
    <div class="page-frame hero-frame">
      <div class="hero-topline">Daily Product Intelligence</div>
      <div class="hero-grid">
        <div class="hero-main">
          <p class="section-kicker">主结论</p>
          <h1>每日深度分析报告</h1>
          <p class="hero-headline">{{ analytics.report_copy.hero_headline }}</p>
          <p class="hero-meta">Run #{{ snapshot.run_id }} ｜ {{ snapshot.logical_date }} ｜ {{ analytics.mode_display }}</p>
        </div>
        <div class="hero-metrics">
          <div class="metric-card">
            <span>产品数</span>
            <strong>{{ analytics.kpis.product_count }}</strong>
            {% if analytics.kpis.product_count_delta is defined and analytics.kpis.product_count_delta != 0 %}
            <span class="delta {{ 'delta-up' if analytics.kpis.product_count_delta > 0 else 'delta-down' }}">
              {{ analytics.kpis.product_count_delta_display }} vs 上期
            </span>
            {% endif %}
          </div>
          <div class="metric-card">
            <span>新增评论</span>
            <strong>{{ analytics.kpis.ingested_review_rows }}</strong>
            {% if analytics.kpis.ingested_review_rows_delta is defined and analytics.kpis.ingested_review_rows_delta != 0 %}
            <span class="delta {{ 'delta-up' if analytics.kpis.ingested_review_rows_delta > 0 else 'delta-down' }}">
              {{ analytics.kpis.ingested_review_rows_delta_display }} vs 上期
            </span>
            {% endif %}
          </div>
          <div class="metric-card">
            <span>差评数</span>
            <strong>{{ analytics.kpis.negative_review_rows }}</strong>
            {% if analytics.kpis.negative_review_rows_delta is defined and analytics.kpis.negative_review_rows_delta != 0 %}
            <span class="delta {{ 'delta-up' if analytics.kpis.negative_review_rows_delta > 0 else 'delta-down' }}">
              {{ analytics.kpis.negative_review_rows_delta_display }} vs 上期
            </span>
            {% endif %}
          </div>
          <div class="metric-card">
            <span>差评率</span>
            <strong>{{ analytics.kpis.negative_review_rate_display }}</strong>
          </div>
        </div>
      </div>
      <div class="hero-support">
        <article class="hero-block">
          <p class="section-kicker">关键判断</p>
          <ul class="hero-bullets">
            {% for item in analytics.report_copy.executive_bullets[:3] %}
            <li>{{ item }}</li>
            {% endfor %}
          </ul>
        </article>
        <article class="hero-block hero-block-mode">
          <p class="section-kicker">报告口径</p>
          <p class="mode-copy">当前模式：{{ analytics.mode_display }}</p>
          <p class="mode-copy">自有产品 {{ analytics.kpis.own_product_count }} 个，竞品 {{ analytics.kpis.competitor_product_count }} 个。</p>
          <p class="mode-copy">自有评论 {{ analytics.kpis.own_review_rows }} 条，竞品评论 {{ analytics.kpis.competitor_review_rows }} 条。</p>
        </article>
      </div>
      {% if analytics.alert_level is defined %}
      <div class="alert-signal alert-{{ analytics.alert_level }}">
        {{ analytics.alert_text }}
      </div>
      {% endif %}
    </div>
  </section>

  <section class="report-page report-section">
    <div class="page-frame">
      <div class="page-head">
        <p class="section-kicker">自有产品</p>
        <h2>自有产品风险总览</h2>
        <p class="page-note">先看优先排查对象，再看问题簇分布，避免日报被总量信息稀释。</p>
      </div>
      <div class="two-up">
        <article class="analysis-block">
          <div class="block-head">
            <h3>高风险产品排序</h3>
            <p>用于确定排查顺序，不等同于最终质量定性。</p>
          </div>
          <div class="chart-wrap">{{ chart_svgs.self_risk_products }}</div>
          <div class="stack-list">
            {% for item in analytics.self.risk_products[:4] %}
            <div class="stack-row">
              <div>
                <p class="row-title">{{ item.product_name }}</p>
                <p class="row-meta">SKU: {{ item.product_sku }}</p>
              </div>
              <div class="row-stats">
                <span>风险分 {{ item.risk_score }}</span>
                <span>差评 {{ item.negative_review_rows }}</span>
                <span>{{ item.evidence_refs_display }}</span>
              </div>
            </div>
            {% endfor %}
          </div>
        </article>
        <article class="analysis-block">
          <div class="block-head">
            <h3>问题簇排序</h3>
            <p>只展示自有产品负向问题簇，便于研发抓主线。</p>
          </div>
          <div class="chart-wrap">{{ chart_svgs.self_negative_clusters }}</div>
          <div class="stack-list">
            {% for item in analytics.self.top_negative_clusters[:4] %}
            <div class="stack-row">
              <div class="row-inline">
                <p class="row-title">{{ item.label_display }}</p>
                <span class="tag">{{ item.severity_display }}</span>
              </div>
              <div class="row-stats">
                <span>证据 {{ item.review_count }}</span>
                <span>{{ item.evidence_refs_display }}</span>
              </div>
            </div>
            {% endfor %}
          </div>
        </article>
      </div>
      {% if chart_svgs.self_risk_matrix is defined %}
      <div class="chart-wrap">{{ chart_svgs.self_risk_matrix }}</div>
      {% endif %}
    </div>
  </section>

  <section class="report-page report-section">
    <div class="page-frame">
      <div class="page-head">
        <p class="section-kicker">重点产品</p>
        <h2>重点产品深挖</h2>
        <p class="page-note">只展开当前最值得研发先看的 1 到 2 个产品，并直接引用证据编号。</p>
      </div>
      <div class="focus-grid">
        {% for item in analytics.self.risk_products[:2] %}
        <article class="focus-card">
          <div class="focus-head">
            <div>
              <p class="section-kicker">重点产品 {{ loop.index }}</p>
              <h3>{{ item.product_name }}</h3>
              <p class="row-meta">SKU: {{ item.product_sku }}</p>
            </div>
            <div class="focus-stats">
              <span>风险分 {{ item.risk_score }}</span>
              <span>差评 {{ item.negative_review_rows }}</span>
              <span>图片 {{ item.image_review_rows }}</span>
            </div>
          </div>
          <div class="focus-body">
            <div class="focus-panel">
              <p class="panel-label">主要问题</p>
              <p>{{ item.top_labels_display }}</p>
            </div>
            <div class="focus-panel">
              <p class="panel-label">证据编号</p>
              <p>{{ item.evidence_refs_display }}</p>
            </div>
            <div class="focus-panel focus-quote">
              <p class="panel-label">代表性评论</p>
              <p>{{ item.focus_summary or "当前缺少可直接展示的代表性评论。" }}</p>
            </div>
          </div>
        </article>
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="report-page report-section">
    <div class="page-frame">
      <div class="page-head">
        <p class="section-kicker">问题簇</p>
        <h2>问题簇与改良建议</h2>
        <p class="page-note">每个建议都必须能回到证据量和图片编号，避免沦为空泛套话。</p>
      </div>
      <div class="issue-grid">
        {% for item in analytics.self.top_negative_clusters[:4] %}
        <article class="issue-card">
          <div class="issue-top">
            <div>
              <h3>{{ item.label_display }}</h3>
              <p class="row-meta">证据量 {{ item.evidence_count }} ｜ {{ item.evidence_refs_display }}</p>
            </div>
            <span class="priority-tag">{{ item.priority_display }}</span>
          </div>
          <div class="issue-facts">
            <p>差评 {{ item.evidence_count }} 条
              {% if item.affected_product_count is defined %} | 涉及 {{ item.affected_product_count }} 个产品{% endif %}
              {% if item.image_review_count is defined %} | 图片证据 {{ item.image_review_count }} 条{% endif %}
            </p>
            {% if item.first_seen %}
            <p class="issue-timeline">首次出现：{{ item.first_seen }} ｜ 最近一条：{{ item.last_seen }}</p>
            {% endif %}
          </div>
          {% if item.example_reviews %}
          <div class="issue-quotes">
            {% set ex = item.example_reviews[0] %}
            <blockquote>
              <p class="quote-cn">"{{ ex.summary_text }}"</p>
              {% if ex.headline_en or ex.body_en %}
              <p class="quote-en">"{{ ex.headline_en }}{% if ex.body_en %}: {{ ex.body_en[:80] }}{% endif %}"</p>
              {% endif %}
              <cite>— 评分 {{ ex.rating }} · {{ ex.author or '匿名' }}{% if ex.date_published %} · {{ ex.date_published }}{% endif %}</cite>
            </blockquote>
          </div>
          {% endif %}
          {% if item.image_evidence %}
          <div class="issue-evidence-strip">
            {% for img in item.image_evidence[:3] %}
            <div class="evidence-thumb">
              <img src="{{ img.primary_image_data_uri or img.primary_image }}" alt="{{ img.evidence_id }}">
              <span class="evidence-label">{{ img.evidence_id }}</span>
            </div>
            {% endfor %}
            {% if item.image_evidence | length > 3 %}
            <div class="evidence-more">+{{ item.image_evidence | length - 3 }}</div>
            {% endif %}
          </div>
          {% endif %}
          <p class="issue-xref">详见 Excel →「评论」页 → 筛选 SKU 列</p>
        </article>
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="report-page report-section">
    <div class="page-frame">
      <div class="page-head">
        <p class="section-kicker">竞品借鉴</p>
        <h2>竞品好评 Benchmark</h2>
        <p class="page-note">竞品只看正向借鉴，不抢自有产品主篇幅。</p>
      </div>
      {% if analytics.competitor.gap_analysis %}
      <div class="gap-callout">
        <p class="section-kicker">竞品优势 vs 自有短板</p>
        {% for gap in analytics.competitor.gap_analysis %}
        <p>{{ gap.label_display }}：竞品好评 {{ gap.competitor_positive_count }} 条，自有差评 {{ gap.own_negative_count }} 条</p>
        {% endfor %}
      </div>
      {% endif %}
      <div class="two-up benchmark-layout">
        <article class="analysis-block">
          <div class="block-head">
            <h3>正向主题 Top 5</h3>
            <p>用于识别用户明确认可的稳定体验点。</p>
          </div>
          <div class="chart-wrap">{{ chart_svgs.competitor_positive_themes }}</div>
          <ul class="takeaway-list">
            {% for item in analytics.competitor.benchmark_takeaways[:3] %}
            <li>{{ item }}</li>
            {% endfor %}
          </ul>
        </article>
        <article class="analysis-block">
          <div class="block-head">
            <h3>高价值样本</h3>
            <p>只保留少量高纯度好评样本，避免 benchmark 被样本噪音带偏。</p>
          </div>
          <div class="quote-stack">
            {% for item in analytics.competitor.benchmark_examples[:2] %}
            <article class="quote-block">
              <p class="row-title">{{ item.product_name }}</p>
              <p class="row-meta">SKU: {{ item.product_sku }} ｜ {{ item.label_display_list }}</p>
              <p>{{ item.summary_text }}</p>
            </article>
            {% endfor %}
          </div>
        </article>
      </div>
    </div>
  </section>

</body>
</html>
