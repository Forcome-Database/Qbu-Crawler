<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <!--[if mso]><style>table{border-collapse:collapse;}td{font-family:Arial,sans-serif;}</style><![endif]-->
</head>
<body style="margin:0;padding:0;background:#f5f0e8;font-family:'Microsoft YaHei',Arial,sans-serif;">

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#f5f0e8;">
<tr><td align="center" style="padding:20px 10px;">

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="max-width:600px;background:#fffaf3;border-radius:12px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.08);">

  <!-- ===== 1. HEADER BAR ===== -->
  <tr>
    <td style="background:#93543f;padding:16px 24px;">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
        <tr>
          <td style="color:#ffffff;font-size:13px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;">Daily Product Intelligence</td>
          <td style="color:rgba(255,255,255,0.7);font-size:12px;text-align:right;white-space:nowrap;">{{ snapshot.logical_date }}</td>
        </tr>
      </table>
    </td>
  </tr>

  <!-- ===== 2. HEALTH INDEX HERO ===== -->
  {% if analytics.alert_level == 'red' %}
  {% set hero_bg = '#f2d9d0' %}
  {% set hero_color = '#93543f' %}
  {% elif analytics.alert_level == 'yellow' %}
  {% set hero_bg = '#f5ecd4' %}
  {% set hero_color = '#b0823a' %}
  {% else %}
  {% set hero_bg = '#dce9e3' %}
  {% set hero_color = '#345f57' %}
  {% endif %}
  <tr>
    <td style="background:{{ hero_bg }};padding:28px 24px 20px;text-align:center;">
      <div style="font-size:10px;color:{{ hero_color }};letter-spacing:0.15em;text-transform:uppercase;opacity:0.8;margin-bottom:8px;">产品健康指数 <span title="{{ analytics.tooltips['健康指数'] }}" style="display:inline-block;width:12px;height:12px;line-height:12px;border-radius:50%;background:rgba(255,255,255,0.3);font-size:8px;font-weight:700;text-align:center;cursor:help;vertical-align:middle;">ⓘ</span></div>
      <div style="font-size:56px;font-weight:900;color:{{ hero_color }};line-height:1;margin-bottom:6px;">{{ analytics.kpis.health_index | default('—') }}</div>
      <div style="font-size:13px;color:{{ hero_color }};opacity:0.7;">/ 100 &nbsp;·&nbsp; {{ analytics.mode_display | default('深度日报') }}</div>
    </td>
  </tr>

  <!-- ===== 3. ALERT SIGNAL ===== -->
  {% if analytics.alert_level and analytics.alert_text %}
  {% if analytics.alert_level == 'red' %}
  {% set alert_bg = '#93543f' %}
  {% set alert_color = '#ffffff' %}
  {% set alert_icon = '⚠' %}
  {% elif analytics.alert_level == 'yellow' %}
  {% set alert_bg = '#b0823a' %}
  {% set alert_color = '#ffffff' %}
  {% set alert_icon = '●' %}
  {% else %}
  {% set alert_bg = '#345f57' %}
  {% set alert_color = '#ffffff' %}
  {% set alert_icon = '✓' %}
  {% endif %}
  <tr>
    <td style="background:{{ alert_bg }};padding:10px 24px;text-align:center;">
      <span style="color:{{ alert_color }};font-size:13px;font-weight:600;">{{ alert_icon }}&nbsp;&nbsp;{{ analytics.alert_text }}</span>
    </td>
  </tr>
  {% endif %}

  <!-- ===== 4. KPI CARDS ===== -->
  <tr>
    <td style="padding:20px 24px 8px;">
      <div style="font-size:10px;color:#766d62;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:12px;">关键指标</div>

      <!-- Row 1: 3 cards -->
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
        <tr>
          <!-- Card: 自有评论 -->
          <td width="32%" style="padding:12px;background:#ffffff;border:1px solid #e8dfd4;border-radius:8px;text-align:center;vertical-align:top;">
            <div style="font-size:10px;color:#766d62;margin-bottom:6px;">自有评论 <span title="{{ analytics.tooltips['自有评论'] }}" style="display:inline-block;width:12px;height:12px;line-height:12px;border-radius:50%;background:#f1e6d7;color:#93543f;font-size:8px;font-weight:700;text-align:center;cursor:help;vertical-align:middle;">ⓘ</span></div>
            <div style="font-size:26px;font-weight:800;color:#201b16;line-height:1;">{{ analytics.kpis.own_review_rows | default(0) }}</div>
            {% if analytics.kpis.ingested_review_rows_delta_display is defined and analytics.kpis.ingested_review_rows_delta_display %}
            <div style="font-size:11px;color:#766d62;margin-top:4px;">{{ analytics.kpis.ingested_review_rows_delta_display }}</div>
            {% endif %}
          </td>
          <td width="2%"></td>
          <!-- Card: 自有差评 -->
          <td width="32%" style="padding:12px;background:#ffffff;border:1px solid #e8dfd4;border-radius:8px;text-align:center;vertical-align:top;">
            <div style="font-size:10px;color:#766d62;margin-bottom:6px;">自有差评 <span title="{{ analytics.tooltips['差评率'] }}" style="display:inline-block;width:12px;height:12px;line-height:12px;border-radius:50%;background:#f1e6d7;color:#93543f;font-size:8px;font-weight:700;text-align:center;cursor:help;vertical-align:middle;">ⓘ</span></div>
            <div style="font-size:26px;font-weight:800;color:#93543f;line-height:1;">{{ analytics.kpis.own_negative_review_rows | default(analytics.kpis.negative_review_rows | default(0)) }}</div>
            {% if analytics.kpis.negative_review_rows_delta_display is defined and analytics.kpis.negative_review_rows_delta_display %}
            <div style="font-size:11px;color:#766d62;margin-top:4px;">{{ analytics.kpis.negative_review_rows_delta_display }}</div>
            {% endif %}
          </td>
          <td width="2%"></td>
          <!-- Card: 自有差评率 -->
          <td width="32%" style="padding:12px;background:#ffffff;border:1px solid #e8dfd4;border-radius:8px;text-align:center;vertical-align:top;">
            <div style="font-size:10px;color:#766d62;margin-bottom:6px;">自有差评率 <span title="{{ analytics.tooltips['差评率'] }}" style="display:inline-block;width:12px;height:12px;line-height:12px;border-radius:50%;background:#f1e6d7;color:#93543f;font-size:8px;font-weight:700;text-align:center;cursor:help;vertical-align:middle;">ⓘ</span></div>
            <div style="font-size:26px;font-weight:800;color:#201b16;line-height:1;">{{ analytics.kpis.own_negative_review_rate_display | default('—') }}</div>
          </td>
        </tr>
      </table>

      <!-- Spacer -->
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0"><tr><td style="height:8px;"></td></tr></table>

      <!-- Row 2: 2 cards -->
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
        <tr>
          <!-- Card: 高风险产品 -->
          <td width="49%" style="padding:12px;background:#ffffff;border:1px solid #e8dfd4;border-radius:8px;text-align:center;vertical-align:top;">
            <div style="font-size:10px;color:#766d62;margin-bottom:6px;">高风险产品 <span title="{{ analytics.tooltips['高风险产品'] }}" style="display:inline-block;width:12px;height:12px;line-height:12px;border-radius:50%;background:#f1e6d7;color:#93543f;font-size:8px;font-weight:700;text-align:center;cursor:help;vertical-align:middle;">ⓘ</span></div>
            <div style="font-size:26px;font-weight:800;color:#93543f;line-height:1;">{{ analytics.kpis.high_risk_count | default(0) }}</div>
            <div style="font-size:10px;color:#766d62;margin-top:4px;">自有 {{ analytics.kpis.own_product_count | default(0) }} / 竞品 {{ analytics.kpis.competitor_product_count | default(0) }}</div>
          </td>
          <td width="2%"></td>
          <!-- Card: 竞品差距 -->
          <td width="49%" style="padding:12px;background:#ffffff;border:1px solid #e8dfd4;border-radius:8px;text-align:center;vertical-align:top;">
            <div style="font-size:10px;color:#766d62;margin-bottom:6px;">竞品差距分 <span title="{{ analytics.tooltips['竞品差距分'] }}" style="display:inline-block;width:12px;height:12px;line-height:12px;border-radius:50%;background:#f1e6d7;color:#93543f;font-size:8px;font-weight:700;text-align:center;cursor:help;vertical-align:middle;">ⓘ</span></div>
            <div style="font-size:26px;font-weight:800;color:#345f57;line-height:1;">{% if analytics.kpis.competitive_gap_index is not none %}{{ analytics.kpis.competitive_gap_index }}{% else %}—{% endif %}</div>
            {% if analytics.kpis.competitive_gap_index_delta_display is defined and analytics.kpis.competitive_gap_index_delta_display %}
            <div style="font-size:11px;color:#766d62;margin-top:4px;">{{ analytics.kpis.competitive_gap_index_delta_display }}</div>
            {% endif %}
          </td>
        </tr>
      </table>

    </td>
  </tr>

  <!-- ===== 5. ACTION ITEMS ===== -->
  <tr>
    <td style="padding:20px 24px 8px;">
      <div style="font-size:10px;color:#766d62;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:14px;">需要关注</div>
      {% for item in analytics.report_copy.executive_bullets[:3] %}
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:10px;">
        <tr>
          <td width="28" valign="top" style="padding-top:1px;">
            <div style="width:22px;height:22px;background:#93543f;border-radius:50%;text-align:center;line-height:22px;font-size:12px;font-weight:700;color:#ffffff;">{{ loop.index }}</div>
          </td>
          <td style="padding-left:10px;font-size:13px;color:#201b16;line-height:1.65;">{{ item }}</td>
        </tr>
      </table>
      {% else %}
      <p style="font-size:13px;color:#766d62;margin:0;">当前暂无足够样本形成明确判断。</p>
      {% endfor %}
    </td>
  </tr>

  <!-- ===== RISK PRODUCTS TABLE (optional) ===== -->
  {% if analytics.self.risk_products %}
  <tr>
    <td style="padding:8px 24px 16px;">
      <div style="font-size:10px;color:#766d62;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:10px;">风险产品 TOP 3</div>
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border-collapse:collapse;font-size:12px;">
        <tr>
          <td style="padding:8px 10px;font-weight:700;background:#93543f;color:#ffffff;border-radius:4px 0 0 0;">产品名称</td>
          <td style="padding:8px 10px;font-weight:700;background:#93543f;color:#ffffff;text-align:center;">主要问题</td>
          <td style="padding:8px 10px;font-weight:700;background:#93543f;color:#ffffff;text-align:center;border-radius:0 4px 0 0;white-space:nowrap;" title="{{ analytics.tooltips['差评率'] }}">差评数 <span style="font-size:8px;opacity:0.7;">ⓘ</span></td>
        </tr>
        {% for item in analytics.self.risk_products[:3] %}
        <tr style="background:{% if loop.index is odd %}#faf5ef{% else %}#ffffff{% endif %};">
          <td style="padding:8px 10px;border-bottom:1px solid #e8dfd4;color:#201b16;">{{ item.product_name }}</td>
          <td style="padding:8px 10px;border-bottom:1px solid #e8dfd4;text-align:center;color:#766d62;">{{ item.top_labels_display or '—' }}</td>
          <td style="padding:8px 10px;border-bottom:1px solid #e8dfd4;text-align:center;font-weight:700;color:#93543f;">{{ item.negative_review_rows }}</td>
        </tr>
        {% endfor %}
      </table>
    </td>
  </tr>
  {% endif %}

  <!-- ===== 6. ATTACHMENT GUIDE ===== -->
  <tr>
    <td style="padding:16px 24px;background:#f0ebe2;border-top:1px solid #e8dfd4;">
      <div style="font-size:10px;color:#766d62;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:10px;">附件说明</div>
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
        <tr>
          <td width="50%" style="padding-right:8px;">
            <div style="padding:10px 14px;background:#ffffff;border:1px solid #e8dfd4;border-radius:6px;font-size:12px;color:#201b16;">
              &#128196;&nbsp; <strong>HTML 交互式报告</strong><br>
              <span style="font-size:11px;color:#766d62;">图表 · 问题详情 · 评论摘录</span>
            </div>
          </td>
          <td width="50%" style="padding-left:8px;">
            <div style="padding:10px 14px;background:#ffffff;border:1px solid #e8dfd4;border-radius:6px;font-size:12px;color:#201b16;">
              &#128202;&nbsp; <strong>Excel 数据明细</strong><br>
              <span style="font-size:11px;color:#766d62;">可筛选原始数据</span>
            </div>
          </td>
        </tr>
      </table>
    </td>
  </tr>

  <!-- ===== 7. FOOTER ===== -->
  <tr>
    <td style="padding:12px 24px;text-align:center;border-top:1px solid #e8dfd4;">
      <p style="margin:0;font-size:10px;color:#a89e94;line-height:1.6;">
        QBU 网评监控智能分析系统 &nbsp;·&nbsp; 差评定义：≤{{ threshold }}星 &nbsp;·&nbsp; 内部资料<br>
        本报告由 AI 自动生成，数据及分析结论仅供参考 · 请勿直接回复此邮件
      </p>
    </td>
  </tr>

</table>

</td></tr>
</table>

</body>
</html>
