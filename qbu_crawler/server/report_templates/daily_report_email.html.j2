<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <!--[if mso]>
  <style>table { border-collapse: collapse; } td { font-family: Arial, sans-serif; }</style>
  <![endif]-->
</head>
<body style="margin:0;padding:20px;background-color:#f5f0e8;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Arial,sans-serif;">
<table role="presentation" style="width:100%;max-width:600px;margin:0 auto;background:#ffffff;border:1px solid #d9ccb9;border-radius:8px;">
  <!-- Header -->
  <tr>
    <td style="padding:20px 24px;background:#93543f;color:#ffffff;border-radius:8px 8px 0 0;">
      <p style="margin:0;font-size:10px;letter-spacing:1.5px;text-transform:uppercase;opacity:0.8;">Daily Product Intelligence</p>
      <h1 style="margin:8px 0 0;font-size:18px;font-weight:700;">产品评论日报 {{ snapshot.logical_date }}</h1>
    </td>
  </tr>
  <!-- KPI -->
  <tr>
    <td style="padding:16px 24px;">
      <table role="presentation" style="width:100%;table-layout:fixed;">
        <tr>
          <td style="padding:10px;text-align:center;border:1px solid #d9ccb9;border-radius:8px;">
            <div style="font-size:10px;color:#766d62;">产品数</div>
            <div style="font-size:24px;font-weight:700;color:#93543f;margin-top:4px;">{{ analytics.kpis.product_count }}</div>
          </td>
          <td style="width:8px;"></td>
          <td style="padding:10px;text-align:center;border:1px solid #d9ccb9;border-radius:8px;">
            <div style="font-size:10px;color:#766d62;">新增评论</div>
            <div style="font-size:24px;font-weight:700;color:#93543f;margin-top:4px;">{{ analytics.kpis.ingested_review_rows }}</div>
          </td>
        </tr>
        <tr><td colspan="3" style="height:8px;"></td></tr>
        <tr>
          <td style="padding:10px;text-align:center;border:1px solid #d9ccb9;border-radius:8px;">
            <div style="font-size:10px;color:#766d62;">差评数</div>
            <div style="font-size:24px;font-weight:700;color:#93543f;margin-top:4px;">{{ analytics.kpis.negative_review_rows }}</div>
          </td>
          <td style="width:8px;"></td>
          <td style="padding:10px;text-align:center;border:1px solid #d9ccb9;border-radius:8px;">
            <div style="font-size:10px;color:#766d62;">差评率</div>
            <div style="font-size:24px;font-weight:700;color:#93543f;margin-top:4px;">{{ analytics.kpis.negative_review_rate_display }}</div>
          </td>
        </tr>
      </table>
    </td>
  </tr>
  <!-- Bullets -->
  <tr>
    <td style="padding:0 24px 16px;">
      <p style="margin:0 0 8px;font-size:10px;color:#766d62;letter-spacing:1px;text-transform:uppercase;">今日要点</p>
      <ol style="margin:0;padding-left:18px;font-size:13px;line-height:1.8;color:#201b16;">
        {% for item in analytics.report_copy.executive_bullets_human[:3] %}
        <li style="margin-bottom:6px;">{{ item }}</li>
        {% else %}
        <li>当前暂无足够样本形成明确判断。</li>
        {% endfor %}
      </ol>
    </td>
  </tr>
  <!-- TOP3 Risk Products -->
  {% if analytics.self.risk_products %}
  <tr>
    <td style="padding:0 24px 16px;">
      <p style="margin:0 0 8px;font-size:10px;color:#766d62;letter-spacing:1px;text-transform:uppercase;">风险产品 TOP 3</p>
      <table role="presentation" style="width:100%;border-collapse:collapse;font-size:12px;">
        <tr>
          <td style="padding:8px;font-weight:700;background:#93543f;color:#fff;border-radius:4px 0 0 0;">产品名称</td>
          <td style="padding:8px;font-weight:700;background:#93543f;color:#fff;text-align:center;">主要问题</td>
          <td style="padding:8px;font-weight:700;background:#93543f;color:#fff;text-align:center;border-radius:0 4px 0 0;">差评数</td>
        </tr>
        {% for item in analytics.self.risk_products[:3] %}
        <tr>
          <td style="padding:8px;border-bottom:1px solid #d9ccb9;">{{ item.product_name }}</td>
          <td style="padding:8px;border-bottom:1px solid #d9ccb9;text-align:center;">{{ item.top_labels_display or '' }}</td>
          <td style="padding:8px;border-bottom:1px solid #d9ccb9;text-align:center;">{{ item.negative_review_rows }}</td>
        </tr>
        {% endfor %}
      </table>
    </td>
  </tr>
  {% endif %}
  <!-- Footer -->
  <tr>
    <td style="padding:16px 24px;font-size:11px;color:#766d62;text-align:center;border-top:1px solid #d9ccb9;">
      详见附件 PDF（分析版）和 Excel（明细版）。此邮件由自动化系统生成，请勿直接回复。
    </td>
  </tr>
</table>
</body>
</html>
