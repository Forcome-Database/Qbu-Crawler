<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="margin:0;padding:0;background:#f8fafc;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Arial,sans-serif;">
{% set _analytics = analytics or {} %}
{% set _kpis = _analytics.get("kpis", {}) %}
{% set _digest = _analytics.get("change_digest", {}) %}
{% set _summary = _digest.get("summary", {}) %}
{% set _issues = _digest.get("issue_changes", {}) %}
{% set _products = _digest.get("product_changes", {}) %}
{% set _signals = _digest.get("review_signals", {}) %}
{% set _warnings = _digest.get("warnings", {}) %}
{% set _empty = _digest.get("empty_state", {}) %}
{% set _view_state = _digest.get("view_state", "") %}
{% set _semantics = _analytics.get("report_semantics", "incremental") %}
{% set _report_copy = report_copy if report_copy is defined and report_copy else _analytics.get("report_copy", {}) %}
{% set _bullets = _report_copy.get("executive_bullets", []) %}
{% set _risk = risk_products if risk_products is defined and risk_products else (_analytics.get("self", {}) or {}).get("risk_products", []) %}
{% set _fresh_competitor_positive_reviews = _signals.get("fresh_competitor_positive_reviews", []) %}
{% set _stock_display = {"in_stock": "有货", "out_of_stock": "缺货", "unknown": "未知"} %}
{% set _alert = alert_level or "green" %}
{% if _alert == "red" %}
  {% set _accent = "#b91c1c" %}
  {% set _hero_bg = "#fef2f2" %}
{% elif _alert == "yellow" %}
  {% set _accent = "#a16207" %}
  {% set _hero_bg = "#fefce8" %}
{% else %}
  {% set _accent = "#047857" %}
  {% set _hero_bg = "#ecfdf5" %}
{% endif %}

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#f8fafc;">
  <tr>
    <td align="center" style="padding:20px 12px;">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="max-width:640px;background:#ffffff;border-radius:14px;overflow:hidden;border:1px solid #e2e8f0;">
        <tr>
          <td style="background:#1d4ed8;padding:18px 24px;color:#ffffff;">
            <div style="font-size:12px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;">QBU 网评监控</div>
            <div style="font-size:11px;opacity:0.8;margin-top:4px;">{{ logical_date }}</div>
          </td>
        </tr>

        <tr>
          <td style="background:{{ _hero_bg }};padding:24px;">
            <div style="font-size:12px;color:{{ _accent }};font-weight:700;letter-spacing:0.08em;text-transform:uppercase;">整体概览</div>
            <div style="font-size:44px;line-height:1;font-weight:800;color:{{ _accent }};margin-top:8px;">{{ _kpis.get("health_index", "-") }}</div>
            <div style="font-size:12px;color:#475569;margin-top:8px;">健康指数 / 100</div>
          </td>
        </tr>

        {% if alert_text %}
        <tr>
          <td style="padding:12px 24px;background:#111827;color:#ffffff;font-size:12px;">{{ alert_text }}</td>
        </tr>
        {% endif %}

        <tr>
          <td style="padding:18px 24px 8px;">
            <div style="font-size:12px;font-weight:700;color:#1e293b;letter-spacing:0.08em;text-transform:uppercase;">核心指标</div>
          </td>
        </tr>
        <tr>
          <td style="padding:0 24px 12px;">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
              <tr>
                <td width="32%" style="padding:12px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;text-align:center;">
                  <div style="font-size:11px;color:#64748b;">自有评论</div>
                  <div style="font-size:24px;font-weight:700;color:#0f172a;margin-top:6px;">{{ _kpis.get("own_review_rows", 0) }}</div>
                </td>
                <td width="2%"></td>
                <td width="32%" style="padding:12px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;text-align:center;">
                  <div style="font-size:11px;color:#64748b;">高风险产品</div>
                  <div style="font-size:24px;font-weight:700;color:#0f172a;margin-top:6px;">{{ _kpis.get("high_risk_count", 0) }}</div>
                </td>
                <td width="2%"></td>
                <td width="32%" style="padding:12px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;text-align:center;">
                  <div style="font-size:11px;color:#64748b;">覆盖产品</div>
                  <div style="font-size:24px;font-weight:700;color:#0f172a;margin-top:6px;">{{ _kpis.get("own_product_count", 0) }} / {{ _kpis.get("competitor_product_count", 0) }}</div>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <tr>
          <td style="padding:18px 24px 8px;">
            <div style="font-size:12px;font-weight:700;color:#1e293b;letter-spacing:0.08em;text-transform:uppercase;">今日变化</div>
          </td>
        </tr>
        <tr>
          <td style="padding:0 24px 18px;">
            {% if _semantics == "bootstrap" or _view_state == "bootstrap" %}
            <div style="padding:14px 16px;background:#eff6ff;border:1px solid #bfdbfe;border-radius:10px;color:#1e3a8a;font-size:13px;">
              <div style="font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;">Monitoring Start</div>
              <div style="font-weight:700;margin-top:4px;">监控起点</div>
              <div style="margin-top:6px;">首次建档，当前结果用于建立监控基线。</div>
            </div>
            {% elif _empty.get("enabled") %}
            <div style="padding:14px 16px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;color:#475569;font-size:13px;">
              <div style="font-weight:700;">{{ _empty.get("title", "本期无显著变化") }}</div>
              {% if _empty.get("description") %}
              <div style="margin-top:6px;">{{ _empty.get("description") }}</div>
              {% endif %}
            </div>
            {% endif %}

            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-top:10px;">
              <tr>
                <td width="48%" style="padding:10px 12px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;">
                  <div style="font-size:11px;color:#64748b;">本次入库评论</div>
                  <div style="font-size:22px;font-weight:700;color:#0f172a;margin-top:6px;">{{ _summary.get("ingested_review_count", 0) }}</div>
                  <div style="font-size:11px;color:#64748b;margin-top:6px;">新近 {{ _summary.get("fresh_review_count", 0) }} / 补采 {{ _summary.get("historical_backfill_count", 0) }}</div>
                </td>
                <td width="4%"></td>
                <td width="48%" style="padding:10px 12px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;">
                  <div style="font-size:11px;color:#64748b;">重点风险</div>
                  <div style="font-size:13px;color:#0f172a;line-height:1.8;margin-top:6px;">
                    自有新近差评 {{ _summary.get("fresh_own_negative_count", 0) }}<br>
                    新增问题 {{ _summary.get("issue_new_count", 0) }} / 升级问题 {{ _summary.get("issue_escalated_count", 0) }}<br>
                    产品状态变更 {{ _summary.get("state_change_count", 0) }}
                  </div>
                </td>
              </tr>
            </table>

            {% for warning_key in ["translation_incomplete", "estimated_dates", "backfill_dominant"] %}
            {% set _warning = _warnings.get(warning_key, {}) %}
            {% if _warning.get("enabled") %}
            <div style="margin-top:10px;padding:10px 12px;background:#fff7ed;border:1px solid #fdba74;border-radius:10px;color:#9a3412;font-size:12px;">
              {{ _warning.get("message", "") }}
            </div>
            {% endif %}
            {% endfor %}
          </td>
        </tr>

        {% if _issues.get("new") or _issues.get("escalated") or _issues.get("improving") %}
        <tr>
          <td style="padding:0 24px 18px;">
            <div style="font-size:12px;font-weight:700;color:#1e293b;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:10px;">问题变化</div>
            {% for section_key, section_title, section_color in [
              ("new", "新增问题", "#a16207"),
              ("escalated", "升级问题", "#b91c1c"),
              ("improving", "改善问题", "#047857")
            ] %}
            {% for item in _issues.get(section_key, [])[:3] %}
            <div style="padding:10px 12px;border-left:3px solid {{ section_color }};background:#f8fafc;border-radius:0 10px 10px 0;margin-bottom:8px;">
              <div style="font-size:13px;font-weight:700;color:#0f172a;">{{ item.get("label_display", "") }}</div>
              <div style="font-size:12px;color:#475569;margin-top:4px;">{{ section_title }} / 当前评论 {{ item.get("current_review_count", 0) }} / 影响 SKU {{ item.get("affected_product_count", 0) }}</div>
            </div>
            {% endfor %}
            {% endfor %}
          </td>
        </tr>
        {% endif %}

        {% if _products.get("price_changes") or _products.get("stock_changes") %}
        <tr>
          <td style="padding:0 24px 18px;">
            <div style="font-size:12px;font-weight:700;color:#1e293b;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:10px;">产品状态变化</div>
            {% for item in _products.get("price_changes", [])[:5] %}
            <div style="padding:10px 12px;background:#fefce8;border:1px solid #fde68a;border-radius:10px;margin-bottom:8px;font-size:12px;color:#713f12;">
              {{ item.get("name", item.get("sku", "")) }}：{{ item.get("old", "-") }} → {{ item.get("new", "-") }}
            </div>
            {% endfor %}
            {% for item in _products.get("stock_changes", [])[:5] %}
            <div style="padding:10px 12px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;margin-bottom:8px;font-size:12px;color:#334155;">
              {{ item.get("name", item.get("sku", "")) }}：{{ _stock_display.get(item.get("old", "unknown"), "未知") }} → {{ _stock_display.get(item.get("new", "unknown"), "未知") }}
            </div>
            {% endfor %}
          </td>
        </tr>
        {% endif %}

        {% if _fresh_competitor_positive_reviews %}
        <tr>
          <td style="padding:0 24px 18px;">
            <div style="font-size:12px;font-weight:700;color:#1e293b;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:10px;">竞品新近好评</div>
            {% for item in _fresh_competitor_positive_reviews[:3] %}
            <div style="padding:10px 12px;background:#ecfdf5;border:1px solid #86efac;border-radius:10px;margin-bottom:8px;">
              <div style="font-size:13px;font-weight:700;color:#166534;">{{ item.get("product_name", "") }}</div>
              <div style="font-size:12px;color:#166534;margin-top:4px;">{{ item.get("headline_display") or item.get("headline") or "" }}</div>
              {% set _body = item.get("body_display") or item.get("body") %}
              {% if _body %}
              <div style="font-size:12px;color:#166534;margin-top:4px;">{{ _body }}</div>
              {% endif %}
            </div>
            {% endfor %}
          </td>
        </tr>
        {% endif %}

        {% if _risk %}
        <tr>
          <td style="padding:0 24px 18px;">
            <div style="font-size:12px;font-weight:700;color:#1e293b;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:10px;">持续关注</div>
            {% for item in _risk[:3] %}
            <div style="padding:10px 12px;background:#fff7f7;border:1px solid #fecaca;border-radius:10px;margin-bottom:8px;">
              <div style="font-size:13px;font-weight:700;color:#991b1b;">{{ item.get("product_name", "") }}</div>
              <div style="font-size:12px;color:#7f1d1d;margin-top:4px;">差评 {{ item.get("negative_review_rows", 0) }}</div>
            </div>
            {% endfor %}
          </td>
        </tr>
        {% endif %}

        <tr>
          <td style="padding:0 24px 18px;">
            <div style="font-size:12px;font-weight:700;color:#1e293b;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:10px;">行动建议</div>
            {% if _bullets %}
            {% for item in _bullets[:3] %}
            <div style="padding:10px 12px;background:#eef2ff;border:1px solid #c7d2fe;border-radius:10px;margin-bottom:8px;font-size:12px;color:#312e81;">
              {{ item }}
            </div>
            {% endfor %}
            {% else %}
            <div style="padding:10px 12px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;font-size:12px;color:#64748b;">
              当前纳入分析产品 {{ _kpis.get("own_product_count", 0) }} 个，新增评论 {{ _summary.get("ingested_review_count", 0) }} 条。
            </div>
            {% endif %}
          </td>
        </tr>

        {% if report_url %}
        <tr>
          <td style="padding:0 24px 20px;">
            <a href="{{ report_url }}" style="display:block;padding:12px 14px;background:#dbeafe;border:1px solid #93c5fd;border-radius:10px;color:#1d4ed8;font-size:13px;font-weight:700;text-decoration:none;">打开完整 HTML 报告</a>
          </td>
        </tr>
        {% endif %}

        <tr>
          <td style="padding:14px 24px;background:#f8fafc;border-top:1px solid #e2e8f0;font-size:11px;color:#64748b;line-height:1.8;">
            KPI 展示统一读取 analytics.kpis，今日变化统一读取 analytics.change_digest。<br>
            本邮件为自动生成，仅供内部参考。
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>
</body>
</html>
