<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="margin:0;padding:0;background:#f8fafc;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Arial,sans-serif;">
{# ──────────────────────────────────────────────────────────
   F011 §4.1 — email_full.html.j2 重构 (4 KPI 灯 + Hero + Top 3 + 产品状态)
   max-width 640px / table 布局 / 内联 CSS / 无 JS / 无外部 CSS
   ────────────────────────────────────────────────────────── #}

{% set _analytics    = analytics or {} %}
{% set _contract     = _analytics.get("report_user_contract") or {} %}
{% set _kpis         = _contract.get("kpis") or _analytics.get("kpis", {}) %}
{% set _self         = _analytics.get("self", {}) %}
{% set _report_copy  = _analytics.get("report_copy") or {} %}
{% set _bullets      = (_report_copy.get("executive_bullets") or [])[:3] %}
{% set _priorities   = (_contract.get("action_priorities") or _report_copy.get("improvement_priorities") or [])[:3] %}
{% set _hero         = _report_copy.get("hero_headline") or "" %}
{% set _product_status = _self.get("product_status") or [] %}

{# ── KPI 数值 ── #}
{% set _health = _kpis.get("health_index") %}
{% set _own_pos = _kpis.get("own_positive_review_rows", 0) %}
{% set _own_total = _kpis.get("own_review_rows", 0) %}
{% set _own_neg_rate = _kpis.get("own_negative_review_rate", 0) %}
{% set _own_neg_rate_display = _kpis.get("own_negative_review_rate_display") %}
{% set _positive_rate_display = ((_own_pos / _own_total * 100) | round(1)) ~ "%" if _own_total else "—" %}
{% set _own_pc = _kpis.get("own_product_count", 0) %}
{% set _comp_pc = _kpis.get("competitor_product_count", 0) %}
{% set _ingested = _kpis.get("ingested_review_rows", 0) %}

{# ── 健康灯阈值 ≥85 绿 / [70,85) 黄 / <70 红 ── #}
{% set _health_num = _health if _health is number else (_health | float if _health else 0) %}
{% if _health is none or _health == "" %}
  {% set _health_lamp = "gray" %}
  {% set _health_emoji = "⚪" %}
  {% set _health_label = "无数据" %}
{% elif _health_num >= 85 %}
  {% set _health_lamp = "green" %}
  {% set _health_emoji = "🟢" %}
  {% set _health_label = "优秀" %}
{% elif _health_num >= 70 %}
  {% set _health_lamp = "yellow" %}
  {% set _health_emoji = "🟡" %}
  {% set _health_label = "关注" %}
{% else %}
  {% set _health_lamp = "red" %}
  {% set _health_emoji = "🔴" %}
  {% set _health_label = "警戒" %}
{% endif %}

{# ── 差评率灯（参考阈值：≤2% 绿 / (2%,5%] 黄 / >5% 红） ── #}
{% set _neg_pct = (_own_neg_rate * 100) if _own_neg_rate else 0 %}
{% if _own_total == 0 %}
  {% set _neg_lamp = "gray" %}
  {% set _neg_emoji = "⚪" %}
{% elif _neg_pct <= 2 %}
  {% set _neg_lamp = "green" %}
  {% set _neg_emoji = "🟢" %}
{% elif _neg_pct <= 5 %}
  {% set _neg_lamp = "yellow" %}
  {% set _neg_emoji = "🟡" %}
{% else %}
  {% set _neg_lamp = "red" %}
  {% set _neg_emoji = "🔴" %}
{% endif %}

{# ── 好评率灯（统一绿色，量级判断） ── #}
{% set _pos_emoji = "🟢" if _own_total else "⚪" %}
{% set _pos_lamp = "green" if _own_total else "gray" %}

{# ── 需关注产品计数（v1.1 / I2：黄+红灯产品数，非硬编码 risk_score≥25）
       Jinja 的 {% set %} 在 for 循环内是局部作用域，必须用 namespace 跨循环聚合 ── #}
{% set _attention_count_from_kpi = _kpis.get("attention_product_count") %}
{% set _ns = namespace(count=0, first="") %}
{% for ps in _product_status %}
  {% if ps.get("status_lamp") in ("yellow", "red") %}
    {% set _ns.count = _ns.count + 1 %}
    {% if not _ns.first %}{% set _ns.first = ps.get("product_name") or "" %}{% endif %}
  {% endif %}
{% endfor %}
{% set _attention_count = _attention_count_from_kpi if _attention_count_from_kpi is not none else _ns.count %}
{% set _attention_first = _ns.first %}
{% if _attention_count == 0 %}
  {% set _attention_lamp = "green" %}
  {% set _attention_emoji = "🟢" %}
{% elif _attention_count <= 1 %}
  {% set _attention_lamp = "yellow" %}
  {% set _attention_emoji = "🟡" %}
{% else %}
  {% set _attention_lamp = "red" %}
  {% set _attention_emoji = "🔴" %}
{% endif %}

{# ── 产品状态灯 emoji 映射 ── #}
{% set _lamp_emoji_map = {"red": "🔴", "yellow": "🟡", "green": "🟢", "gray": "⚪"} %}

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#f8fafc;">
  <tr>
    <td align="center" style="padding:20px 12px;">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="max-width:640px;background:#ffffff;border-radius:12px;overflow:hidden;border:1px solid #e2e8f0;">

        {# ── 1. 标题 + 副标题 ── #}
        <tr>
          <td style="padding:20px 24px 8px;">
            <div style="font-size:18px;font-weight:800;color:#0f172a;line-height:1.3;">QBU 评论分析 · {{ logical_date }}</div>
            <div style="font-size:12px;color:#64748b;margin-top:6px;">
              本期 自有 {{ _own_pc }} 款 / 竞品 {{ _comp_pc }} 款 / 共 {{ _ingested }} 条评论
            </div>
          </td>
        </tr>

        {# ── 2. KPI 灯条（4 张语义灯） ── #}
        <tr>
          <td style="padding:12px 24px 16px;">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
              {# 总体口碑 #}
              <tr class="lamp-{{ _health_lamp }}">
                <td style="padding:10px 12px;border:1px solid #e2e8f0;border-radius:8px;background:#fbfdff;font-size:13px;color:#0f172a;">
                  <span style="font-size:16px;">{{ _health_emoji }}</span>
                  <strong style="margin-left:6px;">总体口碑</strong>
                  <span style="margin-left:8px;color:#475569;">
                    {{ _health_label }}{% if _health is not none and _health != "" %} ({{ _health }}){% endif %}
                  </span>
                </td>
              </tr>
              <tr><td style="height:6px;line-height:6px;font-size:0;">&nbsp;</td></tr>
              {# 好评率 #}
              <tr class="lamp-{{ _pos_lamp }}">
                <td style="padding:10px 12px;border:1px solid #e2e8f0;border-radius:8px;background:#fbfdff;font-size:13px;color:#0f172a;">
                  <span style="font-size:16px;">{{ _pos_emoji }}</span>
                  <strong style="margin-left:6px;">好评率</strong>
                  <span style="margin-left:8px;color:#475569;">{{ _positive_rate_display }}</span>
                </td>
              </tr>
              <tr><td style="height:6px;line-height:6px;font-size:0;">&nbsp;</td></tr>
              {# 差评率 #}
              <tr class="lamp-{{ _neg_lamp }}">
                <td style="padding:10px 12px;border:1px solid #e2e8f0;border-radius:8px;background:#fbfdff;font-size:13px;color:#0f172a;">
                  <span style="font-size:16px;">{{ _neg_emoji }}</span>
                  <strong style="margin-left:6px;">差评率</strong>
                  <span style="margin-left:8px;color:#475569;">
                    {{ _own_neg_rate_display or ((_neg_pct | round(1)) ~ "%") }} (≤2 星 / 自有评论)
                  </span>
                </td>
              </tr>
              <tr><td style="height:6px;line-height:6px;font-size:0;">&nbsp;</td></tr>
              {# 需关注产品 #}
              <tr class="lamp-{{ _attention_lamp }}">
                <td style="padding:10px 12px;border:1px solid #e2e8f0;border-radius:8px;background:#fbfdff;font-size:13px;color:#0f172a;">
                  <span style="font-size:16px;">{{ _attention_emoji }}</span>
                  <strong style="margin-left:6px;">需关注产品 {{ _attention_count }} 个</strong>
                  {% if _attention_first %}
                  <span style="margin-left:8px;color:#475569;">{{ _attention_first }}{% if _attention_count > 1 %} 等{% endif %}</span>
                  {% endif %}
                </td>
              </tr>
            </table>
          </td>
        </tr>

        {# ── 3. 关键判断（Hero + 3 bullets） ── #}
        {% if _hero or _bullets %}
        <tr>
          <td style="padding:0 24px 16px;">
            <div style="font-size:11px;font-weight:700;color:#1e293b;letter-spacing:0.08em;text-transform:uppercase;">关键判断</div>
            {% if _hero %}
            <div style="margin-top:8px;padding:12px 14px;background:#f1f5f9;border-left:3px solid #1d4ed8;border-radius:0 8px 8px 0;font-size:14px;color:#0f172a;line-height:1.55;">
              {{ _hero }}
            </div>
            {% endif %}
            {% if _bullets %}
            <ul style="margin:10px 0 0;padding-left:20px;color:#334155;font-size:13px;line-height:1.7;">
              {% for b in _bullets %}
              <li>{{ b }}</li>
              {% endfor %}
            </ul>
            {% endif %}
          </td>
        </tr>
        {% endif %}

        {# ── 4. Top 3 行动建议 ── #}
        {% if _priorities %}
        <tr>
          <td style="padding:0 24px 16px;">
            <div style="font-size:11px;font-weight:700;color:#1e293b;letter-spacing:0.08em;text-transform:uppercase;">Top 3 行动建议</div>
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-top:8px;">
              {% for item in _priorities %}
              <tr>
                <td style="padding:10px 12px;background:#fef9c3;border:1px solid #fde68a;border-radius:8px;font-size:13px;color:#713f12;">
                  <strong>{{ loop.index }}.</strong>
                  {% if item.get("label_display") %}[{{ item.get("label_display") }}] {% endif %}
                  {{ item.get("short_title") or item.get("label_display") or "" }}
                  · 影响 {{ item.get("affected_products_count") or 0 }} 款
                </td>
              </tr>
              {% if not loop.last %}<tr><td style="height:6px;line-height:6px;font-size:0;">&nbsp;</td></tr>{% endif %}
              {% endfor %}
            </table>
          </td>
        </tr>
        {% endif %}

        {# ── 5. 自有产品状态（Task 3.4 才会填充 product_status；为空时整块跳过） ── #}
        {% if _product_status %}
        <tr>
          <td style="padding:0 24px 16px;">
            <div style="font-size:11px;font-weight:700;color:#1e293b;letter-spacing:0.08em;text-transform:uppercase;">自有产品状态</div>
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-top:8px;">
              {% for ps in _product_status[:5] %}
              {% set _lamp = ps.get("status_lamp") or "gray" %}
              <tr>
                <td style="padding:8px 10px;border:1px solid #e2e8f0;border-radius:6px;background:#ffffff;font-size:13px;color:#0f172a;">
                  <span style="font-size:14px;">{{ _lamp_emoji_map.get(_lamp, "⚪") }}</span>
                  <span style="margin-left:6px;font-weight:600;">{{ ps.get("product_name") or "(未知产品)" }}</span>
                  <span style="margin-left:10px;color:#475569;">
                    {{ ps.get("primary_concern") or ("无数据" if _lamp == "gray" else "健康") }}
                  </span>
                </td>
              </tr>
              {% if not loop.last %}<tr><td style="height:4px;line-height:4px;font-size:0;">&nbsp;</td></tr>{% endif %}
              {% endfor %}
            </table>
          </td>
        </tr>
        {% endif %}

        {# ── 6. 附件链接 ── #}
        <tr>
          <td style="padding:4px 24px 18px;">
            <div style="font-size:12px;color:#475569;line-height:1.8;">
              ▶ 详情 / 评论原文见附件 HTML<br>
              ▶ 数据下钻见 Excel 附件
            </div>
          </td>
        </tr>

        <tr>
          <td style="padding:12px 24px;background:#f8fafc;border-top:1px solid #e2e8f0;font-size:11px;color:#94a3b8;line-height:1.6;">
            本邮件为 QBU 自动生成报告，仅供内部参考。
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>
</body>
</html>
