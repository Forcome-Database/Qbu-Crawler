<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <!--[if mso]><noscript><xml><o:OfficeDocumentSettings><o:AllowPNG/><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings></xml></noscript><![endif]-->
  <!--[if mso]><style>table{border-collapse:collapse;}td{font-family:Arial,sans-serif;}</style><![endif]-->
</head>
<body style="margin:0;padding:0;background:#f8fafc;font-family:system-ui,-apple-system,'Segoe UI',Roboto,Arial,sans-serif;-webkit-font-smoothing:antialiased;">

{# ── Defensive variable normalization ───────────────────────────────────── #}
{% set _kpis = cumulative_kpis if cumulative_kpis is defined and cumulative_kpis else (analytics.kpis if analytics is defined and analytics.kpis is defined else {}) %}
{% set _win = window if window is defined and window else {} %}
{% set _changes = changes if changes is defined and changes else {} %}
{% set _new = new_review_summary if new_review_summary is defined and new_review_summary else {} %}
{% set _alert = alert_level or "green" %}
{% set _conf = health_confidence if health_confidence is defined else _kpis.get("health_confidence", "high") %}

{# ── Alert level colors ──────────────────────────────────────────────────── #}
{% if _alert == "red" %}
  {% set hero_bg = "#fef2f2" %}{% set hero_color = "#b91c1c" %}{% set abg = "#b91c1c" %}
{% elif _alert == "yellow" %}
  {% set hero_bg = "#fefce8" %}{% set hero_color = "#a16207" %}{% set abg = "#a16207" %}
{% else %}
  {% set hero_bg = "#ecfdf5" %}{% set hero_color = "#047857" %}{% set abg = "#047857" %}
{% endif %}

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#f8fafc;">
<tr><td align="center" style="padding:20px 10px;">

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="max-width:600px;background:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.07);">

  <!-- ===== 1. HEADER BAR ===== -->
  <tr>
    <td style="background:#4f46e5;padding:16px 24px;">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
        <tr>
          <td style="color:#ffffff;font-size:12px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;">QBU 网评监控</td>
          <td style="color:rgba(255,255,255,0.65);font-size:11px;text-align:right;white-space:nowrap;">{{ logical_date }}</td>
        </tr>
      </table>
    </td>
  </tr>

  <!-- ===== 2. HEALTH HERO (cumulative) ===== -->
  <tr>
    <td style="background:{{ hero_bg }};padding:28px 24px 20px;text-align:center;">
      <div style="font-size:10px;color:{{ hero_color }};letter-spacing:0.15em;text-transform:uppercase;opacity:0.75;margin-bottom:8px;">产品健康指数（累积）</div>
      <div style="font-size:52px;font-weight:900;color:{{ hero_color }};line-height:1;margin-bottom:6px;">{{ _kpis.get("health_index", "—") if _kpis else "—" }}</div>
      {# Delta display #}
      {% set _hi_delta = _kpis.get("health_index_delta_display", "") if _kpis else "" %}
      {% if _hi_delta %}
      <div style="font-size:12px;color:{{ hero_color }};opacity:0.8;margin-bottom:4px;">{{ _hi_delta }}</div>
      {% endif %}
      {# Confidence warning #}
      {% if _conf == "low" %}
      <div style="font-size:11px;color:{{ hero_color }};opacity:0.7;margin-bottom:4px;">&#9888; 样本仅 {{ _kpis.get("own_review_rows", 0) if _kpis else 0 }} 条，置信度低</div>
      {% elif _conf == "medium" %}
      <div style="font-size:11px;color:{{ hero_color }};opacity:0.7;margin-bottom:4px;">样本 {{ _kpis.get("own_review_rows", 0) if _kpis else 0 }} 条，置信度中等</div>
      {% elif _conf == "no_data" %}
      <div style="font-size:11px;color:{{ hero_color }};opacity:0.7;margin-bottom:4px;">&#9888; 暂无足够评论数据</div>
      {% endif %}
      <div style="font-size:12px;color:{{ hero_color }};opacity:0.55;">/ 100 · 累积全量评论</div>
    </td>
  </tr>

  <!-- ===== 3. ALERT BANNER ===== -->
  {% set _alert_text = alert_text or "" %}
  {% if _alert_text %}
  <tr>
    <td style="background:{{ abg }};padding:10px 24px;text-align:center;">
      <span style="color:#ffffff;font-size:12px;font-weight:600;">{{ _alert_text }}</span>
    </td>
  </tr>
  {% endif %}

  <!-- ===== 4. 累积概览 SECTION HEADER ===== -->
  <tr>
    <td style="padding:20px 24px 4px;">
      <div style="font-size:11px;font-weight:700;color:#4f46e5;letter-spacing:0.08em;text-transform:uppercase;border-bottom:2px solid #eef2ff;padding-bottom:6px;">&#128202; 累积概览</div>
    </td>
  </tr>

  <!-- ===== 5. KPI CARDS (cumulative, 3-column) ===== -->
  <tr>
    <td style="padding:12px 24px 8px;">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
        <tr>
          <!-- Card 1: 自有评论 -->
          <td width="32%" style="padding:12px 10px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;text-align:center;vertical-align:top;">
            <div style="font-size:10px;color:#64748b;margin-bottom:6px;">自有评论</div>
            <div style="font-size:24px;font-weight:800;color:#1e293b;line-height:1;">{{ _kpis.get("own_review_rows", 0) if _kpis else 0 }}</div>
            {% set _d1 = _kpis.get("ingested_review_rows_delta_display", "") if _kpis else "" %}
            {% if _d1 %}<div style="font-size:10px;color:#94a3b8;margin-top:4px;">{{ _d1 }}</div>{% endif %}
          </td>
          <td width="2%"></td>
          <!-- Card 2: 自有差评率 -->
          <td width="32%" style="padding:12px 10px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;text-align:center;vertical-align:top;">
            <div style="font-size:10px;color:#64748b;margin-bottom:6px;">自有差评率</div>
            <div style="font-size:24px;font-weight:800;color:#b91c1c;line-height:1;">{{ _kpis.get("own_negative_review_rate_display", "—") if _kpis else "—" }}</div>
            {% set _d2 = _kpis.get("negative_review_rows_delta_display", "") if _kpis else "" %}
            {% if _d2 %}<div style="font-size:10px;color:#94a3b8;margin-top:4px;">{{ _d2 }}</div>{% endif %}
          </td>
          <td width="2%"></td>
          <!-- Card 3: 高风险产品 -->
          <td width="32%" style="padding:12px 10px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;text-align:center;vertical-align:top;">
            <div style="font-size:10px;color:#64748b;margin-bottom:6px;">高风险产品</div>
            <div style="font-size:24px;font-weight:800;color:#b91c1c;line-height:1;">{{ _kpis.get("high_risk_count", 0) if _kpis else 0 }}</div>
            <div style="font-size:10px;color:#94a3b8;margin-top:4px;">自有 {{ _kpis.get("own_product_count", 0) if _kpis else 0 }} / 竞品 {{ _kpis.get("competitor_product_count", 0) if _kpis else 0 }}</div>
          </td>
        </tr>
      </table>
    </td>
  </tr>

  <!-- ===== 6. 今日变化 SECTION HEADER ===== -->
  <tr>
    <td style="padding:16px 24px 4px;">
      <div style="font-size:11px;font-weight:700;color:#0284c7;letter-spacing:0.08em;text-transform:uppercase;border-bottom:2px solid #e0f2fe;padding-bottom:6px;">&#128204; 今日变化 ({{ logical_date }})</div>
    </td>
  </tr>

  <!-- ===== 7. TODAY'S CHANGES BLOCK ===== -->
  {% set _win_count = _win.get("reviews_count", 0) %}
  {% set _win_own = _win.get("own_reviews_count", _new.get("own_count", 0)) %}
  {% set _win_comp = _win.get("competitor_reviews_count", _new.get("comp_count", 0)) %}
  {% set _win_neg = _win.get("new_negative_count", _new.get("own_negative", 0)) %}
  {# Cluster changes from changes dict #}
  {% set _escalated = _changes.get("escalated", []) if _changes else [] %}
  {% set _new_issues = _changes.get("new", []) if _changes else [] %}
  {% set _improving = _changes.get("improving", []) if _changes else [] %}
  {# Price/stock changes (only present if detect_snapshot_changes result is passed) #}
  {% set _price = _changes.get("price_changes", []) if _changes else [] %}
  {% set _stock = _changes.get("stock_changes", []) if _changes else [] %}

  <tr>
    <td style="padding:10px 24px 16px;">

      {# ── Review count row ── #}
      {% if _win_count > 0 or _win_own > 0 or _win_comp > 0 %}
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:10px;border-left:3px solid #0284c7;border-radius:0 6px 6px 0;background:#f0f9ff;">
        <tr><td style="padding:10px 14px;">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
            <tr>
              <td style="font-size:11px;color:#0369a1;font-weight:700;">新增评论</td>
              <td style="text-align:right;">
                {% set _total_new = [_win_count, _win_own + _win_comp] | max %}
                {% if _total_new > 0 %}<span style="display:inline-block;padding:2px 10px;background:#4f46e5;color:#fff;border-radius:999px;font-size:11px;font-weight:700;">+{{ _total_new }} 条</span>{% endif %}
                {% if _win_own > 0 %}<span style="display:inline-block;padding:2px 8px;background:#dbeafe;color:#1d4ed8;border-radius:999px;font-size:10px;margin-left:4px;">自有 {{ _win_own }}</span>{% endif %}
                {% if _win_comp > 0 %}<span style="display:inline-block;padding:2px 8px;background:#e5e7eb;color:#374151;border-radius:999px;font-size:10px;margin-left:4px;">竞品 {{ _win_comp }}</span>{% endif %}
                {% if _win_neg > 0 %}<span style="display:inline-block;padding:2px 8px;background:#fee2e2;color:#b91c1c;border-radius:999px;font-size:10px;font-weight:700;margin-left:4px;">差评 {{ _win_neg }}</span>{% endif %}
              </td>
            </tr>
          </table>
        </td></tr>
      </table>
      {% else %}
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:10px;border-left:3px solid #94a3b8;border-radius:0 6px 6px 0;background:#f8fafc;">
        <tr><td style="padding:10px 14px;font-size:11px;color:#64748b;">今日无新增评论</td></tr>
      </table>
      {% endif %}

      {# ── Cluster changes (escalated / new / improving) ── #}
      {% if _escalated %}
      <div style="font-size:10px;color:#b91c1c;font-weight:700;margin:8px 0 4px;letter-spacing:0.08em;">&#9650; 风险升级</div>
      {% for iss in _escalated[:3] %}
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:4px;"><tr>
        <td width="10" valign="top" style="padding-top:4px;"><div style="width:6px;height:6px;border-radius:50%;background:#b91c1c;"></div></td>
        <td style="padding-left:8px;font-size:12px;color:#1e293b;line-height:1.5;"><strong>{{ iss.get("label_display", "") }}</strong><span style="color:#94a3b8;"> — {{ iss.get("review_count", 0) }} 条 ▲升级</span></td>
      </tr></table>
      {% endfor %}
      {% endif %}

      {% if _new_issues %}
      <div style="font-size:10px;color:#a16207;font-weight:700;margin:8px 0 4px;letter-spacing:0.08em;">&#9733; 新发现问题</div>
      {% for iss in _new_issues[:3] %}
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:4px;"><tr>
        <td width="10" valign="top" style="padding-top:4px;"><div style="width:6px;height:6px;border-radius:50%;background:#a16207;"></div></td>
        <td style="padding-left:8px;font-size:12px;color:#1e293b;line-height:1.5;"><strong>{{ iss.get("label_display", "") }}</strong><span style="color:#94a3b8;"> — {{ iss.get("review_count", 0) }} 条 ★新发现</span></td>
      </tr></table>
      {% endfor %}
      {% endif %}

      {% if _improving %}
      <div style="font-size:10px;color:#047857;font-weight:700;margin:8px 0 4px;letter-spacing:0.08em;">&#9660; 改善中</div>
      {% for iss in _improving[:2] %}
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:4px;"><tr>
        <td width="10" valign="top" style="padding-top:4px;"><div style="width:6px;height:6px;border-radius:50%;background:#047857;"></div></td>
        <td style="padding-left:8px;font-size:12px;color:#1e293b;line-height:1.5;"><strong>{{ iss.get("label_display", "") }}</strong><span style="color:#047857;"> ▼改善中</span></td>
      </tr></table>
      {% endfor %}
      {% endif %}

      {# ── Price changes ── #}
      {% if _price %}
      <div style="font-size:10px;color:#a16207;font-weight:700;margin:10px 0 6px;letter-spacing:0.08em;">&#128176; 价格变动（{{ _price | length }}个）</div>
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border-collapse:collapse;font-size:11px;margin-bottom:10px;">
        <tr>
          <td style="padding:5px 8px;font-weight:700;background:#fef9c3;color:#854d0e;border-radius:4px 0 0 0;">产品</td>
          <td style="padding:5px 8px;font-weight:700;background:#fef9c3;color:#854d0e;text-align:center;">旧价</td>
          <td style="padding:5px 8px;font-weight:700;background:#fef9c3;color:#854d0e;text-align:center;border-radius:0 4px 0 0;">新价</td>
        </tr>
        {% for item in _price[:5] %}
        {% set _up = (item.get("new") or 0) > (item.get("old") or 0) %}
        <tr style="background:{% if loop.index is odd %}#fefce8{% else %}#ffffff{% endif %};">
          <td style="padding:5px 8px;border-bottom:1px solid #fef08a;color:#1e293b;font-size:10px;">{{ item.get("name", item.get("sku", "")) }}</td>
          <td style="padding:5px 8px;border-bottom:1px solid #fef08a;text-align:center;color:#94a3b8;text-decoration:line-through;">${{ item.get("old", "—") }}</td>
          <td style="padding:5px 8px;border-bottom:1px solid #fef08a;text-align:center;font-weight:700;color:{% if _up %}#b91c1c{% else %}#047857{% endif %};">${{ item.get("new", "—") }} {% if _up %}▲{% else %}▼{% endif %}</td>
        </tr>
        {% endfor %}
        {% if _price | length > 5 %}<tr><td colspan="3" style="padding:4px 8px;font-size:10px;color:#94a3b8;text-align:center;background:#fefce8;">还有 {{ (_price | length) - 5 }} 个变动...</td></tr>{% endif %}
      </table>
      {% endif %}

      {# ── Stock changes ── #}
      {% if _stock %}
      {% set _stock_display = {"in_stock": "有货", "out_of_stock": "缺货"} %}
      <div style="font-size:10px;color:#374151;font-weight:700;margin:10px 0 6px;letter-spacing:0.08em;">&#128230; 库存变动（{{ _stock | length }}个）</div>
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border-collapse:collapse;font-size:11px;margin-bottom:10px;">
        <tr>
          <td style="padding:5px 8px;font-weight:700;background:#f1f5f9;color:#374151;border-radius:4px 0 0 0;">产品</td>
          <td style="padding:5px 8px;font-weight:700;background:#f1f5f9;color:#374151;text-align:center;">旧状态</td>
          <td style="padding:5px 8px;font-weight:700;background:#f1f5f9;color:#374151;text-align:center;border-radius:0 4px 0 0;">新状态</td>
        </tr>
        {% for item in _stock[:5] %}
        <tr style="background:{% if loop.index is odd %}#f8fafc{% else %}#ffffff{% endif %};">
          <td style="padding:5px 8px;border-bottom:1px solid #e2e8f0;color:#1e293b;font-size:10px;">{{ item.get("name", item.get("sku", "")) }}</td>
          <td style="padding:5px 8px;border-bottom:1px solid #e2e8f0;text-align:center;color:#94a3b8;">{{ _stock_display.get(item.get("old"), "未知") }}</td>
          <td style="padding:5px 8px;border-bottom:1px solid #e2e8f0;text-align:center;font-weight:700;color:{% if item.get('new') == 'in_stock' %}#047857{% elif item.get('new') == 'out_of_stock' %}#b91c1c{% else %}#8e8ea0{% endif %};">{{ _stock_display.get(item.get("new"), "未知") }}</td>
        </tr>
        {% endfor %}
      </table>
      {% endif %}

      {# ── Empty today's changes state ── #}
      {% if not _escalated and not _new_issues and not _improving and not _price and not _stock and (_win_count == 0 and _win_own == 0 and _win_comp == 0) %}
      <div style="font-size:11px;color:#94a3b8;font-style:italic;">今日无显著变化</div>
      {% endif %}

    </td>
  </tr>

  <!-- ===== 8. 持续关注 — RISK PRODUCTS TOP 3 (cumulative) ===== -->
  {% set _risk = risk_products if risk_products is defined and risk_products else [] %}
  {% if _risk %}
  <tr>
    <td style="padding:4px 24px 4px;">
      <div style="font-size:11px;font-weight:700;color:#dc2626;letter-spacing:0.08em;text-transform:uppercase;border-bottom:2px solid #fee2e2;padding-bottom:6px;">&#128680; 持续关注</div>
    </td>
  </tr>
  <tr>
    <td style="padding:10px 24px 16px;">
      {% for item in _risk[:3] %}
      {% if _alert == "red" %}{% set _lborder = "#b91c1c" %}
      {% elif _alert == "yellow" %}{% set _lborder = "#a16207" %}
      {% else %}{% set _lborder = "#64748b" %}{% endif %}
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:8px;border-left:3px solid {{ _lborder }};border-radius:0 6px 6px 0;background:#fff7f7;">
        <tr><td style="padding:10px 14px;">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
            <tr>
              <td style="font-size:12px;font-weight:700;color:#1e293b;">{{ item.get("product_name", "") }}</td>
              <td style="text-align:right;white-space:nowrap;">
                <span style="display:inline-block;padding:2px 8px;background:#fee2e2;color:#b91c1c;border-radius:999px;font-size:11px;font-weight:700;">差评 {{ item.get("negative_review_rows", 0) }}</span>
              </td>
            </tr>
          </table>
          {% set _top_labels = item.get("top_labels_display", "") or "" %}
          {% if _top_labels %}
          <div style="font-size:10px;color:#64748b;margin-top:4px;">主要问题：{{ _top_labels }}</div>
          {% endif %}
        </td></tr>
      </table>
      {% endfor %}
    </td>
  </tr>
  {% endif %}

  <!-- ===== 9. 行动建议 — AI EXECUTIVE BULLETS ===== -->
  {% set _bullets = [] %}
  {% if report_copy is defined and report_copy %}
    {% set _bullets = report_copy.get("executive_bullets", []) %}
  {% elif analytics is defined and analytics and analytics.report_copy is defined %}
    {% set _bullets = analytics.report_copy.get("executive_bullets", []) %}
  {% endif %}
  <tr>
    <td style="padding:4px 24px 4px;">
      <div style="font-size:11px;font-weight:700;color:#4f46e5;letter-spacing:0.08em;text-transform:uppercase;border-bottom:2px solid #eef2ff;padding-bottom:6px;">&#128161; 行动建议</div>
    </td>
  </tr>
  <tr>
    <td style="padding:10px 24px 16px;">
      {% for item in _bullets[:3] %}
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:10px;"><tr>
        <td width="28" valign="top" style="padding-top:1px;">
          <div style="width:22px;height:22px;background:#4f46e5;border-radius:50%;text-align:center;line-height:22px;font-size:11px;font-weight:700;color:#ffffff;">{{ loop.index }}</div>
        </td>
        <td style="padding-left:10px;font-size:12px;color:#1e293b;line-height:1.65;">{{ item }}</td>
      </tr></table>
      {% else %}
      <p style="font-size:12px;color:#94a3b8;margin:0;font-style:italic;">当前暂无足够样本形成明确判断。</p>
      {% endfor %}
    </td>
  </tr>

  <!-- ===== 10. REPORT LINK ===== -->
  {% if report_url is defined and report_url %}
  <tr>
    <td style="padding:4px 24px 16px;background:#f8fafc;border-top:1px solid #e2e8f0;">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-top:8px;"><tr>
        <td style="padding:10px 14px;background:#eef2ff;border:1px solid #c7d2fe;border-radius:8px;font-size:12px;color:#1e293b;">
          &#128196; <a href="{{ report_url }}" style="color:#4f46e5;font-weight:700;text-decoration:none;">打开完整交互式分析报告</a>
          <span style="color:#94a3b8;font-size:10px;"> — 包含图表、问题详情与评论摘录</span>
        </td>
      </tr></table>
    </td>
  </tr>
  {% endif %}

  <!-- ===== 11. FOOTER ===== -->
  <tr>
    <td style="padding:12px 24px;text-align:center;border-top:1px solid #e2e8f0;background:#f8fafc;">
      <p style="margin:0;font-size:10px;color:#94a3b8;line-height:1.7;">
        QBU 网评监控智能分析系统 · 差评定义：&#8804;{{ threshold or 2 }}星 · 内部资料<br>
        KPI 卡片数据为累积全量基础；今日变化为本次抓取窗口增量<br>
        本报告由 AI 自动生成，数据及分析结论仅供参考 · 请勿直接回复此邮件
      </p>
    </td>
  </tr>

</table>
</td></tr>
</table>
</body>
</html>
