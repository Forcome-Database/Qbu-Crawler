{% extends "_email_base.html.j2" %}
{% block content %}
  {% if headline %}<h2 style="font-family:Georgia,serif;font-size:18px;margin:0 0 8px;">{{ headline }}</h2>{% endif %}
  {% if bullets %}
  <ul style="font-size:13px;margin:12px 0;padding-left:18px;">
    {% for b in bullets %}<li>{{ b }}</li>{% endfor %}
  </ul>
  {% endif %}
  {% if issue_cards %}
  <h4 style="margin:16px 0 6px;font-size:13px;color:#555770;letter-spacing:0.08em;text-transform:uppercase;">本周关键问题</h4>
  <ul style="font-size:13px;padding-left:18px;">
    {% for c in issue_cards[:3] %}
    <li>{{ c.label_display }} — {{ c.review_count }} 条</li>
    {% endfor %}
  </ul>
  {% endif %}
{% endblock %}
