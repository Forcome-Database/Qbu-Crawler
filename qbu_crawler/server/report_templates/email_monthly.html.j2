{% extends "_email_base.html.j2" %}
{% block content %}
  {% if stance_label %}
  <p style="font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:#8e8ea0;margin:0 0 4px;">
    月度态势 · {{ stance_label }}
  </p>
  {% endif %}
  {% if headline %}
  <h2 style="font-family:Georgia,serif;font-size:22px;margin:0 0 4px;line-height:1.25;">{{ headline }}</h2>
  {% endif %}

  {% if bullets %}
  <ul style="font-size:14px;margin:16px 0;padding-left:20px;">
    {% for b in bullets %}<li>{{ b }}</li>{% endfor %}
  </ul>
  {% endif %}

  {% if actions %}
  <div style="margin:20px 0;padding:14px 16px;background:#eef2ff;border-left:3px solid #4f46e5;border-radius:4px;">
    <div style="font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:#4338ca;margin-bottom:8px;font-weight:600;">
      建议行动 Top {{ actions|length }}
    </div>
    <ol style="font-size:13px;margin:0;padding-left:20px;">
      {% for a in actions %}<li>{{ a }}</li>{% endfor %}
    </ol>
  </div>
  {% endif %}

  {% if safety_count and safety_count > 0 %}
  <p style="background:rgba(185,28,28,0.08);padding:10px 14px;border-radius:6px;color:#b91c1c;font-size:13px;margin-top:16px;">
    ⚠ 本月 {{ safety_count }} 起安全事件（详情见完整报告）
  </p>
  {% endif %}
{% endblock %}
