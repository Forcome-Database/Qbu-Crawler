      "name": "export_review_images",
      "output_schema": {
        "additionalProperties": true,
        "properties": {
          "artifact": {
            "type": "object"
          },
          "data": {
            "type": "object"
          },
          "error": {
            "type": "string"
          },
          "scope": {
            "type": "object"
          }
        },
        "type": "object"
      },
      "supports": [
        "review-image export only"
      ],
      "tier": "produce_action",
      "time_axes": [
        "review_ingest_time",
        "review_publish_time",
        "product_state_time"
      ]
    },
    "generate_report": {
