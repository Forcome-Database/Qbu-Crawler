# ── MinIO ──
MINIO_ENDPOINT=192.168.16.116
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=your-access-key
MINIO_SECRET_KEY=your-secret-key
MINIO_BUCKET=qbu-crawler
MINIO_PUBLIC_URL=https://minio-api.forcome.com

# ── Server ──
QBU_DATA_DIR=./data
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
API_KEY=your-api-key
MAX_WORKERS=3
TASK_STALE_SECONDS=900
WORKFLOW_INTERVAL=15
WORKFLOW_NOTIFICATION_TARGET=chat:cid-your-daily-room
NOTIFIER_INTERVAL=5
NOTIFIER_LEASE_SECONDS=60
NOTIFIER_MAX_ATTEMPTS=3
LOCAL_API_BASE_URL=http://127.0.0.1:8000
DAILY_SCHEDULER_TIME=08:00
DAILY_SCHEDULER_INTERVAL=30
DAILY_SCHEDULER_RETRY_SECONDS=300

# ── Rollout feature flags（重构期间必须显式管理）──
NOTIFICATION_MODE=outbox
DAILY_SUBMIT_MODE=embedded
REPORT_MODE=legacy
AI_DIGEST_MODE=off

# ── Chrome 用户数据（绕过 Akamai 等严格反爬，留空则用独立浏览器）──
#
# ⚠ 强烈建议使用 *专属* 目录，不要直接指向用户真实的 Chrome profile。
# 用户个人 Chrome 运行时（甚至后台保持运行时）会持有 SingletonLock，
# 我们 Popen 的 Chrome 会把命令 IPC 给它后自己退出 → 采集死循环。
#
# 推荐配置：
#   CHROME_USER_DATA_PATH=C:\QbuCrawlerProfile          # 专属目录（爬虫 Chrome 用）
#   CHROME_USER_DATA_SEED=C:\Users\USER\AppData\Local\Google\Chrome\User Data  # 真实 profile（仅用于首次种子复制）
#
# 首次启动若 CHROME_USER_DATA_PATH 目录不存在，会从 SEED 目录复制几个关键文件
# （Default/Cookies、Default/Preferences、Local State），让 Akamai _abck cookie
# 从用户真实 profile 继承过来。之后 Chrome 专属目录与用户 Chrome 互不干扰。
#
# 仅设 PATH 不设 SEED：Chrome 用空白 profile 启动（Akamai 挑战需手动完成一次）
# 都留空：用独立浏览器（auto_port + 临时 profile），遇 Akamai 会 403
CHROME_USER_DATA_PATH=
CHROME_USER_DATA_SEED=
CHROME_USER_DATA_COPY_PREFERENCES=false
CHROME_USER_DATA_COPY_LOCAL_STATE=false

# ── 代理池（遇到反爬封锁时自动获取代理 IP，留空则不使用）──
# 1024proxy API 地址（完整 URL 含参数，返回 ip:port 格式）
PROXY_API_URL=
PROXY_MAX_RETRIES=3
# 指定站点直接走代理，跳过直连（逗号分隔：basspro,waltons,meatyourmaker）
PROXY_SITES=basspro

# ── OpenClaw（legacy/shadow 模式下的旧 webhook 通知路径）──
OPENCLAW_HOOK_URL=http://127.0.0.1:18789
OPENCLAW_HOOK_TOKEN=your-hooks-token
OPENCLAW_BRIDGE_URL=http://127.0.0.1:18888/notify
OPENCLAW_BRIDGE_TOKEN=your-bridge-token
OPENCLAW_BRIDGE_TIMEOUT=15

# ── LLM Translation (OpenAI-compatible) ──
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=sk-xxx
LLM_MODEL=gpt-4o-mini
LLM_TRANSLATE_BATCH_SIZE=20
TRANSLATE_INTERVAL=60
TRANSLATE_MAX_RETRIES=3
TRANSLATE_WORKERS=3

# ── Email SMTP ──
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=your-password
SMTP_FROM=noreply@example.com
SMTP_USE_SSL=false

# ── Report ──
REPORT_DIR=
OPENCLAW_WORKSPACE_DIR=
DAILY_SOURCE_CSV_PATH=
DAILY_PRODUCT_CSV_PATH=
# Configure both remote URLs together, or leave both blank.
DAILY_SOURCE_CSV_URL=
DAILY_PRODUCT_CSV_URL=

# ── Report Thresholds ──
REPORT_NEGATIVE_THRESHOLD=2
REPORT_LOW_RATING_THRESHOLD=3
REPORT_HEALTH_RED=45
REPORT_HEALTH_YELLOW=60
REPORT_HIGH_RISK_THRESHOLD=35

# ── Report Mode (P006+P007) ──────────────────────
REPORT_PERSPECTIVE=dual              # dual（累积+增量双视角）| window（仅当日窗口）
REPORT_LABEL_MODE=rule               # rule（规则分类）| hybrid（规则+LLM）
REPORT_QUIET_EMAIL_DAYS=3            # 连续静默天数内每天发邮件，之后按周发

# ── 数据质量监控 ──
# 数据质量告警阈值（任一字段缺失率 ≥ 此值触发独立告警邮件）
SCRAPE_QUALITY_ALERT_RATIO=0.10
# 数据质量告警收件人（留空则沿用业务报告收件人）
SCRAPE_QUALITY_ALERT_RECIPIENTS=

# 报告模板版本 (F011 v1.1)
# v3 (default) / v3_legacy (rollback)
# REPORT_TEMPLATE_VERSION=v3
